      </g>
      <g fill="none" stroke="#7a5020" stroke-width="3" stroke-linecap="round">
        <path d="M52 28 Q38 18 32 28 Q26 40 34 50 Q44 56 52 48" opacity=".6"/>
      </g>
      <!-- Horn ridge lines -->
      <g stroke="#3a2008" stroke-width=".8" fill="none" opacity=".5">
        <path d="M46 22 Q34 24 30 34"/><path d="M40 26 Q28 32 28 44"/>
      </g>
      <ellipse cx="62" cy="83" rx="30" ry="4" fill="#3a1c06" opacity=".18"/>
    </svg>`,

    'pronghorn': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#d4b860" opacity=".18"/>
      <!-- Flat sagebrush plain -->
      <line x1="0" y1="72" x2="120" y2="72" stroke="#8a6820" stroke-width=".8" opacity=".4"/>
      <g fill="#6a5020" opacity=".4">
        <ellipse cx="20" cy="72" rx="8" ry="4"/><ellipse cx="50" cy="73" rx="6" ry="3"/>
        <ellipse cx="85" cy="72" rx="7" ry="3"/><ellipse cx="108" cy="73" rx="5" ry="3"/>
      </g>
      <!-- Slender body -->
      <ellipse cx="63" cy="63" rx="26" ry="12" fill="#c89840" opacity=".87" stroke="#6a3c10" stroke-width=".8"/>
      <!-- White belly/sides -->
      <ellipse cx="63" cy="68" rx="24" ry="8" fill="#e8d8a0" opacity=".45"/>
      <!-- White rump -->
      <ellipse cx="85" cy="60" rx="10" ry="8" fill="#e8e0c8" opacity=".7"/>
      <!-- Neck — long elegant -->
      <path d="M48 53 Q52 38 57 53" fill="#c89840" stroke="#6a3c10" stroke-width=".8"/>
      <!-- Head — narrow -->
      <ellipse cx="50" cy="30" rx="9" ry="13" fill="#d0a848" opacity=".92" stroke="#6a3c10" stroke-width=".8"/>
      <!-- Black face markings -->
      <path d="M44 30 Q50 26 56 30 Q50 28 44 30Z" fill="#1a0c04" opacity=".6"/>
      <!-- Snout -->
      <ellipse cx="50" cy="39" rx="5" ry="4" fill="#b88830" opacity=".85"/>
      <!-- Eye — large -->
      <circle cx="45" cy="28" r="3" fill="#1a0c04"/>
      <circle cx="44" cy="27" r="1" fill="#c8a030" opacity=".4"/>
      <!-- Prong horns — unique forked shape -->
      <g stroke="#1a0c04" stroke-width="2.5" fill="none" stroke-linecap="round">
        <path d="M47 20 Q44 10 44 2"/>
        <path d="M44 12 Q40 8 38 4"/>
        <path d="M53 20 Q56 10 56 2"/>
        <path d="M56 12 Q60 8 62 4"/>
      </g>
      <ellipse cx="63" cy="78" rx="28" ry="4" fill="#3a1c06" opacity=".15"/>
    </svg>`,

    // ── UPLAND BIRDS ──
    'turkey': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#a08830" opacity=".18"/>
      <!-- Forest edge -->
      <path d="M80 90 L80 30 Q88 15 96 30 L96 90Z M94 90 L94 22 Q102 8 110 22 L110 90Z" fill="#3a2808" opacity=".5"/>
      <!-- Fan tail feathers -->
      <g fill="#5a3c18" stroke="#2a1406" stroke-width=".6" opacity=".85">
        <path d="M60 65 Q40 45 30 25 Q45 42 60 60Z"/>
        <path d="M60 65 Q42 48 38 28 Q50 46 60 62Z"/>
        <path d="M60 65 Q48 50 50 30 Q56 50 60 64Z"/>
        <path d="M60 65 Q60 50 64 30 Q62 50 60 64Z"/>
        <path d="M60 65 Q70 50 76 30 Q66 50 60 62Z"/>
        <path d="M60 65 Q76 48 84 28 Q72 46 60 62Z"/>
        <path d="M60 65 Q82 45 90 25 Q77 42 60 60Z"/>
      </g>
      <!-- Body -->
      <ellipse cx="60" cy="72" rx="22" ry="15" fill="#4a3010" opacity=".9" stroke="#1a0c04" stroke-width=".8"/>
      <!-- Iridescent breast hatching -->
      <g stroke="#6a4820" stroke-width=".6" opacity=".5">
        <path d="M46 68 Q52 64 58 68"/><path d="M48 73 Q54 69 60 73"/>
        <path d="M52 78 Q58 74 64 78"/>
      </g>
      <!-- Neck — red -->
      <path d="M56 58 Q60 50 64 58" fill="#8a2808" stroke="#5a1004" stroke-width=".7"/>
      <!-- Head — small, red -->
      <circle cx="60" cy="44" r="9" fill="#9a3010" opacity=".9" stroke="#5a1004" stroke-width=".8"/>
      <!-- Caruncles/snood -->
      <path d="M60 38 Q58 32 60 28 Q62 32 60 38Z" fill="#b03020" opacity=".8"/>
      <ellipse cx="58" cy="48" rx="4" ry="3" fill="#c03020" opacity=".6"/>
      <!-- Eye -->
      <circle cx="56" cy="43" r="2.5" fill="#c8a020" opacity=".9"/>
      <circle cx="56" cy="43" r="1.2" fill="#0a0604"/>
      <!-- Beard -->
      <path d="M60 56 L58 68" stroke="#1a0c04" stroke-width="2" stroke-linecap="round" opacity=".7"/>
    </svg>`,

    'pheasant': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#a0b860" opacity=".15"/>
      <!-- Corn stubble field -->
      <g stroke="#8a6820" stroke-width=".8" opacity=".45">
        <line x1="15" y1="90" x2="14" y2="72"/><line x1="25" y1="90" x2="24" y2="70"/>
        <line x1="90" y1="90" x2="89" y2="73"/><line x1="100" y1="90" x2="99" y2="71"/>
      </g>
      <!-- Very long tail -->
      <path d="M88 58 Q105 50 115 42 Q110 50 102 58 Q95 60 88 60Z" fill="#8a6020" opacity=".8" stroke="#4a2c08" stroke-width=".6"/>
      <path d="M88 60 Q108 55 118 50" stroke="#6a4010" stroke-width=".8" fill="none" opacity=".6"/>
      <!-- Body — iridescent -->
      <ellipse cx="65" cy="65" rx="28" ry="14" fill="#8a5020" opacity=".88" stroke="#3a1c06" stroke-width=".8"/>
      <!-- Gold/copper breast -->
      <ellipse cx="52" cy="65" rx="14" ry="11" fill="#c07818" opacity=".6"/>
      <!-- Scale pattern -->
      <g stroke="#7a4010" stroke-width=".5" fill="none" opacity=".45">
        <path d="M46 60 Q52 56 58 60"/><path d="M44 66 Q50 62 56 66"/>
        <path d="M48 72 Q54 68 60 72"/>
      </g>
      <!-- Neck white ring -->
      <path d="M48 54 Q52 50 56 54 Q52 52 48 54Z" fill="#e8e0c8" opacity=".8"/>
      <!-- Neck -->
      <path d="M44 55 Q48 45 52 55" fill="#2a4008" stroke="#1a2c04" stroke-width=".7"/>
      <!-- Head — iridescent green -->
      <circle cx="42" cy="40" r="12" fill="#2a5818" opacity=".92" stroke="#1a3008" stroke-width=".8"/>
      <!-- Red eye patch -->
      <ellipse cx="38" cy="39" rx="6" ry="4" fill="#c02010" opacity=".7"/>
      <!-- Eye -->
      <circle cx="38" cy="39" r="2.5" fill="#f0c020" opacity=".9"/>
      <circle cx="38" cy="39" r="1.2" fill="#0a0604"/>
      <!-- Short crest -->
      <path d="M42 28 Q40 22 42 18 Q44 22 42 28Z" fill="#1a3808" opacity=".8"/>
    </svg>`,

    'grouse': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#9aaa70" opacity=".18"/>
      <!-- Pine branch -->
      <line x1="0" y1="35" x2="120" y2="42" stroke="#4a3010" stroke-width="4" opacity=".6"/>
      <g stroke="#3a2808" stroke-width=".8" fill="none" opacity=".5">
        <path d="M20 35 Q18 25 16 20"/><path d="M40 37 Q38 27 36 22"/>
        <path d="M60 38 Q58 28 56 23"/><path d="M80 39 Q78 29 76 24"/>
      </g>
      <!-- Body perched on branch -->
      <ellipse cx="60" cy="58" rx="24" ry="14" fill="#7a6030" opacity=".88" stroke="#3a2008" stroke-width=".8"/>
      <!-- Barred/mottled feather pattern -->
      <g stroke="#5a4018" stroke-width=".6" opacity=".5">
        <path d="M42 54 Q50 50 58 54"/><path d="M44 60 Q52 56 60 60"/>
        <path d="M58 54 Q66 50 74 54"/><path d="M56 60 Q64 56 72 60"/>
        <path d="M44 66 Q52 62 60 66"/>
      </g>
      <!-- Fan tail -->
      <path d="M80 58 Q96 52 102 48 Q98 55 90 60 Q85 62 80 60Z" fill="#6a5020" opacity=".75" stroke="#3a2008" stroke-width=".6"/>
      <!-- Neck -->
      <path d="M44 46 Q48 38 52 46" fill="#7a6030" stroke="#3a2008" stroke-width=".7"/>
      <!-- Head -->
      <circle cx="44" cy="34" r="12" fill="#8a6838" opacity=".9" stroke="#3a2008" stroke-width=".8"/>
      <!-- Red eyebrow comb -->
      <path d="M36 28 Q42 24 50 26 Q42 26 36 28Z" fill="#c02010" opacity=".75"/>
      <!-- Eye -->
      <circle cx="40" cy="33" r="2.5" fill="#c0a020" opacity=".85"/>
      <circle cx="40" cy="33" r="1.2" fill="#0a0604"/>
      <!-- Small beak -->
      <path d="M34 36 Q30 34 33 38Z" fill="#4a3010" opacity=".8"/>
    </svg>`,

    'sharptail': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#c0b870" opacity=".15"/>
      <!-- Shrub-steppe, sagebrush -->
      <ellipse cx="25" cy="75" rx="14" ry="8" fill="#7a7040" opacity=".5"/>
      <ellipse cx="90" cy="76" rx="12" ry="7" fill="#7a7040" opacity=".45"/>
      <!-- Pointed tail sticking up -->
      <path d="M80 55 Q92 44 98 38" stroke="#8a7040" stroke-width="2.5" fill="none" stroke-linecap="round" opacity=".8"/>
      <!-- Body -->
      <ellipse cx="60" cy="64" rx="25" ry="13" fill="#c0a860" opacity=".87" stroke="#6a4820" stroke-width=".8"/>
      <!-- Spotted/barred pattern -->
      <g fill="#6a4820" opacity=".4">
        <ellipse cx="46" cy="60" rx="3" ry="2"/><ellipse cx="54" cy="57" rx="3" ry="2"/>
        <ellipse cx="62" cy="58" rx="3" ry="2"/><ellipse cx="70" cy="60" rx="3" ry="2"/>
        <ellipse cx="48" cy="68" rx="3" ry="2"/><ellipse cx="58" cy="68" rx="3" ry="2"/>
        <ellipse cx="68" cy="67" rx="3" ry="2"/>
      </g>
      <!-- Neck -->
      <path d="M46 53 Q50 44 54 53" fill="#c0a860" stroke="#6a4820" stroke-width=".7"/>
      <!-- Head -->
      <circle cx="46" cy="40" r="11" fill="#c8b068" opacity=".9" stroke="#6a4820" stroke-width=".8"/>
      <!-- Yellow eyebrow -->
      <path d="M38 36 Q46 32 54 34" stroke="#d4b820" stroke-width="2" fill="none" opacity=".7"/>
      <!-- Eye -->
      <circle cx="42" cy="38" r="2.5" fill="#1a0c04" opacity=".9"/>
      <!-- Small crest -->
      <path d="M46 30 Q44 24 46 20 Q48 24 46 30Z" fill="#b09040" opacity=".7"/>
    </svg>`,

    'chukar': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#c0a860" opacity=".18"/>
      <!-- Rocky canyon wall -->
      <path d="M85 0 L85 90 L120 90 L120 0Z" fill="#7a6040" opacity=".4"/>
      <g stroke="#5a4020" stroke-width=".7" opacity=".4">
        <path d="M85 20 Q95 18 105 22"/><path d="M85 40 Q95 37 108 42"/>
        <path d="M85 60 Q97 57 112 63"/>
      </g>
      <!-- Body -->
      <ellipse cx="55" cy="64" rx="26" ry="14" fill="#c0a860" opacity=".88" stroke="#6a4820" stroke-width=".8"/>
      <!-- Black barred flanks — distinctive chukar pattern -->
      <g stroke="#1a0c04" stroke-width="1.5" opacity=".7">
        <line x1="36" y1="60" x2="36" y2="72"/><line x1="40" y1="58" x2="40" y2="71"/>
        <line x1="44" y1="57" x2="44" y2="70"/><line x1="48" y1="57" x2="48" y2="70"/>
        <line x1="70" y1="58" x2="70" y2="71"/><line x1="74" y1="59" x2="74" y2="72"/>
      </g>
      <!-- Gray breast -->
      <ellipse cx="50" cy="62" rx="12" ry="9" fill="#a0a0a0" opacity=".4"/>
      <!-- Neck -->
      <path d="M42 52 Q46 43 50 52" fill="#d0a060" stroke="#6a4820" stroke-width=".7"/>
      <!-- Head -->
      <circle cx="42" cy="38" r="12" fill="#d0a868" opacity=".92" stroke="#6a4820" stroke-width=".8"/>
      <!-- Bold black face stripe and gorget -->
      <path d="M30 32 Q42 28 54 32 Q48 28 42 26 Q36 28 30 32Z" fill="#0a0804" opacity=".8"/>
      <!-- Red beak and eye ring -->
      <ellipse cx="33" cy="38" rx="6" ry="3" fill="#c03010" opacity=".7"/>
      <circle cx="36" cy="37" r="2" fill="#c03010" opacity=".6"/>
      <!-- Eye -->
      <circle cx="38" cy="36" r="2.5" fill="#c0a020" opacity=".85"/>
      <circle cx="38" cy="36" r="1.2" fill="#0a0604"/>
    </svg>`,

    'hun': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#b0c070" opacity=".18"/>
      <!-- Stubble field -->
      <g stroke="#9a7820" stroke-width=".7" opacity=".4">
        <line x1="20" y1="90" x2="19" y2="76"/><line x1="32" y1="90" x2="31" y2="74"/>
        <line x1="80" y1="90" x2="79" y2="77"/><line x1="95" y1="90" x2="94" y2="75"/>
      </g>
      <!-- Body — compact round partridge shape -->
      <ellipse cx="60" cy="66" rx="24" ry="14" fill="#b89850" opacity=".88" stroke="#5a3c18" stroke-width=".8"/>
      <!-- Chestnut horseshoe belly patch -->
      <path d="M50 68 Q60 72 70 68 Q60 78 50 68Z" fill="#8a3818" opacity=".65"/>
      <!-- Barred sides -->
      <g stroke="#6a4820" stroke-width=".7" opacity=".45">
        <path d="M38 62 Q44 58 50 62"/><path d="M38 68 Q44 64 50 68"/>
        <path d="M68 62 Q74 58 80 62"/><path d="M68 68 Q74 64 80 68"/>
      </g>
      <!-- Neck -->
      <path d="M52 54 Q56 46 60 54" fill="#c0a060" stroke="#5a3c18" stroke-width=".7"/>
      <!-- Head — orange-chestnut -->
      <circle cx="54" cy="40" r="12" fill="#c07830" opacity=".92" stroke="#5a3c18" stroke-width=".8"/>
      <!-- Gray face -->
      <path d="M45 38 Q54 34 62 38 Q56 36 54 34 Q50 36 45 38Z" fill="#a0a090" opacity=".5"/>
      <!-- Eye -->
      <circle cx="50" cy="38" r="2.5" fill="#1a0c04" opacity=".9"/>
      <!-- Small beak -->
      <path d="M44 41 Q40 39 43 44Z" fill="#8a6020" opacity=".8"/>
    </svg>`,

    'quail': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#a0b860" opacity=".18"/>
      <!-- Shrubby chaparral -->
      <ellipse cx="18" cy="80" rx="12" ry="7" fill="#6a7040" opacity=".5"/>
      <ellipse cx="100" cy="78" rx="10" ry="6" fill="#6a7040" opacity=".45"/>
      <!-- Body — plump -->
      <ellipse cx="62" cy="66" rx="22" ry="14" fill="#8a8060" opacity=".88" stroke="#3a2c18" stroke-width=".8"/>
      <!-- Scale pattern on breast -->
      <g stroke="#4a3c20" stroke-width=".5" fill="none" opacity=".45">
        <path d="M50 60 Q56 56 62 60"/><path d="M48 66 Q54 62 60 66"/>
        <path d="M52 72 Q58 68 64 72"/><path d="M62 60 Q68 56 74 60"/>
      </g>
      <!-- Neck -->
      <path d="M52 54 Q56 46 60 54" fill="#a09068" stroke="#3a2c18" stroke-width=".7"/>
      <!-- Head — blue-gray -->
      <circle cx="52" cy="40" r="11" fill="#6878a0" opacity=".9" stroke="#303850" stroke-width=".8"/>
      <!-- Chestnut crown and white stripe -->
      <path d="M44 36 Q52 30 60 34 Q52 32 44 36Z" fill="#8a3808" opacity=".65"/>
      <path d="M44 36 Q52 33 60 36 Q52 34 44 36Z" fill="#e8e0c0" opacity=".5"/>
      <!-- Topknot plume — curved forward -->
      <path d="M52 30 Q50 22 54 16 Q52 22 56 28" fill="#1a1008" stroke="#0a0804" stroke-width="1.5" stroke-linecap="round" opacity=".85"/>
      <!-- Eye -->
      <circle cx="48" cy="40" r="2.5" fill="#1a0c04" opacity=".9"/>
      <!-- Small beak -->
      <path d="M43 42 Q38 40 42 45Z" fill="#6a5020" opacity=".8"/>
    </svg>`,

    'dove': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#c8c0a0" opacity=".15"/>
      <!-- Fence wire — dove habitat -->
      <line x1="0" y1="50" x2="120" y2="50" stroke="#6a5020" stroke-width="1.5" opacity=".5"/>
      <line x1="25" y1="30" x2="25" y2="80" stroke="#5a3c18" stroke-width="2.5" opacity=".5"/>
      <line x1="95" y1="30" x2="95" y2="80" stroke="#5a3c18" stroke-width="2.5" opacity=".5"/>
      <!-- Sleek body perched -->
      <ellipse cx="60" cy="48" rx="22" ry="10" fill="#c0b090" opacity=".88" stroke="#7a5c30" stroke-width=".8"/>
      <!-- Long pointed tail -->
      <path d="M80 48 Q100 46 108 44 Q100 50 82 52Z" fill="#9a8060" opacity=".8" stroke="#6a4820" stroke-width=".6"/>
      <!-- Iridescent neck patch -->
      <ellipse cx="50" cy="44" rx="8" ry="5" fill="#a08060" opacity=".5"/>
      <!-- Wing spots -->
      <g fill="#4a3010" opacity=".55">
        <circle cx="62" cy="45" r="2"/><circle cx="68" cy="43" r="1.8"/>
        <circle cx="72" cy="46" r="1.5"/>
      </g>
      <!-- Neck -->
      <path d="M46 40 Q50 32 54 40" fill="#c0b090" stroke="#7a5c30" stroke-width=".7"/>
      <!-- Head — small, round -->
      <circle cx="46" cy="28" r="10" fill="#d0c0a0" opacity=".9" stroke="#7a5c30" stroke-width=".8"/>
      <!-- Black eye spot -->
      <circle cx="42" cy="27" r="2.5" fill="#1a0c04" opacity=".9"/>
      <circle cx="41" cy="26" r="1" fill="#c8a030" opacity=".3"/>
      <!-- Small beak -->
      <path d="M37 28 Q32 27 36 31Z" fill="#8a7040" opacity=".8"/>
    </svg>`,

    'snipe': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#80a870" opacity=".18"/>
      <!-- Wetland bg — cattails -->
      <g stroke="#4a5820" stroke-width="2" opacity=".5">
        <line x1="15" y1="0" x2="15" y2="70"/><line x1="25" y1="10" x2="25" y2="72"/>
        <line x1="95" y1="5" x2="95" y2="68"/><line x1="105" y1="0" x2="105" y2="70"/>
      </g>
      <g fill="#4a3010" opacity=".55">
        <ellipse cx="15" cy="25" rx="4" ry="10"/><ellipse cx="25" cy="30" rx="4" ry="10"/>
        <ellipse cx="95" cy="22" rx="4" ry="10"/><ellipse cx="105" cy="28" rx="4" ry="10"/>
      </g>
      <!-- Body — stocky, streaked -->
      <ellipse cx="62" cy="65" rx="22" ry="12" fill="#8a7040" opacity=".88" stroke="#3a2808" stroke-width=".8"/>
      <!-- Bold stripe pattern -->
      <g stroke="#c0a860" stroke-width="1.2" opacity=".55">
        <line x1="44" y1="60" x2="80" y2="58"/><line x1="44" y1="65" x2="80" y2="63"/>
        <line x1="44" y1="70" x2="78" y2="68"/>
      </g>
      <!-- Very long straight bill -->
      <path d="M32 42 Q20 40 8 40" stroke="#4a3010" stroke-width="3" fill="none" stroke-linecap="round" opacity=".85"/>
      <!-- Neck -->
      <path d="M40 55 Q38 46 42 55" fill="#8a7040" stroke="#3a2808" stroke-width=".7"/>
      <!-- Head — striped -->
      <ellipse cx="36" cy="42" rx="12" ry="10" fill="#9a8048" opacity=".9" stroke="#3a2808" stroke-width=".8"/>
      <!-- Head stripes -->
      <g stroke="#2a1c08" stroke-width="1.5" opacity=".6">
        <path d="M26 38 Q36 36 46 38"/><path d="M26 42 Q36 40 46 42"/>
      </g>
      <!-- Eye -->
      <circle cx="36" cy="40" r="2.5" fill="#1a0c04" opacity=".9"/>
    </svg>`,

    'sandhill-crane': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#c0c890" opacity=".15"/>
      <!-- Agricultural field -->
      <line x1="0" y1="78" x2="120" y2="78" stroke="#8a6820" stroke-width=".8" opacity=".4"/>
      <!-- Very tall bird — long legs -->
      <line x1="55" y1="72" x2="52" y2="90" stroke="#5a4020" stroke-width="2.5" opacity=".85"/>
      <line x1="65" y1="72" x2="68" y2="90" stroke="#5a4020" stroke-width="2.5" opacity=".85"/>
      <!-- Body — large, gray -->
      <ellipse cx="60" cy="62" rx="20" ry="14" fill="#9090a0" opacity=".85" stroke="#505060" stroke-width=".8"/>
      <!-- Wing tips drooping -->
      <path d="M80 60 Q95 65 100 62 Q92 68 80 66Z" fill="#808090" opacity=".7"/>
      <!-- Long neck -->
      <path d="M55 48 Q58 30 62 48" fill="#909098" stroke="#505060" stroke-width=".8"/>
      <!-- Head -->
      <ellipse cx="58" cy="24" rx="9" ry="12" fill="#9090a0" opacity=".9" stroke="#505060" stroke-width=".8"/>
      <!-- Red crown patch -->
      <ellipse cx="58" cy="16" rx="7" ry="5" fill="#c02010" opacity=".8"/>
      <!-- Long straight bill -->
      <line x1="52" y1="28" x2="36" y2="26" stroke="#5a5050" stroke-width="3" stroke-linecap="round" opacity=".85"/>
      <!-- Eye — red/orange -->
      <circle cx="52" cy="25" r="2.5" fill="#c03010" opacity=".85"/>
      <circle cx="52" cy="25" r="1.2" fill="#0a0604"/>
    </svg>`,

    // ── WATERFOWL ──
    'duck': `<svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
      <rect width="120" height="90" fill="#6090c0" opacity=".18"/>
      <!-- Water surface -->
      <path d="M0 65 Q30 60 60 65 Q90 60 120 65 L120 90 L0 90Z" fill="#4878a8" opacity=".4"/>
      <!-- Reflection ripples -->
      <g stroke="#6898c8" stroke-width=".7" fill="none" opacity=".5">
        <path d="M35 70 Q50 68 65 70"/><path d="M40 75 Q55 73 70 75"/>
      </g>
      <!-- Mallard — body floating -->
      <ellipse cx="62" cy="66" rx="28" ry="13" fill="#8a7040" opacity=".88" stroke="#3a2c18" stroke-width=".8"/>
      <!-- White collar ring -->
      <path d="M46 55 Q52 52 58 55 Q52 53 46 55Z" fill="#e8e0c8" opacity=".85"/>
      <!-- Iridescent green head -->
      <circle cx="46" cy="46" r="14" fill="#2a6020" opacity=".9" stroke="#183010" stroke-width=".9"/>
      <!-- Yellow bill -->
      <path d="M33 48 Q26 46 24 50 Q28 52 33 50Z" fill="#d4b820" opacity=".9"/>
      <!-- Eye -->
      <circle cx="42" cy="45" r="2.8" fill="#1a0c04"/>
      <circle cx="41" cy="44" r="1" fill="#c8a030" opacity=".3"/>
      <!-- Curly tail feathers -->
      <path d="M88 60 Q95 52 98 48" stroke="#2a4020" stroke-width="3" fill="none" stroke-linecap="round" opacity=".7"/>
      <!-- Wing speculum -->
