      </g>
      <!-- Body — lean, mid-size canid -->
      <ellipse cx="65" cy="64" rx="28" ry="13" fill="#b09048" opacity=".87" stroke="#5a3c18" stroke-width=".8"/>
      <!-- Tail drooping down — coyote holds tail low -->
