let quizAnswers = {};
let quizStep = 0;

function startQuiz(){
  quizAnswers = {};
  quizStep = 0;
  showScreen('quiz');
  renderQuizStep();
}

function renderQuizStep(){
  const q = QUIZ_QUESTIONS[quizStep];
  const total = QUIZ_QUESTIONS.length;
  const pct = Math.round((quizStep / total) * 100);

  document.getElementById('quizProgress').textContent = `Question ${quizStep+1} of ${total}`;
  document.getElementById('quizPct').textContent = pct + '%';
  document.getElementById('quizBar').style.width = pct + '%';
  document.getElementById('quizResults').style.display = 'none';

  const selected = quizAnswers[q.id];
  let html = `
    <div style="margin-bottom:20px">
      <div style="font-size:16px;font-weight:700;color:#f0e4c0;margin-bottom:5px;line-height:1.4">${q.q}</div>
      <div style="font-size:12px;color:#5a6a50;margin-bottom:14px;font-style:italic">${q.hint}</div>
      <div style="display:flex;flex-direction:column;gap:9px">
  `;
  q.options.forEach(opt => {
    const isSel = selected === opt.value;
    html += `
      <button onclick="quizSelect('${q.id}','${opt.value}')" style="
        text-align:left;padding:13px 15px;border-radius:12px;font-size:14px;line-height:1.4;
        background:${isSel ? 'rgba(180,140,60,.22)' : 'rgba(255,255,255,.04)'};
        border:1.5px solid ${isSel ? 'rgba(180,140,60,.6)' : 'rgba(255,255,255,.1)'};
        color:${isSel ? '#f0e4c0' : '#a0b090'};
        font-family:inherit;cursor:pointer;transition:all .15s;width:100%
      ">${opt.label}</button>`;
  });
  html += `</div></div>`;

  // Back / Next / Finish nav
  html += `<div style="display:flex;gap:10px;margin-top:4px">`;
  if(quizStep > 0){
    html += `<button onclick="quizBack()" style="flex:1;padding:13px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);color:#7a8a70;font-size:14px;font-family:inherit;cursor:pointer">← Back</button>`;
  }
  if(selected){
    const isLast = quizStep === total - 1;
    html += `<button onclick="${isLast ? 'showQuizResults()' : 'quizNext()'}" style="flex:2;padding:13px;border-radius:10px;background:rgba(180,140,60,.2);border:1px solid rgba(180,140,60,.5);color:#d4a840;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer">${isLast ? '🎯 Show My Recommendation' : 'Next →'}</button>`;
  }
  html += `</div>`;

  document.getElementById('quizQuestions').innerHTML = html;
  document.getElementById('quizResults').style.display = 'none';
  document.getElementById('quizQuestions').style.display = 'block';
}

function quizSelect(qid, value){
  quizAnswers[qid] = value;
  renderQuizStep(); // re-render to highlight selection and show Next button
}

function quizNext(){
  if(quizStep < QUIZ_QUESTIONS.length - 1){
    quizStep++;
    renderQuizStep();
    document.getElementById('quizQuestions').scrollIntoView({behavior:'smooth',block:'start'});
  }
}

function quizBack(){
  if(quizStep > 0){
    quizStep--;
    renderQuizStep();
  }
}

function scoreAnimals(){
  return ANIMAL_PROFILES.map(animal => {
    let score = 0;
    Object.entries(quizAnswers).forEach(([qid, val]) => {
      score += animal.scores[val] || 0;
    });
    return {...animal, score};
  }).sort((a,b) => b.score - a.score);
}

function showQuizResults(){
  const ranked = scoreAnimals();
  const top = ranked.slice(0,3);
  const total = QUIZ_QUESTIONS.length;

  document.getElementById('quizBar').style.width = '100%';
  document.getElementById('quizPct').textContent = '100%';
  document.getElementById('quizProgress').textContent = 'Complete!';
  document.getElementById('quizQuestions').style.display = 'none';

  let html = `
    <div style="margin-bottom:20px">
      <div style="font-size:10px;letter-spacing:3px;color:#b48c3c;margin-bottom:6px">YOUR RESULTS</div>
      <div style="font-size:18px;font-weight:700;color:#f0e4c0;margin-bottom:6px">Here's what we recommend</div>
      <div style="font-size:13px;color:#6a7a60;line-height:1.6;margin-bottom:18px">Based on your answers, these animals are the best match for you right now.</div>
  `;

  top.forEach((animal, i) => {
    const medal = i===0 ? '🥇' : i===1 ? '🥈' : '🥉';
    const spotCount = SPOTS.filter(s => s.deer === animal.id).length;
    html += `
      <div style="background:rgba(255,255,255,.04);border:1.5px solid ${i===0 ? 'rgba(180,140,60,.45)' : 'rgba(255,255,255,.09)'};border-radius:14px;padding:16px;margin-bottom:12px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <div style="font-size:28px">${medal}</div>
          <div>
            <div style="font-size:15px;font-weight:700;color:${animal.color}">${animal.emoji} ${animal.name}</div>
            <div style="font-size:11px;color:#6a7a60;margin-top:1px;font-style:italic">${animal.tagline}</div>
          </div>
        </div>
        <div style="font-size:13px;color:#a0b090;line-height:1.65;margin-bottom:12px;border-left:2px solid ${animal.color}33;padding-left:10px">${animal.why}</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button onclick="quizGoToSpots('${animal.id}')" style="flex:1;background:rgba(180,140,60,.18);border:1px solid rgba(180,140,60,.4);color:#d4a840;border-radius:8px;padding:9px 12px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer;white-space:nowrap">🗺️ See ${spotCount} Spots →</button>
          <button onclick="openAnimalModal('${animal.id}')" style="flex:1;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);color:#a0b090;border-radius:8px;padding:9px 12px;font-size:12px;font-weight:600;font-family:inherit;cursor:pointer;white-space:nowrap">📖 Learn More</button>
        </div>
      </div>
    `;
  });

  html += `
    <button onclick="startQuiz()" style="width:100%;margin-top:4px;padding:13px;border-radius:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);color:#6a7a60;font-size:13px;font-family:inherit;cursor:pointer">↺ Retake Quiz</button>
    </div>
  `;

  document.getElementById('quizResults').innerHTML = html;
  document.getElementById('quizResults').style.display = 'block';
  document.getElementById('quizResults').scrollIntoView({behavior:'smooth',block:'start'});
}

function quizGoToSpots(animalId){
  // Set the filter to show only that animal then open browse map
  activeFilters = new Set([animalId]);
  activeDiffs = new Set(['Beginner','Intermediate','Advanced']);
  buildFilterDrawer();
  showScreen('browse');
}


let fakChecked = new Array(26).fill(false);
function toggleFAK(i){
  fakChecked[i]=!fakChecked[i];
  const el=document.getElementById('fak-'+i);
  const ck=document.getElementById('fakcheck-'+i);
  if(fakChecked[i]){el.classList.add('checked');ck.textContent='✓';}
  else{el.classList.remove('checked');ck.textContent='○';}
  updateFAKProgress();
}
function updateFAKProgress(){
  const done=fakChecked.filter(Boolean).length;
  const total=fakChecked.length;
  const pct=Math.round(done/total*100);
  document.getElementById('fak-bar').style.width=pct+'%';
  document.getElementById('fak-count').textContent=done+' of '+total+' items packed';
  if(done===total){document.getElementById('fak-count').textContent='✅ Kit complete! You\'re ready to hunt safely.';}
}
function resetFAK(){
  fakChecked.fill(false);
  for(let i=0;i<26;i++){
    const el=document.getElementById('fak-'+i);
    if(el){el.classList.remove('checked');document.getElementById('fakcheck-'+i).textContent='○';}
  }
  updateFAKProgress();
}


