    options: [
      { label: '🦌 Big game — deer, elk, something large', value: 'big' },
      { label: '🦃 Birds — something to shoot at on the wing', value: 'bird' },
      { label: '🐇 Small game — rabbits, squirrels, easy start', value: 'small' },
      { label: '🤷 No idea — just show me what makes sense', value: 'any' },
    ]
  },
  {
    id: 'eat',
    q: 'Do you want to eat what you hunt?',
    hint: 'Some hunters hunt for food, some for the experience. Both are valid.',
    options: [
      { label: '🍽️ Yes — filling the freezer is a big part of why I\'m doing this', value: 'yes' },
      { label: '🏕️ Nice to have, but not required', value: 'maybe' },
      { label: '🎯 Not really — I\'m more interested in the sport and experience', value: 'no' },
    ]
  },
  {
    id: 'fitness',
    q: 'How physical do you want the hunt to be?',
    hint: 'Honest answer gets you the best match.',
    options: [
      { label: '🪑 Easy — I\'d rather stay close to the car or truck', value: 'easy' },
      { label: '🥾 Some walking is fine — a couple miles is okay', value: 'moderate' },
      { label: '🏔️ I don\'t mind a real workout — the harder the better', value: 'hard' },
    ]
  },
  {
    id: 'region',
    q: 'Where in Washington are you located or willing to hunt?',
    hint: 'Many animals are only common in certain parts of the state.',
    options: [
      { label: '🌲 West side — Seattle, Olympia, Tacoma, coast area', value: 'west' },
      { label: '🏜️ East side — Spokane, Yakima, Tri-Cities, Wenatchee', value: 'east' },
      { label: '🗺️ Willing to travel anywhere in WA', value: 'both' },
    ]
  },
  {
    id: 'social',
    q: 'How do you picture your first hunt going?',
    hint: 'This affects what gear and tactics you\'ll need.',
    options: [
      { label: '🌅 Sitting quietly before dawn waiting for something to appear', value: 'sit' },
      { label: '🚶 Walking through the woods or fields looking for birds or game', value: 'walk' },
      { label: '🦆 Outdoors near water — rivers, marshes, lakes', value: 'water' },
      { label: '⚡ Fast action — lots of shooting opportunities', value: 'action' },
    ]
  },
];

// Each animal gets scored. Higher = better match.
// Score keys match question option values.
