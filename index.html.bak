<!DOCTYPE html>
<html class="light" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<title>WA Beginners Hunting Guide</title>
<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,700;0,800;1,400&family=Work+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Cinzel:wght@400;600;700&family=IM+Fell+English:ital@0;1&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
tailwind.config = {
  darkMode: "class",
  theme: {
    extend: {
      colors: {
        "inverse-on-surface": "#f6f0e2",
        "outline": "#737972",
        "on-tertiary-fixed": "#261900",
        "secondary-container": "#fec391",
        "secondary-fixed-dim": "#f5bb89",
        "on-primary-fixed": "#0b2012",
        "outline-variant": "#c3c8c1",
        "surface-container-high": "#ede8da",
        "background": "#fef9eb",
        "on-error": "#ffffff",
        "on-background": "#1d1c13",
        "surface-variant": "#e7e2d4",
        "primary-fixed-dim": "#b4cdb7",
        "tertiary-fixed-dim": "#e9c176",
        "secondary-fixed": "#ffdcc1",
        "on-secondary-container": "#794e26",
        "on-error-container": "#93000a",
        "surface": "#fef9eb",
        "on-primary-fixed-variant": "#364c3b",
        "error-container": "#ffdad6",
        "on-secondary-fixed-variant": "#653e17",
        "error": "#ba1a1a",
        "tertiary-container": "#513900",
        "on-primary": "#ffffff",
        "on-tertiary-fixed-variant": "#5d4201",
        "on-tertiary": "#ffffff",
        "on-secondary": "#ffffff",
        "surface-tint": "#4e6452",
        "surface-container-low": "#f8f3e5",
        "on-secondary-fixed": "#2e1600",
        "on-primary-container": "#96ae99",
        "on-surface": "#1d1c13",
        "inverse-surface": "#323127",
        "surface-container-highest": "#e7e2d4",
        "surface-dim": "#dedacc",
        "tertiary": "#352400",
        "primary-container": "#2d4232",
        "surface-container": "#f3eee0",
        "surface-container-lowest": "#ffffff",
        "primary-fixed": "#d0e9d2",
        "tertiary-fixed": "#ffdea5",
        "on-surface-variant": "#434843",
        "surface-bright": "#fef9eb",
        "on-tertiary-container": "#c8a35b",
        "secondary": "#80552c",
        "primary": "#172c1d",
        "inverse-primary": "#b4cdb7"
      },
      fontFamily: {
        "headline": ["Newsreader"],
        "body": ["Work Sans"],
        "label": ["Work Sans"]
      },
      borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
    },
  },
}
</script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
}
.glass-panel {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(20px);
}
.hero-gradient {
  background: linear-gradient(to bottom, rgba(23,44,29,0.8), rgba(45,66,50,0.4));
}

/* ── HOME PAGE ── */
#home-page { display: block; }
#home-page.hidden { display: none; }

/* ── APP SHELL ── */
#app-shell { display: none; }
#app-shell.active { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

.screen { display: none; flex-direction: column; flex: 1; overflow: hidden; }
.screen.active { display: flex; }

/* ── BOTTOM NAV ── */
.bnav {
  background: linear-gradient(180deg, #3a1c08 0%, #2a1206 100%);
  border-top: 2px solid #b88820;
  padding: 4px 0 10px;
  display: flex;
  position: sticky; bottom: 0; z-index: 200;
  box-shadow: 0 -4px 16px rgba(0,0,0,.6);
  flex-shrink: 0;
}
.nb {
  flex: 1; background: transparent; border: none;
  color: rgba(180,140,50,.45);
  padding: 4px 4px 2px;
  font-size: 8px;
  font-family: 'Cinzel', serif;
  letter-spacing: .4px;
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  text-transform: uppercase; cursor: pointer;
}
.nb .ni { font-size: 17px; filter: sepia(100%) brightness(.6) contrast(1.1); }
.nb.active { color: #d4a830; }
.nb.active .ni { filter: sepia(100%) brightness(1.1) contrast(1.1) saturate(1.2); }

/* ── INNER HEADER ── */
.inner-header {
  background: linear-gradient(180deg, #3a1c08 0%, #2a1206 60%, #1e0e04 100%);
  border-bottom: 2px solid #b88820;
  padding: 9px 14px 8px;
  display: flex; align-items: center; gap: 10px;
  position: sticky; top: 0; z-index: 200;
  box-shadow: 0 3px 14px rgba(0,0,0,.55);
  flex-shrink: 0;
}
.hdr-sub   { font-size: 8px; letter-spacing: 4px; color: #d4a830; font-family: 'Cinzel', serif; text-transform: uppercase; margin-bottom: 1px; }
.hdr-title { font-size: 15px; color: #f0dca0; font-family: 'Cinzel', serif; font-weight: 700; text-shadow: 1px 1px 3px rgba(0,0,0,.7); letter-spacing: .5px; }
.back-btn  { background: none; border: none; color: #d4a830; font-size: 26px; padding: 0 8px 0 0; line-height: 1; cursor: pointer; }
.gps-btn   { background: rgba(90,40,16,.4); border: 1px solid #b88820; color: #d4a830; border-radius: 3px; padding: 6px 10px; font-size: 10px; font-family: 'Cinzel', serif; white-space: nowrap; cursor: pointer; }
.gps-btn.located { background: rgba(30,60,15,.4); border-color: #6a9a30; color: #8abe50; }

button { font-family: 'Libre Baskerville', Georgia, serif; cursor: pointer; }
a      { font-family: 'Libre Baskerville', Georgia, serif; }

.pack-tab-bar { padding: 10px 14px 0; display: flex; gap: 7px; flex-shrink: 0; }
.pack-tbtn    { background: rgba(255,255,255,.06); border: 1px solid rgba(180,140,60,.25); color: #a09070; border-radius: 3px; padding: 7px 14px; font-size: 12px; flex: 1; text-align: center; font-family: 'Cinzel', serif; cursor: pointer; }
.pack-tbtn.active { background: rgba(180,140,60,.2); border-color: #b88820; color: #d4a830; }

.tbtn     { background: rgba(139,101,16,.08); border: 1px solid rgba(139,101,16,.2); color: #6b3e1a; border-radius: 3px; padding: 6px 11px; font-size: 12px; font-family: 'Cinzel', serif; cursor: pointer; }
.tbtn.active { background: rgba(139,101,16,.22); border-color: #b88820; color: #8b6510; }

.hunt-map { width: 100%; background: #2a1a08; }
.lpin { width: 20px; height: 20px; border-radius: 50%; border: 2.5px solid rgba(255,255,255,.85); box-shadow: 0 2px 8px rgba(0,0,0,.55); cursor: pointer; }
.leaflet-container { background: #2a1a08 !important; }
.leaflet-tile { filter: sepia(30%) brightness(.82) saturate(.75); }
.leaflet-control-attribution { display: none; }
.leaflet-control-zoom a { background: rgba(240,228,176,.92) !important; color: #8b6510 !important; border-color: #8b6510 !important; }
.scroll-area { flex: 1; overflow-y: auto; padding: 10px 14px 20px; -webkit-overflow-scrolling: touch; }
.near-label  { font-size: 9px; letter-spacing: 3px; color: #8b6510; margin-bottom: 2px; font-family: 'Cinzel', serif; }
.near-sub    { font-size: 12px; color: #6b3e1a; }

.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(20,8,2,.72); z-index: 500; align-items: flex-end; justify-content: center; }
.modal-overlay.open { display: flex; }
.modal-sheet { background: linear-gradient(180deg,#f0e4b0 0%,#dcc880 100%); border-top: 3px solid #b88820; border-radius: 14px 14px 0 0; width: 100%; max-width: 480px; max-height: 90vh; display: flex; flex-direction: column; animation: slideUp .22s ease; box-shadow: 0 -8px 32px rgba(20,8,2,.5); }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.modal-handle { width: 40px; height: 4px; background: rgba(90,40,10,.25); border-radius: 2px; margin: 10px auto 0; flex-shrink: 0; }
.modal-header { padding: 12px 16px 10px; border-bottom: 1px solid rgba(90,40,10,.15); flex-shrink: 0; position: relative; }
.modal-tag    { font-size: 9px; letter-spacing: 2px; color: #8b6510; font-family: 'Cinzel', serif; margin-bottom: 3px; }
.modal-title  { font-size: 18px; font-weight: 700; color: #2c1608; font-family: 'Cinzel', serif; }
.modal-sub    { font-size: 12px; color: #6b3e1a; margin-top: 2px; }
.modal-close  { position: absolute; top: 12px; right: 14px; background: none; border: none; font-size: 18px; color: #6b3e1a; cursor: pointer; }
.modal-body   { overflow-y: auto; flex: 1; padding: 14px 16px 24px; -webkit-overflow-scrolling: touch; font-family: 'Libre Baskerville', Georgia, serif; font-size: 13px; color: #2c1608; line-height: 1.7; }

.spot-card { background: rgba(240,228,176,.7); border: 1px solid rgba(139,101,16,.3); border-radius: 8px; padding: 12px 14px; margin-bottom: 10px; cursor: pointer; transition: all .15s; }
.spot-card:active { transform: scale(.98); background: rgba(240,228,176,.9); }

.cat-section-label { font-size: 9px; letter-spacing: 3px; color: #8b6510; padding: 12px 14px 6px; flex-shrink: 0; font-family: 'Cinzel', serif; }
.animal-grid { display: flex; flex-wrap: wrap; gap: 8px; padding: 0 14px 10px; }
.animal-tile { background: linear-gradient(145deg,#f0e4b0,#dcc470); border: 1.5px solid #8b6510; border-radius: 4px; padding: 10px 12px; cursor: pointer; flex: 1; min-width: 120px; text-align: left; transition: all .15s; box-shadow: 0 2px 5px rgba(30,10,0,.12); }
.animal-tile .at-icon { font-size: 22px; margin-bottom: 4px; }
.animal-tile .at-name { font-size: 13px; font-weight: 700; color: #2c1608; margin-bottom: 2px; font-family: 'Cinzel', serif; }
.animal-tile .at-sub  { font-size: 10px; color: #6b3e1a; }

.pack-list { padding: 10px 14px; }
.pack-item { display: flex; gap: 12px; padding: 10px 0; border-bottom: 1px solid rgba(139,101,16,.15); align-items: flex-start; font-size: 13px; color: #2c1608; }
.pack-icon { font-size: 18px; flex-shrink: 0; }
.pack-note { font-size: 11px; color: #6b3e1a; margin-top: 2px; line-height: 1.5; }
.fak-item  { display: flex; align-items: flex-start; gap: 12px; padding: 10px 0; border-bottom: 1px solid rgba(139,101,16,.12); }

.tag           { display: inline-block; padding: 3px 8px; border-radius: 3px; font-size: 10px; font-weight: 700; letter-spacing: .5px; font-family: 'Cinzel', serif; }
.caliber-tag   { padding: 4px 8px; border-radius: 3px; font-size: 10px; font-family: 'Cinzel', serif; }
.tip-box       { background: rgba(139,101,16,.1); border: 1px solid rgba(139,101,16,.35); border-radius: 4px; padding: 10px 12px; font-size: 12px; color: #6b3e1a; line-height: 1.6; }
.retry-btn     { background: rgba(180,140,60,.2); border: 1px solid rgba(180,140,60,.4); color: #d4a830; border-radius: 8px; padding: 10px 20px; font-size: 13px; cursor: pointer; }
.text-btn      { background: none; border: none; color: #8b6510; font-size: 13px; cursor: pointer; text-decoration: underline; }

.quiz-opt      { background: rgba(240,228,176,.6); border: 1.5px solid rgba(139,101,16,.3); border-radius: 10px; padding: 14px 16px; cursor: pointer; transition: all .15s; text-align: left; width: 100%; margin-bottom: 8px; font-size: 14px; color: #2c1608; }
.quiz-opt.sel  { background: rgba(139,101,16,.2); border-color: #8b6510; }

.filter-group-label { font-size: 9px; letter-spacing: 2px; color: #8b6510; padding: 10px 14px 4px; font-family: 'Cinzel', serif; }
.filter-chip { display: inline-flex; align-items: center; gap: 5px; background: rgba(240,228,176,.7); border: 1px solid rgba(139,101,16,.3); border-radius: 20px; padding: 5px 10px; font-size: 11px; color: #3d2010; cursor: pointer; transition: all .15s; margin: 3px; font-family: 'Cinzel', serif; }
.filter-chip.active { background: rgba(139,101,16,.25); border-color: #8b6510; color: #2c1608; font-weight: 700; }

.budget-select { background: rgba(240,228,176,.8); border: 1px solid rgba(139,101,16,.4); border-radius: 6px; padding: 8px 10px; font-size: 13px; color: #2c1608; width: 100%; font-family: 'Libre Baskerville', Georgia, serif; appearance: none; }
.budget-toggle { background: rgba(240,228,176,.5); border: 1.5px solid rgba(139,101,16,.25); border-radius: 8px; padding: 10px 12px; cursor: pointer; transition: all .15s; text-align: left; width: 100%; font-size: 13px; color: #2c1608; }
.budget-toggle.on { background: rgba(139,101,16,.18); border-color: #8b6510; }
</style>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-secondary-container selection:text-on-secondary-container">

<!-- ═══════════════════════════════════════════════════════
     HOME PAGE — new sketch UI
════════════════════════════════════════════════════════════ -->
<div id="home-page">

<!-- TopAppBar -->
<header class="w-full border-b border-[#c3c8c1]/20 bg-[#fef9eb] sticky top-0 z-50">
  <div class="flex justify-center items-center px-8 py-4 max-w-7xl mx-auto">
    <div class="flex items-center justify-between w-full max-w-md mx-auto">
      <button onclick="homePage()" class="flex items-center text-[#172c1d] hover:text-[#80552c] transition-colors bg-transparent border-none cursor-pointer">
        <span class="material-symbols-outlined text-3xl">home</span>
      </button>
      <button onclick="enterApp('browse')" class="flex items-center text-[#172c1d] hover:text-[#80552c] transition-colors bg-transparent border-none cursor-pointer">
        <span class="material-symbols-outlined text-3xl">map</span>
      </button>
      <button onclick="enterApp('pack')" class="flex items-center text-[#172c1d] hover:text-[#80552c] transition-colors bg-transparent border-none cursor-pointer">
        <span class="material-symbols-outlined text-3xl">backpack</span>
      </button>
      <button onclick="enterApp('animals')" class="flex items-center text-[#172c1d] hover:text-[#80552c] transition-colors bg-transparent border-none cursor-pointer">
        <span class="material-symbols-outlined text-3xl">favorite</span>
      </button>
    </div>
  </div>
</header>

<!-- Hero Section -->
<section class="relative h-[600px] md:h-[751px] flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img class="w-full h-full object-cover" src="./images/cabinwoods.png" alt="Cabin in the Woods"/>
    <div class="absolute inset-0 hero-gradient"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-8 w-full">
    <div class="max-w-2xl">
      <span class="inline-block px-3 py-1 bg-[#ffdea5] text-[#5d4201] text-xs font-bold uppercase tracking-widest mb-6 rounded-sm">Est. 1889 Washington State</span>
      <h2 class="font-headline text-6xl md:text-8xl text-white font-bold leading-none mb-8 tracking-tight">The Wilds Await</h2>
      <div class="glass-panel p-2 rounded-lg flex flex-col md:flex-row gap-2 shadow-2xl">
        <div class="flex-grow flex items-center px-4 py-3 gap-3">
          <span class="material-symbols-outlined text-[#80552c]">search</span>
          <input id="heroSearchInput" class="bg-transparent border-none focus:ring-0 w-full font-body text-[#1d1c13] placeholder:text-[#737972]/60 outline-none" placeholder="Find a hunt near your city" type="text" onkeydown="if(event.key==='Enter')heroSearchGo()"/>
        </div>
        <button onclick="heroSearchGo()" class="bg-[#172c1d] text-white px-8 py-4 font-label font-semibold rounded-md hover:bg-[#172c1d]/90 transition-all">Seek Grounds</button>
      </div>
    </div>
  </div>
</section>

<!-- Bento Grid -->
<section class="py-16 px-6 max-w-7xl mx-auto bg-[#fef9eb]">
  <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
    <div class="max-w-xl">
      <h3 class="font-headline text-4xl text-[#172c1d] font-bold mb-4">New Hunter's Field Guide</h3>
      <p class="text-[#434843] font-body leading-relaxed">This space is a practical guide to take a mere man and turn him into a hunter. It's for those who want to partake in the heritage of the hunt but do not know where to begin.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

    <!-- Become the Hunter -->
    <div onclick="enterApp('become')" class="md:col-span-4 bg-[#f8f3e5] overflow-hidden flex flex-col justify-between rounded-xl group cursor-pointer">
      <div class="h-48 overflow-hidden">
        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="./images/bth.png" alt="Become the Hunter"/>
      </div>
      <div class="p-8">
        <h4 class="font-headline text-2xl text-[#172c1d] font-bold mb-3">Become the Hunter</h4>
        <p class="text-[#434843] text-sm leading-relaxed mb-5">A foundational educational guide for those stepping into the wilderness for the first time.</p>
        <span class="text-[#172c1d] font-bold border-b border-[#172c1d] uppercase text-xs tracking-widest hover:text-[#80552c] hover:border-[#80552c] transition-colors">Step by Step Roadmap →</span>
      </div>
    </div>

    <!-- Choose Your Prey -->
    <div onclick="startQuiz()" class="md:col-span-4 bg-[#172c1d] overflow-hidden flex flex-col justify-between rounded-xl group cursor-pointer">
      <div class="h-48 overflow-hidden">
        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="./images/cyp.png" alt="Choose Your Prey"/>
      </div>
      <div class="p-8">
        <h4 class="font-headline text-2xl text-white font-bold mb-3">Choose Your Prey</h4>
        <p class="text-[#b4cdb7] text-sm leading-relaxed">Find opportunities by species, season, and availability based on how you want to hunt.</p>
        <div class="mt-6 flex flex-wrap gap-2">
          <span class="bg-[#fef9eb] text-[#172c1d] px-2 py-0.5 text-[9px] uppercase font-bold rounded-full">Big Game</span>
          <span class="bg-[#fef9eb] text-[#172c1d] px-2 py-0.5 text-[9px] uppercase font-bold rounded-full">Waterfowl</span>
          <span class="bg-[#fef9eb] text-[#172c1d] px-2 py-0.5 text-[9px] uppercase font-bold rounded-full">Small Game</span>
        </div>
        <span class="text-white font-bold border-b border-white uppercase text-xs tracking-widest mt-5 block hover:text-[#ffdcc1] hover:border-[#ffdcc1] transition-colors">We'll match you with the right animal →</span>
      </div>
    </div>

    <!-- Know Your Prey -->
    <div onclick="enterApp('animals')" class="md:col-span-4 bg-[#ede8da] overflow-hidden flex flex-col justify-between rounded-xl group cursor-pointer">
      <div class="h-48 overflow-hidden">
        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="./images/kyp.png" alt="Know Your Prey"/>
      </div>
      <div class="p-8">
        <h4 class="font-headline text-2xl text-[#172c1d] font-bold mb-3">Know Your Prey</h4>
        <p class="text-[#434843] text-sm leading-relaxed mb-5">Detailed behavior patterns and biological data for ethical harvest.</p>
        <span class="text-[#172c1d] font-bold border-b border-[#172c1d] uppercase text-xs tracking-widest hover:text-[#80552c] hover:border-[#80552c] transition-colors">Species Info to Regulations →</span>
      </div>
    </div>

    <!-- Prepare for the Hunt -->
    <div onclick="enterApp('pack')" class="md:col-span-4 bg-[#172c1d] overflow-hidden flex flex-col justify-between rounded-xl group cursor-pointer">
      <div class="h-48 overflow-hidden">
        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="./images/pfth.png" alt="Prepare for the Hunt"/>
      </div>
      <div class="p-8">
        <h4 class="font-headline text-2xl text-white font-bold mb-3">Prepare for the Hunt</h4>
        <p class="text-[#b4cdb7] text-sm leading-relaxed mb-4">Essential gear checklists and first aid kit assembly for a successful expedition.</p>
        <span class="text-white font-bold border-b border-white uppercase text-xs tracking-widest mt-4 block hover:text-[#ffdcc1] hover:border-[#ffdcc1] transition-colors">Get right gear for the hunt →</span>
      </div>
    </div>

    <!-- Hunting Cost -->
    <div onclick="enterApp('budget')" class="md:col-span-4 bg-[#80552c]/5 border border-[#80552c]/10 overflow-hidden flex flex-col justify-between rounded-xl group cursor-pointer">
      <div class="h-48 overflow-hidden">
        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="./images/hc.png" alt="Hunting Cost"/>
      </div>
      <div class="p-8">
        <h4 class="font-headline text-2xl text-[#172c1d] font-bold mb-3">Hunting Cost</h4>
        <p class="text-[#434843] text-sm leading-relaxed mb-4">Calculate licensing fees, permits, weapon cost, boots, clothing and everything else you need.</p>
        <span class="text-[#172c1d] font-bold border-b border-[#172c1d] uppercase text-xs tracking-widest hover:text-[#80552c] hover:border-[#80552c] transition-colors">You can put a price on it →</span>
      </div>
    </div>

    <!-- All Hunting Spots -->
    <div onclick="enterApp('browse')" class="md:col-span-4 relative overflow-hidden flex flex-col justify-end rounded-xl group cursor-pointer" style="min-height:450px">
      <div class="absolute inset-0 z-0">
        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="./images/all_hunting_spots.png" alt="All Hunting Spots"/>
        <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(23,44,29,.9), rgba(23,44,29,.4) 50%, transparent)"></div>
      </div>
      <div class="relative z-10 p-8">
        <h4 class="font-headline text-2xl text-white font-bold mb-3">All Hunting Spots</h4>
        <p class="text-[#b4cdb7] text-sm leading-relaxed mb-4">Access our comprehensive map archive to explore the best hunting terrains across the state.</p>
        <span class="text-white font-bold border-b border-white uppercase text-xs tracking-widest hover:text-[#ffdcc1] hover:border-[#ffdcc1] transition-colors">Explore the Terrain →</span>
      </div>
    </div>

  </div>
</section>

<!-- Editorial Section -->
<section class="bg-[#172c1d] py-24 px-8 overflow-hidden relative">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-20 items-center">
    <div class="w-full md:w-1/2">
      <img class="aspect-[4/5] object-cover rounded-sm w-full max-w-sm" src="./images/conservation.png" alt="Hunter in the field"/>
    </div>
    <div class="w-full md:w-1/2">
      <h3 class="font-headline text-5xl text-[#fec391] font-bold mb-8">Conservation is the Core of the Hunter.</h3>
      <p class="text-[#d0e9d2] text-lg leading-relaxed mb-8 italic">"To hunt is to witness the cycle of nature firsthand. We do not take; we participate. Our records ensure that the generations following us find the woods as vibrant as we did in 1889."</p>
      <div class="h-1 w-24 bg-[#80552c] mb-12"></div>
      <div class="grid grid-cols-2 gap-8">
        <div>
          <p class="text-white font-bold text-4xl mb-1">1.2M</p>
          <p class="text-[#96ae99] text-xs uppercase tracking-widest">Acres Protected</p>
        </div>
        <div>
          <p class="text-white font-bold text-4xl mb-1">45+</p>
          <p class="text-[#96ae99] text-xs uppercase tracking-widest">Active Species</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Donate -->
<section class="w-full bg-[#fef9eb] py-12 flex justify-center">
  <a href="#" class="flex items-center gap-2 px-8 py-4 rounded-full font-label font-bold text-base text-white hover:opacity-90 transition-all uppercase tracking-widest shadow-lg" style="background-color:#FF6700">
    <span>Donate to Support</span>
    <span class="material-symbols-outlined text-xl">favorite</span>
  </a>
</section>

<!-- Footer -->
<footer class="w-full bg-[#172c1d] py-12 px-8 flex flex-col md:flex-row justify-between items-center gap-6">
  <div class="flex flex-col gap-2">
    <div class="font-headline text-lg text-[#fec391] italic font-bold">New Hunter's Field Guide</div>
    <p class="text-xs font-light tracking-wide text-[#fef9eb]">© 2026 All rights reserved.</p>
  </div>
  <div class="flex flex-wrap justify-center gap-8">
    <a href="#" class="text-xs font-light tracking-wide text-[#fef9eb]/60 hover:text-[#fef9eb] transition-opacity">Regulations</a>
    <a href="#" class="text-xs font-light tracking-wide text-[#fef9eb]/60 hover:text-[#fef9eb] transition-opacity">Other States</a>
    <a href="#" class="text-xs font-light tracking-wide text-[#fef9eb]/60 hover:text-[#fef9eb] transition-opacity">Privacy Policy</a>
  </div>
  <div class="flex gap-4">
    <button class="w-10 h-10 flex items-center justify-center rounded-full border border-[#fef9eb]/20 text-[#fef9eb]/60 hover:border-[#fec391] hover:text-[#fec391] transition-all">
      <span class="material-symbols-outlined text-sm">share</span>
    </button>
    <button class="w-10 h-10 flex items-center justify-center rounded-full border border-[#fef9eb]/20 text-[#fef9eb]/60 hover:border-[#fec391] hover:text-[#fec391] transition-all">
      <span class="material-symbols-outlined text-sm">mail</span>
    </button>
  </div>
</footer>

</div><!-- /#home-page -->


<!-- ═══════════════════════════════════════════════════════
     APP SHELL — inner screens
════════════════════════════════════════════════════════════ -->
<div id="app-shell">

  <!-- Inner Header -->
  <div class="inner-header" id="innerHeader">
    <button class="back-btn" onclick="homePage()">‹</button>
    <div style="flex:1">
      <div class="hdr-sub">WASHINGTON STATE</div>
      <div class="hdr-title" id="innerTitle">Beginners Hunting Guide</div>
    </div>
    <button class="gps-btn" id="gpsHeaderBtn" onclick="requestGPS()" style="display:none">📍 Near Me</button>
  </div>

<!-- ══ BECOME THE HUNTER ══ -->
<div class="screen" id="screen-become">
  <div style="flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:90px">

    <!-- Header -->
    <div style="padding:18px 18px 8px">
      <div style="font-size:10px;letter-spacing:3px;color:#7ab8ff;margin-bottom:4px">YOUR ROADMAP</div>
      <div style="font-size:22px;font-weight:700;color:#f0e4c0;margin-bottom:6px">Become the Hunter</div>
      <div style="font-size:13px;color:#6a7a60;line-height:1.6">Everything you need to go from zero to your first successful hunt in Washington State. Follow these steps in order.</div>
    </div>

    <!-- Progress overview pills -->
    <div style="display:flex;gap:6px;padding:8px 18px 16px;overflow-x:auto;-webkit-overflow-scrolling:touch">
      <div style="background:rgba(74,222,128,.15);border:1px solid rgba(74,222,128,.3);border-radius:20px;padding:5px 12px;font-size:11px;color:#4ade80;white-space:nowrap;font-weight:600">① Decide</div>
      <div style="background:rgba(120,180,255,.12);border:1px solid rgba(120,180,255,.3);border-radius:20px;padding:5px 12px;font-size:11px;color:#7ab8ff;white-space:nowrap;font-weight:600">② Educate</div>
      <div style="background:rgba(180,140,60,.15);border:1px solid rgba(180,140,60,.3);border-radius:20px;padding:5px 12px;font-size:11px;color:#d4a840;white-space:nowrap;font-weight:600">③ License</div>
      <div style="background:rgba(180,100,60,.15);border:1px solid rgba(180,100,60,.3);border-radius:20px;padding:5px 12px;font-size:11px;color:#e07840;white-space:nowrap;font-weight:600">④ Gear Up</div>
      <div style="background:rgba(180,60,180,.12);border:1px solid rgba(180,60,180,.3);border-radius:20px;padding:5px 12px;font-size:11px;color:#c060c0;white-space:nowrap;font-weight:600">⑤ Scout</div>
      <div style="background:rgba(74,222,128,.15);border:1px solid rgba(74,222,128,.3);border-radius:20px;padding:5px 12px;font-size:11px;color:#4ade80;white-space:nowrap;font-weight:600">⑥ Hunt</div>
    </div>

    <div style="padding:0 18px">

      <!-- STEP 1 -->
      <div style="background:rgba(74,222,128,.07);border:1.5px solid rgba(74,222,128,.25);border-radius:16px;padding:18px;margin-bottom:14px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
          <div style="background:rgba(74,222,128,.2);border:1.5px solid rgba(74,222,128,.4);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">🎯</div>
          <div>
            <div style="font-size:10px;letter-spacing:2px;color:#4ade80;font-weight:600;margin-bottom:2px">STEP 1 · DECIDE</div>
            <div style="font-size:16px;font-weight:700;color:#f0e4c0">Figure Out What to Hunt</div>
          </div>
        </div>
        <div style="font-size:13px;color:#8a9a7a;line-height:1.7;margin-bottom:12px">This is the most important decision because it determines your license, gear, season, and location. Don't overthink it — most beginners start with one of three animals.</div>
        <div style="background:rgba(0,0,0,.2);border-radius:10px;padding:12px;margin-bottom:10px">
          <div style="font-size:11px;font-weight:700;color:#4ade80;margin-bottom:8px">BEST FIRST ANIMALS FOR WA BEGINNERS</div>
          <div style="font-size:13px;color:#a0b090;line-height:1.8">
            🌲 <strong style="color:#e8dcc8">Black-tailed Deer</strong> — Most popular. Public land everywhere west of the Cascades. Great eating. Long season.<br>
            🐦 <strong style="color:#e8dcc8">Pheasant / Upland Birds</strong> — Lower cost, no big game license needed, fast-paced fun shooting.<br>
            🐇 <strong style="color:#e8dcc8">Cottontail Rabbit</strong> — Year-round, no bag limit, no special tag. Perfect first hunt.
          </div>
        </div>
        <button onclick="startQuiz()" style="width:100%;background:rgba(74,222,128,.15);border:1px solid rgba(74,222,128,.4);color:#4ade80;border-radius:10px;padding:11px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer">
          🧭 Take the Quiz — Get a Personal Recommendation →
        </button>
      </div>

      <!-- STEP 2 -->
      <div style="background:rgba(120,180,255,.06);border:1.5px solid rgba(120,180,255,.2);border-radius:16px;padding:18px;margin-bottom:14px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
          <div style="background:rgba(120,180,255,.15);border:1.5px solid rgba(120,180,255,.35);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">📚</div>
          <div>
            <div style="font-size:10px;letter-spacing:2px;color:#7ab8ff;font-weight:600;margin-bottom:2px">STEP 2 · EDUCATE</div>
            <div style="font-size:16px;font-weight:700;color:#f0e4c0">Complete Hunter Education</div>
          </div>
        </div>
        <div style="font-size:13px;color:#8a9a7a;line-height:1.7;margin-bottom:10px"><strong style="color:#e8dcc8">Required by law</strong> in Washington if you were born on or after January 1, 1972. You cannot buy a hunting license without it. The good news — it's completely free.</div>
        <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:12px">
          <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:#8a9a7a;line-height:1.5">
            <strong style="color:#7ab8ff">Option A — Online + Field Day (most popular)</strong><br>
            Complete the online course at hunter-ed.com (~8–10 hours at your own pace), then attend a free in-person field day in your area. Takes about 2 weekends total.
          </div>
          <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:#8a9a7a;line-height:1.5">
            <strong style="color:#7ab8ff">Option B — Traditional Classroom Course</strong><br>
            8-hour classroom + field day, all in one weekend. Find courses at wdfw.wa.gov — typically offered fall and spring near you.
          </div>
        </div>
        <div style="display:flex;gap:8px">
          <a href="https://www.hunter-ed.com/washington/" target="_blank" style="flex:1;display:flex;align-items:center;justify-content:center;background:rgba(120,180,255,.15);border:1px solid rgba(120,180,255,.35);color:#7ab8ff;border-radius:10px;padding:11px;font-size:12px;font-weight:700;text-decoration:none;text-align:center">📖 Start Free Course</a>
          <a href="https://wdfw.wa.gov/hunting/requirements/education" target="_blank" style="flex:1;display:flex;align-items:center;justify-content:center;background:rgba(120,180,255,.15);border:1px solid rgba(120,180,255,.35);color:#7ab8ff;border-radius:10px;padding:11px;font-size:12px;font-weight:700;text-decoration:none;text-align:center">📅 Find a Class</a>
        </div>
      </div>

      <!-- STEP 3 -->
      <div style="background:rgba(180,140,60,.07);border:1.5px solid rgba(180,140,60,.25);border-radius:16px;padding:18px;margin-bottom:14px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
          <div style="background:rgba(180,140,60,.15);border:1.5px solid rgba(180,140,60,.4);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">🎫</div>
          <div>
            <div style="font-size:10px;letter-spacing:2px;color:#d4a840;font-weight:600;margin-bottom:2px">STEP 3 · LICENSE</div>
            <div style="font-size:16px;font-weight:700;color:#f0e4c0">Buy Your License & Tags</div>
          </div>
        </div>
        <div style="font-size:13px;color:#8a9a7a;line-height:1.7;margin-bottom:10px">Once you have your Hunter Ed certificate number, you can buy your license online in about 5 minutes. You need both a base license and a tag for the specific animal you're hunting.</div>
        <div style="background:rgba(0,0,0,.2);border-radius:10px;padding:12px;margin-bottom:12px">
          <div style="font-size:11px;font-weight:700;color:#d4a840;margin-bottom:8px">2025 WA RESIDENT LICENSE COSTS</div>
          <div style="display:flex;flex-direction:column;gap:6px">
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#8a9a7a;padding-bottom:5px;border-bottom:1px solid rgba(255,255,255,.06)"><span>Small Game (rabbits, grouse, pheasant)</span><span style="color:#d4a840;font-weight:700">$27</span></div>
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#8a9a7a;padding-bottom:5px;border-bottom:1px solid rgba(255,255,255,.06)"><span>Deer Tag Only</span><span style="color:#d4a840;font-weight:700">$49</span></div>
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#8a9a7a;padding-bottom:5px;border-bottom:1px solid rgba(255,255,255,.06)"><span>Deer + Elk Package</span><span style="color:#d4a840;font-weight:700">$117</span></div>
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#8a9a7a;padding-bottom:5px;border-bottom:1px solid rgba(255,255,255,.06)"><span>Migratory Bird (ducks/geese)</span><span style="color:#d4a840;font-weight:700">$28</span></div>
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#8a9a7a"><span>Discover Pass (park at public land)</span><span style="color:#d4a840;font-weight:700">$35</span></div>
          </div>
        </div>
        <div style="background:rgba(180,140,60,.08);border:1px solid rgba(180,140,60,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:#8a7040;margin-bottom:12px;line-height:1.5">
          ⚠️ <strong style="color:#d4a840">Important:</strong> Buy your license BEFORE you go. You must have it on your person while hunting. Tags must be attached to harvested animals immediately.
        </div>
        <a href="https://fishhunt.dfw.wa.gov" target="_blank" style="display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(180,140,60,.2);border:1px solid rgba(180,140,60,.45);color:#d4a840;border-radius:10px;padding:12px;font-size:13px;font-weight:700;text-decoration:none">🎫 Buy WA License at fishhunt.dfw.wa.gov</a>
      </div>

      <!-- STEP 4 -->
      <div style="background:rgba(180,100,60,.07);border:1.5px solid rgba(180,100,60,.22);border-radius:16px;padding:18px;margin-bottom:14px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
          <div style="background:rgba(180,100,60,.15);border:1.5px solid rgba(180,100,60,.35);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">🔫</div>
          <div>
            <div style="font-size:10px;letter-spacing:2px;color:#e07840;font-weight:600;margin-bottom:2px">STEP 4 · GEAR UP</div>
            <div style="font-size:16px;font-weight:700;color:#f0e4c0">Get the Right Firearm & Gear</div>
          </div>
        </div>
        <div style="font-size:13px;color:#8a9a7a;line-height:1.7;margin-bottom:12px">You don't need expensive gear to start. Here's what actually matters for your first hunt.</div>

        <div style="font-size:11px;font-weight:700;color:#e07840;margin-bottom:8px">CHOOSING YOUR FIRST GUN</div>
        <div style="display:flex;flex-direction:column;gap:7px;margin-bottom:12px">
          <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px">
            <div style="font-size:12px;font-weight:700;color:#e8dcc8;margin-bottom:3px">🦌 Deer / Big Game → Bolt-action Rifle</div>
            <div style="font-size:12px;color:#8a9a7a;line-height:1.5">Best starter: Savage Axis II (~$400) or Ruger American (~$450). Get it in .308 Win or .243 Win — both are widely available, manageable recoil, deadly on deer.</div>
          </div>
          <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px">
            <div style="font-size:12px;font-weight:700;color:#e8dcc8;margin-bottom:3px">🐦 Birds / Turkey → Shotgun</div>
            <div style="font-size:12px;color:#8a9a7a;line-height:1.5">Best starter: Mossberg 500 (~$380) or Remington 870 (~$400). A 12-gauge handles everything from pheasant to turkey. Get a modified choke for versatility.</div>
          </div>
          <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px">
            <div style="font-size:12px;font-weight:700;color:#e8dcc8;margin-bottom:3px">🐇 Small Game / Rabbit → .22 Rifle</div>
            <div style="font-size:12px;color:#8a9a7a;line-height:1.5">Ruger 10/22 (~$300) is the classic. Cheap to shoot, low recoil, perfect for learning fundamentals before moving up to big game.</div>
          </div>
        </div>

        <div style="font-size:11px;font-weight:700;color:#e07840;margin-bottom:8px">WHERE TO BUY IN WASHINGTON</div>
        <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px;margin-bottom:10px;font-size:12px;color:#8a9a7a;line-height:1.7">
          <strong style="color:#e8dcc8">Cabela's / Bass Pro</strong> (Auburn, Tacoma, Tulalip) — Huge selection, staff know hunting<br>
          <strong style="color:#e8dcc8">Sportsman's Warehouse</strong> — Multiple WA locations, competitive pricing<br>
          <strong style="color:#e8dcc8">Local gun stores</strong> — Often best advice, willing to let you handle guns before buying<br>
          <strong style="color:#e8dcc8">Facebook Marketplace / GunBroker</strong> — Good used deals, must go through licensed dealer (FFL) for transfers
        </div>

        <div style="font-size:11px;font-weight:700;color:#e07840;margin-bottom:8px">WA STATE GUN PURCHASE RULES</div>
        <div style="background:rgba(180,100,60,.08);border:1px solid rgba(180,100,60,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:#8a7060;line-height:1.6">
          • Must be 18+ for rifles/shotguns, 21+ for handguns<br>
          • Background check required for ALL firearm purchases in WA (including private sales)<br>
          • 10-business-day waiting period on all firearms<br>
          • No magazine capacity restriction for hunting rifles
        </div>

        <div style="margin-top:12px;font-size:11px;font-weight:700;color:#e07840;margin-bottom:8px">ESSENTIAL GEAR CHECKLIST</div>
        <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:#8a9a7a;line-height:1.8">
          ✓ Hunter orange vest + hat (400 sq in required during firearm deer season)<br>
          ✓ Waterproof boots with ankle support<br>
          ✓ Layered clothing — base, mid, outer shell<br>
          ✓ Binoculars (8x42 minimum for deer hunting)<br>
          ✓ Sharp hunting knife + game bags<br>
          ✓ Gaia GPS app with offline WA maps downloaded<br>
          ✓ OnX Hunt app — shows public vs. private land boundaries<br>
          ✓ First aid kit, headlamp, food, water
        </div>
        <button onclick="showScreen('budget')" style="width:100%;margin-top:12px;background:rgba(180,100,60,.15);border:1px solid rgba(180,100,60,.35);color:#e07840;border-radius:10px;padding:11px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer">
          💰 Calculate Your Full Budget →
        </button>
      </div>

      <!-- STEP 5 -->
      <div style="background:rgba(180,60,180,.06);border:1.5px solid rgba(180,60,180,.2);border-radius:16px;padding:18px;margin-bottom:14px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
          <div style="background:rgba(180,60,180,.12);border:1.5px solid rgba(180,60,180,.3);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">🗺️</div>
          <div>
            <div style="font-size:10px;letter-spacing:2px;color:#c060c0;font-weight:600;margin-bottom:2px">STEP 5 · SCOUT</div>
            <div style="font-size:16px;font-weight:700;color:#f0e4c0">Find Where to Hunt</div>
          </div>
        </div>
        <div style="font-size:13px;color:#8a9a7a;line-height:1.7;margin-bottom:12px">Washington has millions of acres of public land. You never need permission to hunt public land — but you must know the boundaries so you don't accidentally cross onto private property.</div>

        <div style="font-size:11px;font-weight:700;color:#c060c0;margin-bottom:8px">ESSENTIAL APPS — DOWNLOAD BEFORE YOU GO</div>
        <div style="display:flex;flex-direction:column;gap:7px;margin-bottom:12px">
          <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px">
            <div style="font-size:12px;font-weight:700;color:#e8dcc8;margin-bottom:3px">OnX Hunt — Most Important App</div>
            <div style="font-size:12px;color:#8a9a7a;line-height:1.5">Shows public vs. private land boundaries in real time using your GPS. The #1 tool to avoid trespassing. ~$30/year. Download offline maps before leaving cell service.</div>
          </div>
          <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px">
            <div style="font-size:12px;font-weight:700;color:#e8dcc8;margin-bottom:3px">Gaia GPS — Navigation</div>
            <div style="font-size:12px;color:#8a9a7a;line-height:1.5">Download full WA topo maps offline. Works without cell service. Know how to get back to your car even if you get turned around in the timber.</div>
          </div>
          <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px">
            <div style="font-size:12px;font-weight:700;color:#e8dcc8;margin-bottom:3px">WA DNR Road Viewer — Timber Roads</div>
            <div style="font-size:12px;color:#8a9a7a;line-height:1.5">Shows which DNR logging roads are open and which require a Green Dot permit. Essential for western WA timber country hunting.</div>
          </div>
        </div>

        <div style="font-size:11px;font-weight:700;color:#c060c0;margin-bottom:8px">BEST PUBLIC LAND FOR BEGINNERS</div>
        <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px;margin-bottom:12px;font-size:12px;color:#8a9a7a;line-height:1.7">
          <strong style="color:#e8dcc8">WDFW Wildlife Areas</strong> — Managed specifically for public hunting. No permission needed. Signs mark the boundaries.<br>
          <strong style="color:#e8dcc8">National Forests</strong> — Millions of acres. Great for deer, elk, grouse. Requires downloaded maps.<br>
          <strong style="color:#e8dcc8">DNR Timber Lands</strong> — Huge clearcut areas, excellent for western WA black-tail deer.<br>
          <strong style="color:#e8dcc8">BLM Land</strong> — Common in eastern WA. Open sagebrush great for birds and mule deer.
        </div>
        <button onclick="requestGPS()" style="width:100%;background:rgba(180,60,180,.12);border:1px solid rgba(180,60,180,.3);color:#c060c0;border-radius:10px;padding:11px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer">
          📍 Find Hunting Spots Near Me →
        </button>
      </div>

      <!-- STEP 6 -->
      <div style="background:rgba(74,222,128,.07);border:1.5px solid rgba(74,222,128,.25);border-radius:16px;padding:18px;margin-bottom:14px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
          <div style="background:rgba(74,222,128,.2);border:1.5px solid rgba(74,222,128,.4);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">🌅</div>
          <div>
            <div style="font-size:10px;letter-spacing:2px;color:#4ade80;font-weight:600;margin-bottom:2px">STEP 6 · HUNT</div>
            <div style="font-size:16px;font-weight:700;color:#f0e4c0">Go On Your First Hunt</div>
          </div>
        </div>
        <div style="font-size:13px;color:#8a9a7a;line-height:1.7;margin-bottom:12px">You're ready. Here's what to do the first time out.</div>
        <div style="background:rgba(0,0,0,.2);border-radius:10px;padding:12px;margin-bottom:12px">
          <div style="font-size:11px;font-weight:700;color:#4ade80;margin-bottom:8px">MORNING OF YOUR HUNT</div>
          <div style="font-size:12px;color:#8a9a7a;line-height:1.9">
            ① Check the WA hunting regulations for your GMU at wdfw.wa.gov<br>
            ② Confirm your license and tag are in your pack<br>
            ③ Tell someone where you're going and when you'll be back<br>
            ④ Arrive at your spot before first legal shooting light (30 min before sunrise)<br>
            ⑤ Move slowly, stay quiet, and watch more than you walk<br>
            ⑥ If you harvest an animal — tag it immediately before moving it
          </div>
        </div>
        <div style="background:rgba(74,222,128,.08);border:1px solid rgba(74,222,128,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:#5a8a5a;line-height:1.6;margin-bottom:12px">
          💡 <strong style="color:#4ade80">First hunt tip:</strong> Don't go alone your first time if you can help it. Ask an experienced hunter to come with you — even one trip with a mentor teaches you more than 10 hours of reading.
        </div>
        <div style="font-size:11px;font-weight:700;color:#4ade80;margin-bottom:8px">AFTER A SUCCESSFUL HARVEST</div>
        <div style="background:rgba(0,0,0,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:#8a9a7a;line-height:1.7">
          • Tag the animal immediately (attach physical tag)<br>
          • Field dress as soon as possible to cool the meat (YouTube has great tutorials)<br>
          • Report your harvest at fishhunt.dfw.wa.gov within 10 days (required by law)<br>
          • Process at home or take to a local butcher ($150–400 for deer)
        </div>
      </div>

      <!-- Bonus: Find a Mentor -->
      <div style="background:rgba(255,255,255,.04);border:1.5px solid rgba(255,255,255,.09);border-radius:16px;padding:18px;margin-bottom:14px">
        <div style="font-size:14px;font-weight:700;color:#f0e4c0;margin-bottom:6px">🤝 Find a Hunting Mentor</div>
        <div style="font-size:13px;color:#8a9a7a;line-height:1.7;margin-bottom:10px">WDFW has a free <strong style="color:#e8dcc8">Apprentice Hunter</strong> program that lets unlicensed beginners hunt with a licensed mentor before completing Hunter Ed. It's the fastest way to learn.</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <a href="https://wdfw.wa.gov/hunting/requirements/hunting-clinics" target="_blank" style="flex:1;min-width:140px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:#a0b090;border-radius:10px;padding:11px;font-size:12px;font-weight:700;text-decoration:none;text-align:center">🎯 WDFW Hunting Clinics & Mentored Hunts</a>
          <a href="https://www.firsthuntfoundation.com" target="_blank" style="flex:1;min-width:140px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:#a0b090;border-radius:10px;padding:11px;font-size:12px;font-weight:700;text-decoration:none;text-align:center">🤝 First Hunt Foundation — Find a Mentor</a>
        </div>
      </div>

    </div><!-- end padding wrapper -->
  </div>
</div>

<!-- ══ QUIZ: WHAT SHOULD I HUNT? ══ -->
<div class="screen" id="screen-quiz">
  <div style="flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:90px">
    <div style="padding:18px 18px 4px">
      <div style="font-size:10px;letter-spacing:3px;color:#b48c3c;margin-bottom:4px">PERSONALIZED GUIDE</div>
      <div style="font-size:20px;font-weight:700;color:#f0e4c0;margin-bottom:6px">Choose Your Prey</div>
      <div style="font-size:13px;color:#6a7a60;line-height:1.6">Answer a few plain questions and we'll match you with the right animal to start with.</div>
    </div>

    <!-- Progress bar -->
    <div style="padding:12px 18px 0">
      <div style="display:flex;justify-content:space-between;margin-bottom:5px">
        <div style="font-size:11px;color:#5a6a50" id="quizProgress">Question 1 of 5</div>
        <div style="font-size:11px;color:#5a6a50" id="quizPct">0%</div>
      </div>
      <div style="background:rgba(255,255,255,.07);border-radius:4px;height:4px;overflow:hidden">
        <div id="quizBar" style="background:#b48c3c;height:4px;width:0%;transition:width .3s ease;border-radius:4px"></div>
      </div>
    </div>

    <!-- Questions container -->
    <div id="quizQuestions" style="padding:16px 18px 0"></div>

    <!-- Results container -->
    <div id="quizResults" style="display:none;padding:16px 18px 0"></div>
  </div>
</div>

<!-- ══ BUDGET ESTIMATOR ══ -->
<div class="screen" id="screen-budget">
  <div style="flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:90px">
    <div style="padding:18px 18px 4px">
      <div style="font-size:10px;letter-spacing:3px;color:#b48c3c;margin-bottom:4px">FIRST-YEAR COST GUIDE</div>
      <div style="font-size:20px;font-weight:700;color:#f0e4c0;margin-bottom:6px">Hunting Cost</div>
      <div style="font-size:13px;color:#6a7a60;line-height:1.6">Pick your situation and see a realistic budget — from licenses to gear. Prices are 2025 Washington State figures.</div>
    </div>
    <div style="padding:12px 18px 0" id="budgetForm"></div>
    <div style="padding:0 18px" id="budgetResults" style="display:none"></div>
  </div>
</div>

<!-- ══ NEAR ME ══ -->
<div class="screen" id="screen-near">
  <div class="center-msg" id="gpsLoading" style="display:none">
    <div style="font-size:52px">📡</div>
    <div style="font-size:17px;font-weight:700;color:#b48c3c">Finding your location…</div>
    <div style="font-size:13px;color:#6a7a60;line-height:1.6">Your browser will ask<br><strong style="color:#e8dcc8">"Allow location access?"</strong><br>Tap <strong style="color:#4ade80">Allow</strong> to continue.</div>
  </div>
  <div class="center-msg" id="gpsError" style="display:none">
    <div style="font-size:48px">⚠️</div>
    <div style="font-size:14px;color:#fb923c;line-height:1.6" id="gpsErrorMsg"></div>
    <button class="retry-btn" onclick="requestGPS()">Try Again</button>
    <button class="text-btn" onclick="showScreen('browse')">Browse all spots instead →</button>
  </div>
  <div id="gpsSuccess" style="display:none;flex:1;flex-direction:column;overflow:hidden;position:relative">
    <!-- Full-screen Leaflet map for Near Me -->
    <div id="nearMapDiv" class="hunt-map" style="flex:1;min-height:0;position:relative">
      <div style="position:absolute;top:10px;left:10px;z-index:800;display:flex;flex-direction:column;gap:6px">
        <div style="background:rgba(0,0,0,.7);border:1px solid rgba(180,140,60,.3);border-radius:8px;padding:6px 10px">
          <div class="near-label" style="margin:0">📍 NEAREST SPOTS</div>
          <div class="near-sub" id="nearSub" style="margin:0">deer spots shown</div>
        </div>
        <button onclick="openFilterDrawer('near')" style="background:rgba(0,0,0,.75);border:1px solid rgba(180,140,60,.4);color:#b48c3c;border-radius:8px;padding:7px 12px;font-size:12px;font-family:inherit;cursor:pointer;white-space:nowrap">⚙️ Filter</button>
      </div>
    </div>

  </div>
</div>

<!-- ══ BROWSE (ALL HUNTING SPOTS) ══ -->
<div class="screen" id="screen-browse" style="background:#fef9eb;overflow-y:auto;-webkit-overflow-scrolling:touch;">

  <!-- ── TOP NAV (mirrors home page) ── -->
  <header style="background:#fef9eb;border-bottom:1px solid #e7e2d4;position:sticky;top:0;z-index:50;flex-shrink:0">
    <nav style="display:flex;justify-content:center;align-items:center;width:100%;padding:16px">
      <div style="display:flex;justify-content:space-between;align-items:center;width:100%;max-width:448px">
        <button onclick="homePage()" style="display:flex;align-items:center;justify-content:center;padding:8px;color:#172c1d;background:none;border:none;cursor:pointer">
          <span class="material-symbols-outlined" style="font-size:28px">home</span>
        </button>
        <button onclick="enterApp('browse')" style="display:flex;align-items:center;justify-content:center;padding:8px;color:#172c1d;background:none;border:none;cursor:pointer">
          <span class="material-symbols-outlined" style="font-size:28px">map</span>
        </button>
        <button onclick="enterApp('pack')" style="display:flex;align-items:center;justify-content:center;padding:8px;color:#172c1d;background:none;border:none;cursor:pointer">
          <span class="material-symbols-outlined" style="font-size:28px">backpack</span>
        </button>
        <button onclick="enterApp('animals')" style="display:flex;align-items:center;justify-content:center;padding:8px;color:#172c1d;background:none;border:none;cursor:pointer">
          <span class="material-symbols-outlined" style="font-size:28px">favorite</span>
        </button>
      </div>
    </nav>
    <div style="background:#f8f3e5;height:1px;width:100%"></div>
  </header>

  <!-- ── PAGE HEADER ── -->
  <div style="padding:32px 24px 0">
    <h2 style="font-family:'Newsreader',Georgia,serif;font-size:clamp(40px,10vw,72px);font-weight:800;color:#172c1d;line-height:1;letter-spacing:-1px;margin-bottom:12px">Hunting Spots</h2>
    <p style="font-family:'Work Sans',sans-serif;font-size:16px;color:#434843;line-height:1.6;max-width:520px;margin-bottom:24px">Explore public land and managed access hunting spots across Washington State. A curated archive for the modern outdoorsman.</p>

    <!-- Filter bar -->
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap">
      <div style="position:relative" id="filterDropdownWrap">
        <button onclick="openFilterDrawer('browse')" id="browseFilterBtn" style="display:flex;align-items:center;gap:8px;padding:10px 20px;background:#172c1d;color:#fff;border:none;border-radius:999px;font-family:'Work Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;box-shadow:0 2px 8px rgba(23,44,29,.2)">
          <span class="material-symbols-outlined" style="font-size:16px">tune</span>
          Filter by Species
          <span class="material-symbols-outlined" style="font-size:14px;opacity:.7">keyboard_arrow_down</span>
          <span id="browseFilterCount" style="color:#fec391;font-weight:800"></span>
        </button>
      </div>
      <button id="tab-spots" onclick="setTab('spots')" style="padding:10px 18px;border-radius:999px;border:1.5px solid #172c1d;background:#172c1d;color:#fff;font-family:'Work Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer">Map & Spots</button>
      <button id="tab-tips" onclick="setTab('tips')" style="padding:10px 18px;border-radius:999px;border:1.5px solid #c3c8c1;background:transparent;color:#434843;font-family:'Work Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer">Field Tips</button>
    </div>
  </div>

  <!-- ── SPOTS TAB ── -->
  <div id="browseSpots" style="display:flex;flex-direction:column">

    <!-- Map + Active Detail panel -->
    <div style="padding:16px 24px;display:flex;flex-direction:column;gap:16px">

      <!-- Map card -->
      <div style="border-radius:12px;overflow:hidden;border:1px solid #e7e2d4;box-shadow:0 2px 12px rgba(23,44,29,.06);height:480px;position:relative;background:#e7e2d4">
        <div id="browseMapDiv" style="width:100%;height:100%"></div>
      </div>

      <!-- Selected spot detail panel — hidden until a spot is selected -->
      <div id="browseDetailPanel" style="display:none;background:#fff;border:1px solid #e7e2d4;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(23,44,29,.06)">
        <!-- image strip -->
        <div id="browseDetailImg" style="height:96px;background:#2d4232;position:relative;overflow:hidden"></div>
        <!-- body -->
        <div style="padding:16px 18px" id="browseDetailBody"></div>
        <!-- directions button -->
        <div style="padding:0 18px 18px">
          <a id="browseDetailDir" href="#" target="_blank" style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:12px;background:#80552c;color:#fff;border-radius:8px;font-family:'Work Sans',sans-serif;font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-decoration:none">
            <span class="material-symbols-outlined" style="font-size:16px">directions</span>
            Get Directions to This Spot
          </a>
        </div>
      </div>

    </div>

    <!-- Explore destinations header -->
    <div style="padding:8px 24px 12px;display:flex;align-items:baseline;justify-content:space-between">
      <h3 style="font-family:'Newsreader',Georgia,serif;font-size:28px;font-weight:700;color:#172c1d">Explore Destinations</h3>
      <span id="browseSpotCount" style="font-family:'Work Sans',sans-serif;font-size:11px;color:#737972;letter-spacing:1px;text-transform:uppercase"></span>
    </div>

    <!-- Spot cards grid -->
    <div id="browseList" style="padding:0 24px 100px;display:grid;grid-template-columns:1fr;gap:16px"></div>

  </div>

  <!-- ── TIPS TAB ── -->
  <div id="browseTips" style="display:none;padding:16px 24px 100px">

    <div style="background:#fff;border:1px solid #e7e2d4;border-radius:12px;overflow:hidden;margin-bottom:16px">
      <div style="padding:20px 20px 14px;border-bottom:1px solid #f3eee0">
        <p style="font-family:'Newsreader',Georgia,serif;font-size:22px;font-weight:700;color:#172c1d;margin-bottom:4px">Scouting Tips</p>
        <p style="font-family:'Work Sans',sans-serif;font-size:12px;color:#737972">How to find and hunt Washington's public land</p>
      </div>
      <div style="padding:16px 20px;display:flex;flex-direction:column;gap:14px">
        <div style="display:flex;gap:14px;align-items:flex-start">
          <span style="font-size:20px;flex-shrink:0;margin-top:2px">📱</span>
          <div><p style="font-family:'Work Sans',sans-serif;font-size:13px;font-weight:600;color:#172c1d;margin-bottom:3px">Download offline maps before you go</p><p style="font-family:'Work Sans',sans-serif;font-size:12px;color:#434843;line-height:1.6">Cell service is unreliable in most WA hunting areas. Use Gaia GPS or OnX Hunt with maps downloaded.</p></div>
        </div>
        <div style="height:1px;background:#f3eee0"></div>
        <div style="display:flex;gap:14px;align-items:flex-start">
          <span style="font-size:20px;flex-shrink:0;margin-top:2px">🌅</span>
          <div><p style="font-family:'Work Sans',sans-serif;font-size:13px;font-weight:600;color:#172c1d;margin-bottom:3px">Hunt transition zones at dawn and dusk</p><p style="font-family:'Work Sans',sans-serif;font-size:12px;color:#434843;line-height:1.6">Edges between forest and open meadow — where brush meets a creek — hold the most deer.</p></div>
        </div>
        <div style="height:1px;background:#f3eee0"></div>
        <div style="display:flex;gap:14px;align-items:flex-start">
          <span style="font-size:20px;flex-shrink:0;margin-top:2px">🔭</span>
          <div><p style="font-family:'Work Sans',sans-serif;font-size:13px;font-weight:600;color:#172c1d;margin-bottom:3px">Glass before you walk</p><p style="font-family:'Work Sans',sans-serif;font-size:12px;color:#434843;line-height:1.6">Use binoculars to spot animals from a distance. Moving into an area spooks game. Sit and watch first.</p></div>
        </div>
        <div style="height:1px;background:#f3eee0"></div>
        <div style="display:flex;gap:14px;align-items:flex-start">
          <span style="font-size:20px;flex-shrink:0;margin-top:2px">💨</span>
          <div><p style="font-family:'Work Sans',sans-serif;font-size:13px;font-weight:600;color:#172c1d;margin-bottom:3px">Wind matters more than anything</p><p style="font-family:'Work Sans',sans-serif;font-size:12px;color:#434843;line-height:1.6">Always approach from downwind. Deer will smell you at 300+ yards.</p></div>
        </div>
        <div style="height:1px;background:#f3eee0"></div>
        <div style="display:flex;gap:14px;align-items:flex-start">
          <span style="font-size:20px;flex-shrink:0;margin-top:2px">⏰</span>
          <div><p style="font-family:'Work Sans',sans-serif;font-size:13px;font-weight:600;color:#172c1d;margin-bottom:3px">First and last hour is prime time</p><p style="font-family:'Work Sans',sans-serif;font-size:12px;color:#434843;line-height:1.6">Big game moves most at dawn and dusk. Be in position before first light.</p></div>
        </div>
      </div>
    </div>

    <div style="background:#172c1d;border-radius:12px;padding:20px">
      <p style="font-family:'Newsreader',Georgia,serif;font-size:20px;font-weight:700;color:#fec391;margin-bottom:14px">Essential Links</p>
      <div style="display:flex;flex-direction:column;gap:8px">
        <a href="https://fishhunt.dfw.wa.gov" target="_blank" style="display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:13px 16px;text-decoration:none">
          <span style="font-family:'Work Sans',sans-serif;font-size:13px;color:#fef9eb;font-weight:500">Buy WA License &amp; Tags</span>
          <span style="color:#fec391;font-size:16px">→</span>
        </a>
        <a href="https://wdfw.wa.gov/hunting/hunt-ed" target="_blank" style="display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:13px 16px;text-decoration:none">
          <span style="font-family:'Work Sans',sans-serif;font-size:13px;color:#fef9eb;font-weight:500">Free Hunter Ed Course</span>
          <span style="color:#fec391;font-size:16px">→</span>
        </a>
        <a href="https://wdfw.wa.gov/hunting/regulations" target="_blank" style="display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:13px 16px;text-decoration:none">
          <span style="font-family:'Work Sans',sans-serif;font-size:13px;color:#fef9eb;font-weight:500">2025–26 WA Hunting Regulations</span>
          <span style="color:#fec391;font-size:16px">→</span>
        </a>
      </div>
    </div>

  </div>
</div>

<!-- ══ ALL ANIMALS ══ -->
<div class="screen" id="screen-animals">
  <div style="padding:10px 14px 4px;font-size:13px;color:#7a8a70;flex-shrink:0">Tap any animal to see species info, hunting methods, calibers, and WA regulations.</div>
  <div style="flex:1;overflow-y:auto;padding-bottom:80px;-webkit-overflow-scrolling:touch" id="animalScrollArea">

    <div class="cat-section-label">🦌 BIG GAME — DEER & ELK</div>
    <div class="animal-grid" id="grid-deer-elk"></div>

    <div class="cat-section-label">🐻 BIG GAME — BEAR & PREDATORS</div>
    <div class="animal-grid" id="grid-bear"></div>

    <div class="cat-section-label">🏔️ BIG GAME — MOUNTAIN SPECIES</div>
    <div class="animal-grid" id="grid-mountain"></div>

    <div class="cat-section-label">🦃 UPLAND BIRDS</div>
    <div class="animal-grid" id="grid-upland"></div>

    <div class="cat-section-label">🦆 WATERFOWL</div>
    <div class="animal-grid" id="grid-waterfowl"></div>

    <div class="cat-section-label">🐇 SMALL GAME</div>
    <div class="animal-grid" id="grid-smallgame"></div>

  </div>
</div>

<!-- ══ PACK LIST ══ -->
<div class="screen" id="screen-pack">
  <div class="pack-tab-bar">
    <button class="pack-tbtn active" id="ptab-day" onclick="setPackTab('day')">☀️ Day Hunt</button>
    <button class="pack-tbtn" id="ptab-multi" onclick="setPackTab('multi')">🏕️ Multi-Day</button>
    <button class="pack-tbtn" id="ptab-firstaid" onclick="setPackTab('firstaid')">🏥 First Aid Kit</button>
  </div>
  <div style="flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch">
    <!-- DAY HUNT -->
    <div id="pack-day" style="padding:14px 14px 80px">
      <div style="background:rgba(74,222,128,.07);border:1px solid rgba(74,222,128,.2);border-radius:10px;padding:12px 14px;margin-bottom:16px;font-size:13px;color:#6a9a6a;line-height:1.6">
        <strong style="color:#4ade80">Day Hunt</strong> — leaving in the morning, back by dark. Typically 6–10 miles of hiking. Gear assumes WA fall weather: cold mornings, possible rain.
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🔫 FIREARMS & LICENSING</div>
        <div class="pack-item"><div class="pack-icon">🔫</div><div><div>Your firearm (rifle, shotgun, or bow)</div><div class="pack-note">WA requires unloaded and cased firearms in vehicles. Check your specific GMU for any firearm restrictions.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🎫</div><div><div>Hunting license + tag — physical copy in your pocket</div><div class="pack-note">Your tag must be immediately validated (signed/punched) at the moment of kill. Digital copies not always accepted in the field.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🔴</div><div><div>Hunter orange or fluorescent pink hat + vest</div><div class="pack-note">Minimum 400 sq. inches above the waist during modern firearm season. Required by WA law — no exceptions.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🔧</div><div><div>Cleaning rod / bore snake + extra ammunition</div><div class="pack-note">Bring at least 20 rounds. WA does not restrict caliber for most game, but some areas restrict lead ammunition near water.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🧭 NAVIGATION</div>
        <div class="pack-item"><div class="pack-icon">📱</div><div><div>Phone with Gaia GPS or OnX Hunt — downloaded offline</div><div class="pack-note">Cell service is absent in most WA hunting areas. Download maps before leaving home. Know public land boundaries.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🗺️</div><div><div>Paper topo map of your area (backup)</div><div class="pack-note">Phones die. Paper doesn't. Get a free PDF from CalTopo.com for your specific area.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🧭</div><div><div>Compass</div><div class="pack-note">Know how to use it with your topo map. A basic skill that can save your life.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🌧️ CLOTHING (WA SPECIFIC)</div>
        <div class="pack-item"><div class="pack-icon">🧥</div><div><div>Waterproof rain jacket + rain pants</div><div class="pack-note">Western WA: bring these always. Eastern WA: bring them anyway. WA weather is unpredictable year-round.</div></div></div>
        <div class="pack-item"><div class="pack-icon">👢</div><div><div>Waterproof boots — rubber or Gore-Tex</div><div class="pack-note">Rubber boots are preferred in western WA — they're waterproof and reduce scent. Insulated if hunting late October+.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🧤</div><div><div>Warm base layer + mid layer (fleece)</div><div class="pack-note">WA fall mornings can be 25–35°F even in October. Fleece is quiet; nylon is not. Quiet matters for big game.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🧢</div><div><div>Hunter orange hat + warm beanie underneath</div><div class="pack-note">You lose 30% of body heat through your head. A beanie under your orange hat is an easy win.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🍎 FOOD & WATER</div>
        <div class="pack-item"><div class="pack-icon">💧</div><div><div>2–3 liters of water</div><div class="pack-note">Dehydration causes poor decisions. WA streams look clean but carry Giardia — always filter or bring your own.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🥜</div><div><div>High-calorie snacks for a full day</div><div class="pack-note">2,000–3,000 calories if you're hiking hard. Jerky, nuts, energy bars, sandwiches. Eat before you get hungry.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🩹 SAFETY & EMERGENCY</div>
        <div class="pack-item"><div class="pack-icon">🩹</div><div><div>First aid kit — see full list below</div><div class="pack-note">Build your own using the Hunter Education recommended kit list. See the 🏥 First Aid Kit tab for the complete checklist.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🔦</div><div><div>Headlamp + extra batteries</div><div class="pack-note">You will be hiking in the dark — either before dawn or packing out after a late kill. Always have this.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🔥</div><div><div>Fire starter (lighter + waterproof matches + ferro rod)</div><div class="pack-note">WA wilderness can get you into trouble fast. Fire = warmth and signal. Carry two methods.</div></div></div>
        <div class="pack-item"><div class="pack-icon">📡</div><div><div>Satellite communicator (Garmin inReach or SPOT)</div><div class="pack-note">Highly recommended for WA hunting. Many hunting areas have zero cell coverage and can be hours from the nearest town.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🆘</div><div><div>Emergency whistle + space blanket</div><div class="pack-note">If you get lost or injured, a whistle carries farther than your voice. A space blanket weighs 2 oz and can prevent hypothermia.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🔪 HARVEST GEAR (IF SUCCESSFUL)</div>
        <div class="pack-item"><div class="pack-icon">🔪</div><div><div>Sharp hunting knife + sharpener</div><div class="pack-note">A dull knife is dangerous and makes field dressing a miserable experience. Sharpen before you go.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🧤</div><div><div>Latex / nitrile gloves (2–3 pairs)</div><div class="pack-note">For field dressing. Also prevents scent transfer while handling carcass. Required mindset for CWD safety.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🎒</div><div><div>Game bags (at least 4)</div><div class="pack-note">WA requires you to keep meat clean and cool. Breathable game bags protect quarters from flies and dirt.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🪢</div><div><div>50 ft of paracord</div><div class="pack-note">For hanging meat, dragging game, hanging a bear bag, or a dozen other field uses.</div></div></div>
        <div class="pack-item"><div class="pack-icon">📸</div><div><div>Camera / phone for harvest photos</div><div class="pack-note">WA requires photo documentation for some special permit harvests. Also: you'll want the memories.</div></div></div>
      </div>
      <div class="pack-warn">⚠️ <strong style="color:#e08080">WA Law:</strong> You must keep ALL edible meat from any big game animal — wanton waste of meat is illegal in Washington and can result in license revocation and significant fines.</div>
    </div>
    <!-- MULTI-DAY HUNT -->
    <div id="pack-multi" style="display:none;padding:14px 14px 80px">
      <div style="background:rgba(180,140,60,.07);border:1px solid rgba(180,140,60,.2);border-radius:10px;padding:12px 14px;margin-bottom:16px;font-size:13px;color:#9a8a6a;line-height:1.6">
        <strong style="color:#b48c3c">Multi-Day Hunt</strong> — 2–7 nights in WA backcountry. Assumes camp is your base. Everything from the Day Hunt list PLUS the additions below.
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🏕️ SHELTER & SLEEP</div>
        <div class="pack-item"><div class="pack-icon">⛺</div><div><div>4-season tent or quality hunting shelter</div><div class="pack-note">WA mountains can get snow in September. A 3-season tent is risky in October+. Worth investing in a true 4-season.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🛏️</div><div><div>Sleeping bag rated to 20°F or lower</div><div class="pack-note">WA high country at night in October can hit 15–20°F. Don't underestimate it. A 0°F bag is not overkill.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🧸</div><div><div>Sleeping pad (insulated)</div><div class="pack-note">Ground sucks heat. An insulated pad is as important as your sleeping bag. R-value of 4+ recommended for WA fall.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🪣</div><div><div>Tarp or extra rain fly</div><div class="pack-note">For covering your meat cache, creating a gear shelter, or rain prep over your tent. WA is wet.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🍳 FOOD & COOKING</div>
        <div class="pack-item"><div class="pack-icon">🍲</div><div><div>Backpacking stove + fuel canisters</div><div class="pack-note">Bring 1 canister per 2 days of cooking. Hot food is a massive morale boost and helps maintain body temperature.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🥘</div><div><div>3,000–4,000 calories per day of food</div><div class="pack-note">Freeze-dried meals, oatmeal, jerky, hard cheese, nuts, chocolate. Hard hunting days burn 4,000+ calories.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🫙</div><div><div>Bear canister or bear hang system</div><div class="pack-note">Black bears are common across WA. Required in some wilderness areas. Protect your food AND your meat from bears.</div></div></div>
        <div class="pack-item"><div class="pack-icon">💧</div><div><div>Water filter (Sawyer Squeeze or similar) + 4L capacity</div><div class="pack-note">You'll drink 4–6 liters per day while hunting hard. A good filter is lighter than carrying water. Giardia is real in WA.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🎒 PACK & CARRY SYSTEM</div>
        <div class="pack-item"><div class="pack-icon">🎒</div><div><div>60–80L backpack with frame</div><div class="pack-note">You need a frame to carry meat quarters out. A frameless pack makes a 60-lb deer quarter torture. Get a frame.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🛡️</div><div><div>Pack cover or dry bags inside pack</div><div class="pack-note">WA weather will soak your pack. A pack cover + keeping critical items in dry bags is your insurance.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🪓</div><div><div>Lightweight packable meat saw</div><div class="pack-note">For quartering elk or larger game in the field. A folding bone saw weighs 4 oz and is essential for elk hunters.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🌡️ EXTRA CLOTHING</div>
        <div class="pack-item"><div class="pack-icon">👕</div><div><div>2 extra base layer shirts + 1 extra pair socks per day</div><div class="pack-note">Wet base layers cause hypothermia. Merino wool is best — it stays warm even when wet and resists odor.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🧥</div><div><div>Insulated puffy jacket (down or synthetic)</div><div class="pack-note">For camp and cold glassing sessions. Down is lighter; synthetic works when wet. Keep it dry in a stuff sack.</div></div></div>
        <div class="pack-item"><div class="pack-icon">👖</div><div><div>Gaiters</div><div class="pack-note">Essential in wet WA conditions — keeps water, snow, and debris out of your boots. Lightweight ones work fine.</div></div></div>
      </div>
      <div class="pack-section">
        <div class="pack-section-title">🩺 EXTENDED SAFETY</div>
        <div class="pack-item"><div class="pack-icon">💊</div><div><div>Extended first aid kit + blister treatment</div><div class="pack-note">Add: SAM splint, Israeli bandage, antibiotic ointment, Benadryl, moleskin for blisters. Blisters end hunts.</div></div></div>
        <div class="pack-item"><div class="pack-icon">📡</div><div><div>Satellite communicator — MANDATORY for multi-day</div><div class="pack-note">A Garmin inReach Mini is $35/month. If you break a leg 10 miles from a road, this is the difference between life and death.</div></div></div>
        <div class="pack-item"><div class="pack-icon">📋</div><div><div>Leave a detailed trip plan with someone at home</div><div class="pack-note">Include: exact location, trailhead GPS, expected return date, who to call if you don't check in. WA Search & Rescue needs this.</div></div></div>
        <div class="pack-item"><div class="pack-icon">🐻</div><div><div>Bear spray</div><div class="pack-note">Black bears are widespread in WA. Grizzlies are present in the North Cascades. Bear spray is effective and worth carrying.</div></div></div>
      </div>
      <div class="pack-warn">⚠️ <strong style="color:#e08080">Meat Care:</strong> In WA, you must keep harvested meat from spoiling. Bone-in quarters must be kept below 40°F. In warm early-season hunting, get meat to a cooler within 24 hours or it will spoil. Wanton waste is a criminal offense in WA.</div>
    </div>

    <!-- FIRST AID KIT -->
    <div id="pack-firstaid" style="display:none;padding:14px 14px 80px">
      <div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:10px;padding:12px 14px;margin-bottom:16px;font-size:13px;color:#fca5a5;line-height:1.6">
        <strong style="color:#ef4444">🏥 Hunter Education First Aid Kit</strong> — This is the official suggested kit list from Hunter-Ed.com. Tap each item to check it off as you pack. Build this kit and carry it on every hunt.
      </div>

      <div id="fak-progress-wrap" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:12px 14px;margin-bottom:16px;text-align:center">
        <div style="font-size:11px;letter-spacing:2px;color:#b48c3c;margin-bottom:6px">KIT PROGRESS</div>
        <div style="background:rgba(255,255,255,.08);border-radius:20px;height:8px;overflow:hidden;margin-bottom:6px">
          <div id="fak-bar" style="height:100%;background:linear-gradient(90deg,#4ade80,#22c55e);border-radius:20px;width:0%;transition:width .3s"></div>
        </div>
        <div id="fak-count" style="font-size:13px;color:#9aaa8a">0 of 26 items packed</div>
        <button onclick="resetFAK()" style="background:none;border:none;color:#6a7a60;font-size:11px;margin-top:4px;font-family:inherit;cursor:pointer">↺ Reset checklist</button>
      </div>

      <div class="pack-section">
        <div class="pack-section-title">🩹 WOUND CARE & DRESSINGS</div>
        <div class="fak-item" id="fak-0" onclick="toggleFAK(0)"><div class="fak-check" id="fakcheck-0">○</div><div class="fak-text"><div class="fak-name">2-inch-square sterile gauze pads</div><div class="fak-note">For covering and cleaning wounds. Use multiple layers on deep cuts.</div></div></div>
        <div class="fak-item" id="fak-1" onclick="toggleFAK(1)"><div class="fak-check" id="fakcheck-1">○</div><div class="fak-text"><div class="fak-name">4-inch-square sterile gauze pads</div><div class="fak-note">Larger wounds or packing deep cuts. Always carry both sizes.</div></div></div>
        <div class="fak-item" id="fak-2" onclick="toggleFAK(2)"><div class="fak-check" id="fakcheck-2">○</div><div class="fak-text"><div class="fak-name">2-inch-wide gauze bandage roll</div><div class="fak-note">For wrapping wounds after gauze pads are applied. Flexible and conforming.</div></div></div>
        <div class="fak-item" id="fak-3" onclick="toggleFAK(3)"><div class="fak-check" id="fakcheck-3">○</div><div class="fak-text"><div class="fak-name">42-inch-square cloth (triangular bandage / sling)</div><div class="fak-note">Can be used as a sling for arm/shoulder injuries, tourniquet, or securing splints.</div></div></div>
        <div class="fak-item" id="fak-4" onclick="toggleFAK(4)"><div class="fak-check" id="fakcheck-4">○</div><div class="fak-text"><div class="fak-name">Assorted adhesive dressings (Band-Aids)</div><div class="fak-note">Multiple sizes for small cuts and abrasions. Include knuckle and fingertip styles.</div></div></div>
        <div class="fak-item" id="fak-5" onclick="toggleFAK(5)"><div class="fak-check" id="fakcheck-5">○</div><div class="fak-text"><div class="fak-name">Assorted butterfly dressings</div><div class="fak-note">For closing wound edges on cuts that don't need stitches. Essential for field laceration care.</div></div></div>
        <div class="fak-item" id="fak-6" onclick="toggleFAK(6)"><div class="fak-check" id="fakcheck-6">○</div><div class="fak-text"><div class="fak-name">Roll of 1-inch adhesive tape</div><div class="fak-note">For securing gauze and dressings. Also useful for blister prevention on known hot spots.</div></div></div>
        <div class="fak-item" id="fak-7" onclick="toggleFAK(7)"><div class="fak-check" id="fakcheck-7">○</div><div class="fak-text"><div class="fak-name">Roll of 2-inch adhesive tape</div><div class="fak-note">Wider tape for larger dressings and securing splints or wraps to limbs.</div></div></div>
        <div class="fak-item" id="fak-8" onclick="toggleFAK(8)"><div class="fak-check" id="fakcheck-8">○</div><div class="fak-text"><div class="fak-name">Moleskin</div><div class="fak-note">A hunter's best friend — prevents and treats blisters from long days on rough terrain. Cut to fit over hot spots before they blister.</div></div></div>
        <div class="fak-item" id="fak-9" onclick="toggleFAK(9)"><div class="fak-check" id="fakcheck-9">○</div><div class="fak-text"><div class="fak-name">Safety pins (assorted)</div><div class="fak-note">For securing triangular bandages, closing slings, and improvising splint wraps.</div></div></div>
      </div>

      <div class="pack-section">
        <div class="pack-section-title">💊 MEDICATIONS & TOPICALS</div>
        <div class="fak-item" id="fak-10" onclick="toggleFAK(10)"><div class="fak-check" id="fakcheck-10">○</div><div class="fak-text"><div class="fak-name">Aspirin</div><div class="fak-note">Pain relief and anti-inflammatory. Also critically important if someone shows signs of a heart attack — chew immediately.</div></div></div>
        <div class="fak-item" id="fak-11" onclick="toggleFAK(11)"><div class="fak-check" id="fakcheck-11">○</div><div class="fak-text"><div class="fak-name">Antacid</div><div class="fak-note">For indigestion and stomach upset from unfamiliar camp food or altitude changes.</div></div></div>
        <div class="fak-item" id="fak-12" onclick="toggleFAK(12)"><div class="fak-check" id="fakcheck-12">○</div><div class="fak-text"><div class="fak-name">Decongestant</div><div class="fak-note">Cold and sinus symptoms are common in WA's wet fall weather. Don't let a stuffy head ruin your hunt.</div></div></div>
        <div class="fak-item" id="fak-13" onclick="toggleFAK(13)"><div class="fak-check" id="fakcheck-13">○</div><div class="fak-text"><div class="fak-name">Antibiotic salve (Neosporin)</div><div class="fak-note">Apply to cuts and abrasions after cleaning. Reduces infection risk significantly — especially important in the dirty field environment.</div></div></div>
        <div class="fak-item" id="fak-14" onclick="toggleFAK(14)"><div class="fak-check" id="fakcheck-14">○</div><div class="fak-text"><div class="fak-name">½% Hydrocortisone cream</div><div class="fak-note">Relieves itching from insect bites, plant contact (stinging nettle is common in WA), and minor rashes.</div></div></div>
        <div class="fak-item" id="fak-15" onclick="toggleFAK(15)"><div class="fak-check" id="fakcheck-15">○</div><div class="fak-text"><div class="fak-name">Petroleum jelly (Vaseline)</div><div class="fak-note">Lubricates chafed skin, seals small wounds, and helps start fires in wet conditions. Multi-use field essential.</div></div></div>
      </div>

      <div class="pack-section">
        <div class="pack-section-title">🧰 TOOLS & EQUIPMENT</div>
        <div class="fak-item" id="fak-16" onclick="toggleFAK(16)"><div class="fak-check" id="fakcheck-16">○</div><div class="fak-text"><div class="fak-name">Scissors</div><div class="fak-note">For cutting tape, bandages, and clothing away from wounds. Trauma shears are ideal.</div></div></div>
        <div class="fak-item" id="fak-17" onclick="toggleFAK(17)"><div class="fak-check" id="fakcheck-17">○</div><div class="fak-text"><div class="fak-name">Needles</div><div class="fak-note">For draining blisters (sterilize first with flame or alcohol). Can also remove splinters.</div></div></div>
        <div class="fak-item" id="fak-18" onclick="toggleFAK(18)"><div class="fak-check" id="fakcheck-18">○</div><div class="fak-text"><div class="fak-name">Single-edged razor blade</div><div class="fak-note">Precision cutting of tape or clothing. Sharper than scissors for delicate wound edge work.</div></div></div>
        <div class="fak-item" id="fak-19" onclick="toggleFAK(19)"><div class="fak-check" id="fakcheck-19">○</div><div class="fak-text"><div class="fak-name">Eye dropper</div><div class="fak-note">For flushing debris from eyes. WA forests have plenty of dust, bark, and insects that can get in eyes on a hike.</div></div></div>
        <div class="fak-item" id="fak-20" onclick="toggleFAK(20)"><div class="fak-check" id="fakcheck-20">○</div><div class="fak-text"><div class="fak-name">Latex / nitrile gloves</div><div class="fak-note">Protect you while treating others' wounds. Also essential for field dressing game — especially for CWD precaution.</div></div></div>
        <div class="fak-item" id="fak-21" onclick="toggleFAK(21)"><div class="fak-check" id="fakcheck-21">○</div><div class="fak-text"><div class="fak-name">Cotton swabs</div><div class="fak-note">For applying ointment to small wounds and cleaning around injuries without further contamination.</div></div></div>
      </div>

      <div class="pack-section">
        <div class="pack-section-title">🌡️ TEMPERATURE MANAGEMENT</div>
        <div class="fak-item" id="fak-22" onclick="toggleFAK(22)"><div class="fak-check" id="fakcheck-22">○</div><div class="fak-text"><div class="fak-name">Instant chemical cold packs</div><div class="fak-note">For sprains, swelling, and blunt injuries. Squeeze to activate. Essential for ankle and knee injuries on rough WA terrain.</div></div></div>
        <div class="fak-item" id="fak-23" onclick="toggleFAK(23)"><div class="fak-check" id="fakcheck-23">○</div><div class="fak-text"><div class="fak-name">Instant chemical hot packs</div><div class="fak-note">For hypothermia treatment and muscle stiffness in cold WA conditions. Place in armpits or groin for core warming.</div></div></div>
      </div>

      <div class="pack-section">
        <div class="pack-section-title">🧼 HYGIENE & SANITATION</div>
        <div class="fak-item" id="fak-24" onclick="toggleFAK(24)"><div class="fak-check" id="fakcheck-24">○</div><div class="fak-text"><div class="fak-name">Hand sanitizer</div><div class="fak-note">Before treating wounds and after field dressing game. Clean hands dramatically reduce infection risk in the field.</div></div></div>
        <div class="fak-item" id="fak-25" onclick="toggleFAK(25)"><div class="fak-check" id="fakcheck-25">○</div><div class="fak-text"><div class="fak-name">Cell phone</div><div class="fak-note">Your most important emergency tool. Keep it charged and in a waterproof case. Download offline maps before entering areas without cell service.</div></div></div>
      </div>

      <div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:10px;padding:13px 14px;margin-top:4px;font-size:12px;color:#fca5a5;line-height:1.6">
        <strong style="color:#ef4444">⚠️ Additional Recommendations for WA Hunting:</strong><br>
        Also consider adding: a tourniquet (CAT or SOFTT-W), a chest seal for firearm accidents, a SAM splint for fractures, a whistle for signaling, and a Garmin inReach or SPOT satellite communicator. WA hunting areas are remote — you may be hours from cell service and EMS.
      </div>

      <div style="margin-top:14px;background:rgba(30,50,80,.4);border:1px solid rgba(80,120,180,.25);border-radius:10px;padding:12px 14px">
        <div style="font-size:11px;font-weight:700;color:#80aaee;margin-bottom:6px">📚 Source</div>
        <div style="font-size:12px;color:#9aaabe;line-height:1.5">This kit list is based on the official suggested contents from Hunter-Ed.com — the nationally recognized Hunter Education course. Take the free online course at <span style="color:#80aaee">hunter-ed.com</span> or <span style="color:#80aaee">wdfw.wa.gov</span></div>
      </div>
    </div><!-- end pack-firstaid -->
  </div><!-- end scroll wrapper -->
</div><!-- end screen-pack -->

<!-- ══ FILTER DRAWER ══ -->
<div class="modal-overlay" id="filterOverlay" onclick="closeFilterDrawer(event)" style="z-index:600">
  <div class="modal-sheet" id="filterSheet" style="max-height:85vh">
    <div class="modal-handle"></div>
    <div style="padding:14px 18px 10px;border-bottom:1px solid rgba(255,255,255,.07);display:flex;align-items:center;justify-content:space-between">
      <div>
        <div style="font-size:10px;letter-spacing:2px;color:#b48c3c;margin-bottom:2px">FILTER SPOTS BY ANIMAL</div>
        <div style="font-size:16px;font-weight:700;color:#f0e4c0">Which animals to show?</div>
      </div>
      <button onclick="closeFilterDrawerDirect()" style="background:rgba(255,255,255,.08);border:none;color:#a0a090;border-radius:50%;width:32px;height:32px;font-size:16px;display:flex;align-items:center;justify-content:center">✕</button>
    </div>
    <div style="overflow-y:auto;padding:14px 18px 24px;-webkit-overflow-scrolling:touch">
      <!-- Quick presets -->
      <div style="display:flex;gap:7px;flex-wrap:wrap;margin-bottom:16px">
        <button onclick="filterPreset('deer')" class="preset-btn">🦌 All Deer</button>
        <button onclick="filterPreset('all')" class="preset-btn">✅ All Animals</button>
        <button onclick="filterPreset('none')" class="preset-btn">❌ Clear All</button>
        <button onclick="filterPreset('birds')" class="preset-btn">🐦 All Birds</button>
        <button onclick="filterPreset('beginner')" class="preset-btn">🟢 Beginner Only</button>
      </div>
      <!-- Dynamic groups built by buildFilterDrawer() -->
      <div id="filterDrawerGroups"></div>

      <!-- Difficulty filter -->
      <div class="fd-group-title" style="margin-top:14px">📊 DIFFICULTY LEVEL</div>
      <div class="fd-grid">
        <label class="fd-chip"><input type="checkbox" id="fd-Beginner" checked onchange="applyDiffFilter()"><span>🟢 Beginner</span></label>
        <label class="fd-chip"><input type="checkbox" id="fd-Intermediate" checked onchange="applyDiffFilter()"><span>🟡 Intermediate</span></label>
        <label class="fd-chip"><input type="checkbox" id="fd-Advanced" checked onchange="applyDiffFilter()"><span>🟠 Advanced</span></label>
      </div>
      <button onclick="closeFilterDrawerDirect()" style="width:100%;margin-top:18px;background:rgba(180,140,60,.2);border:1px solid rgba(180,140,60,.4);color:#d4a840;border-radius:10px;padding:13px;font-size:14px;font-weight:700;font-family:inherit">
        ✓ Apply Filter
      </button>
    </div>
  </div>
</div>

<!-- ══ BOTTOM NAV ══ -->
<div class="bnav" id="bottomNav">
  <button class="nb" id="nav-home" onclick="goHome()"><span class="ni">🏠</span>Home</button>
  <button class="nb" id="nav-pack" onclick="showScreen('pack')"><span class="ni">🎒</span>Prepare</button>
  <button class="nb" id="nav-budget" onclick="showScreen('budget')"><span class="ni">💰</span>Cost</button>
  <button class="nb" id="nav-browse" onclick="showScreen('browse')"><span class="ni">🗺️</span>Browse</button>
</div>

