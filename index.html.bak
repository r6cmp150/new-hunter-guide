      </g>
      <!-- Eye — intense amber -->
      <ellipse cx="35" cy="36" rx="3.5" ry="2.8" fill="#c8a020" opacity=".9"/>
      <ellipse cx="35" cy="36" rx="1.8" ry="2.5" fill="#0a0604"/>
      <!-- Whiskers -->
      <g stroke="#8a6020" stroke-width=".7" opacity=".55">
        <line x1="27" y1="42" x2="14" y2="40"/><line x1="27" y1="44" x2="14" y2="46"/>
