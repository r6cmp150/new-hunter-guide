</div><!-- /#app-shell -->

<script>
// ── DEER SPOTS ─────────────────────────────────────────────────────────────
const SPOTS=[
  // BLACK-TAILED DEER
  {id:"olympic",deer:"black-tail",name:"Olympic Wildlife Area",subname:"Anderson Homestead Unit",lat:47.8908,lng:-124.3759,place_id:"ChIJoyYMj417jlQRWV9OUIXMgJs",gmu:"GMUs 621-636",publicLand:true,difficulty:"Beginner",
   summary:"Park along logging roads and walk to clearcut edges at first light. Deer feed in open cuts before retreating to rainforest timber by mid-morning.",
   access:"From Forks: Head south on US-101 onto logging roads toward Anderson Homestead. 4WD recommended when wet.",
   how:{overview:"Classic western WA black-tail setup. Deer live in dense rainforest timber but come out to feed in logged clearcuts. Get to the edge before sunrise.",steps:["Drive logging roads the evening before to find clearcuts with deer tracks in soft dirt.","Park 200 yards from where you plan to hunt. Walk in quietly in the dark.","Set up at the downwind edge of a clearcut 30 min before sunrise. Sit still.","If nothing by 9am, still-hunt slowly along the timber edge.","Return to clearcut edges in the last 2 hours of daylight."],terrain:"Dense rainforest with logged clearcuts. Muddy trails. Dress in waterproof layers.",bestTime:"Opening week of modern firearm season (mid-October). Overcast mornings after rain are best.",gear:["Waterproof rain jacket and pants","Rubber boots","Binoculars","Hunter orange (required)","Gaia GPS offline"],warning:"4WD strongly recommended. Logging roads can be impassable mud. Always tell someone where you are going."}},
  {id:"capitol",deer:"black-tail",name:"Capitol State Forest",subname:"Near Olympia",lat:46.9582,lng:-123.1148,place_id:"ChIJZRRQSy-ckVQRWmYvX4BbDKM",gmu:"GMUs 651-652",publicLand:true,difficulty:"Beginner",
   summary:"Excellent beginner spot 20 minutes from Olympia. Hunt edges where logged clearcuts meet standing timber. Deer follow these boundaries at dawn.",
   access:"From Olympia: Take US-12 west, turn south on Waddell Creek Rd. Multiple trailhead parking areas.",
   how:{overview:"Working timber forest with a patchwork of clearcuts and standing timber. Very accessible road network, great for first-time hunters close to home.",steps:["Download WA DNR Road Viewer app. Find clearcuts 3-8 years old.","Drive main forest roads the evening before and look for deer crossing at dusk.","Arrive at clearcut edge 30-45 min before sunrise. Walk in quietly.","Post up at the junction of clearcut and timber edge. Watch and wait.","Slowly drive forest roads mid-morning looking for deer near road edges."],terrain:"Gentle to moderate hills with gravel roads. Some areas accessible by 2WD on dry days.",bestTime:"Mid-October through early November. Overcast mornings after rain are productive.",gear:["Quiet clothing","Hunter orange (required)","Binoculars","WA DNR Road Viewer app offline","Rubber boots"],warning:"Check the DNR website for road closures before you go. Some roads are gated seasonally."}},
  {id:"willapa-hills",deer:"black-tail",name:"Willapa Hills",subname:"Southwest Washington",lat:46.6664,lng:-123.5015,place_id:"ChIJp8OQKwHHk1QRoh_arfwe3gk",gmu:"GMUs 658-662",publicLand:true,difficulty:"Intermediate",
   summary:"Rolling timber country with high black-tail densities. Focus on creek bottoms connecting clearcuts to timber. Less pressure than forests near Seattle.",
   access:"From Chehalis: Head west on SR-6. Numerous DNR roads provide access.",
   how:{overview:"Vast second-growth timber in SW Washington. Strong deer populations, lower hunting pressure than near Seattle. Classic timber-country hunting.",steps:["Use WA DNR Road Viewer or OnX Hunt. Look for clearcuts 2-10 years old.","Focus on creek bottoms connecting clearcuts to timber.","Set up before first light at the downwind end of a clearcut.","Still-hunt slowly along old skid roads and timber edges mid-morning.","Scout for rubs and scrapes during the rut in late October."],terrain:"Rolling hills, muddy logging roads, dense second-growth. 4WD recommended.",bestTime:"Late October through November when the rut begins.",gear:["Waterproof rubber boots","Rain gear","Hunter orange (required)","OnX Hunt or topo map","Binoculars"],warning:"Cell service is very limited. Download maps offline before leaving home."}},
  // MULE DEER
  {id:"sinlahekin",deer:"mule-deer",name:"Sinlahekin Wildlife Area",subname:"Okanogan County",lat:48.6289,lng:-119.6880,place_id:"ChIJDdPHo9PTnFQRRqUm89U2VYQ",gmu:"GMU 108",publicLand:true,difficulty:"Beginner",
   summary:"Glass the open valley slopes with binoculars from the road then make a careful stalk on feeding bucks. One of the top mule deer valleys in Washington.",
   access:"From Tonasket: US-97 north, west on Loomis-Oroville Rd, south on Sinlahekin Creek Rd. Paved to gravel.",
   how:{overview:"Long narrow valley with open grassy slopes. Perfect spot-and-stalk mule deer country. GMU 108 is one of the top-producing units in the state.",steps:["Drive Sinlahekin Creek Rd slowly at first light glassing both slopes.","When you spot a deer watch its direction before moving.","Plan your stalk keeping the wind in your face using terrain for cover.","Move very slowly and freeze if the deer looks up.","By 9-10am deer bed in pine timber. Walk slowly through pines stopping often."],terrain:"Open grassy slopes with scattered pines. Valley floor has creek and willows.",bestTime:"Opening week of modern firearm season. Mornings best for spotting deer in the open.",gear:["Quality binoculars - essential","Quiet earthy-colored clothing","Hunter orange (required)","Layers","Water and snacks"],warning:"GMU 108 has excellent harvest rates. Check current regulations for antler restrictions before you go."}},
  {id:"okanogan",deer:"mule-deer",name:"Okanogan Valley Area",subname:"Tonasket - GMU 105",lat:48.6666,lng:-119.5033,place_id:"ChIJPRueGV7XnFQRyWDBGynPyoo",gmu:"GMU 105",publicLand:false,difficulty:"Intermediate",
   summary:"Open pine forest ideal for driving roads at first light to spot deer then stalking in on foot. Consistently one of the top-producing GMUs in Washington.",
   access:"From Tonasket: Head north on US-97 then follow Pine Creek Rd west. Mix of public and private land - use OnX Hunt.",
   how:{overview:"GMU 105 consistently produces some of the highest mule deer harvests in Washington. Open ponderosa pine forest - deer are numerous and relatively visible.",steps:["Download OnX Hunt loaded with GMU 105 - shows public vs private land live. Essential here.","Drive forest roads slowly at first light. When you spot deer park and approach on foot.","Focus on edges where pine forest meets open grassy areas.","Still-hunt through scattered timber walking slowly and stopping every few steps.","In late October-November look for rutting bucks exposing themselves in daylight."],terrain:"Gently rolling open pine forest. Generally dry. Some areas accessible by 2WD.",bestTime:"Mid-October through early November. The rut (late October) is most exciting.",gear:["OnX Hunt with GMU 105 loaded","Binoculars","Hunter orange (required)","Good walking boots","Warm layers"],warning:"Respect private land boundaries strictly - trespassing costs you your hunting license."}},
  {id:"umatilla-for",deer:"mule-deer",name:"Umatilla National Forest",subname:"Blue Mountains SE Washington",lat:46.30,lng:-117.90,place_id:"ChIJuzjzPosCo1QRAbus3O4Sp9U",gmu:"GMUs 145-149",publicLand:true,difficulty:"Intermediate",
   summary:"Ridge-and-draw country in the Blue Mountains. Hike to a ridge top before dawn glass the slopes below then stalk in on deer you locate from above.",
   access:"From Dayton: Head south on US-12 into the forest. Download Avenza Maps or Gaia GPS before you go - no cell service.",
   how:{overview:"The Blue Mountains offer both mule deer and whitetail. Deer feed on open ridge-tops and south-facing slopes then bed in timbered draws.",steps:["Get to a ridge top before first light. Glass opposite ridge faces and open parks.","Work along ridges slowly glassing into draws below.","When you see a deer move along the back side of the ridge to stay hidden.","Midday walk creek bottoms slowly. Deer bed nearby.","Late afternoon return to ridge tops as deer move again."],terrain:"Steep ridges and deep draws. Physically demanding. Forest Service roads access the high country.",bestTime:"Mid-October through November. Snow concentrates deer and makes tracking easier.",gear:["Good hiking boots with ankle support","Layered clothing","Binoculars (essential)","Downloaded topo maps","Hunter orange (required)"],warning:"Snow can close higher Forest Service roads quickly. Check with Umatilla NF office (541-278-3716) before heading up."}},
  // WHITETAIL
  {id:"little-pend",deer:"whitetail",name:"Little Pend Oreille NWR",subname:"Colville Stevens County",lat:48.4614,lng:-117.7321,place_id:"ChIJTy27ZVtmYlMREECqwv6Kmh8",gmu:"GMU 117",publicLand:true,difficulty:"Intermediate",
   summary:"Patience wins here. Find a heavily-used trail intersection near water set up a stand before dawn and wait motionlessly. Scent control is everything.",
   access:"From Colville: Take SR-20 east turn north on Bear Creek Rd. Open 24 hours good gravel roads.",
   how:{overview:"Heart of NE WA whitetail country. Dense timber near Idaho border. Whitetail hunting is a waiting game - success depends on scent control patience and picking the right spot.",steps:["Scout before season - look for heavily used deer trails rubs on trees and scrapes.","Set up a tree stand or ground blind near a trail intersection. Wind direction is critical.","Arrive 45-60 minutes before first light. Spray boots with scent eliminator.","Sit absolutely still. Whitetails will come to you if you are scent-free and quiet.","Peak activity is first and last hour of daylight. During rut bucks also move midday."],terrain:"Dense mixed timber with some open areas. Relatively flat with good gravel road access.",bestTime:"The rut - late October through mid-November. Best chance at a mature buck in daylight.",gear:["Scent-eliminating spray (essential)","Quiet fleece clothing","Portable tree stand or ground blind","Hunter orange (required)","Hand warmers"],warning:"Whitetail hunting has a steep learning curve. Many experienced hunters sit 5-10 times before seeing the right deer."}},
  {id:"colville",deer:"whitetail",name:"Colville National Forest",subname:"Stevens and Pend Oreille Counties",lat:48.6354,lng:-117.6328,place_id:"ChIJOdbxAUSGYlMRY9wapV66VhE",gmu:"GMUs 117-124",publicLand:true,difficulty:"Intermediate",
   summary:"Find the creek bottoms and timbered draws connecting forest to private farm fields - these are the corridors whitetails walk every single morning and evening.",
   access:"From Colville: Forest HQ on S Main St. Extensive forest road network - download Avenza Maps or Gaia GPS before you go.",
   how:{overview:"Colville National Forest has high whitetail numbers in the eastern units. Creek bottoms and river drainages are the highways whitetails use to travel between feeding and bedding.",steps:["Use OnX Hunt to find public land bordering private agricultural areas - that boundary is prime whitetail territory.","Find creek bottoms and timbered draws connecting public forest to ag areas.","Set up a stand where these corridors funnel through a pinch point before first light.","Scent control is critical - approach from downwind. Spray boots with scent killer.","During the rut add a grunt call or rattling antlers - this can pull bucks in from surprising distances."],terrain:"Varied - dense creek-bottom timber to open ridge-top forest. Lower elevation units most productive.",bestTime:"November - rut in full swing. Cold snaps after warm spells dramatically increase deer movement.",gear:["Scent control spray and sealed clothing bag","Grunt call or rattling antlers for rut","Tree stand or ground blind","Hunter orange (required)","OnX Hunt for land boundaries"],warning:"Wolf packs are established in NE Washington. Do not leave harvested game unattended for extended periods."}},
  // TURKEY
  {id:"yakima-turkey",deer:"turkey",name:"Wenas Wildlife Area",subname:"Yakima County - Top Turkey County in WA",lat:46.9189,lng:-120.5906,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 340",publicLand:true,difficulty:"Intermediate",
   summary:"Yakima County averages more wild turkeys than any other WA county. Glass oak-covered ridges at dawn for gobbling toms then call them in from their roost trees.",
   access:"From Selah: Head north on Wenas Rd into the Wenas Valley. Multiple wildlife area parking pullouts along the road.",
   how:{overview:"The Wenas area sits in WA's best turkey country. Turkeys roost in ponderosa pines and oaks on the slopes feeding in open areas below at dawn.",steps:["Scout the evening before - listen for gobbling at roost time 30 min before dark.","Set up 100-150 yards from the roost tree before first light. Get there early.","When the gobbler flies down begin calling softly with yelps on a mouth call or slate call.","If he gobbles back but will not come in try a hen decoy set at 20 yards.","For fall season scatter a flock then sit where they scattered and call - birds come back to regroup."],terrain:"Rolling hills oak and pine timber open meadows. Moderate hiking. Mostly accessible by vehicle.",bestTime:"Spring season April 15 - May 31. First week is best when toms are actively gobbling.",gear:["Mouth call or slate call and striker","Hen decoy","Full camo - no orange required for turkey","Shotgun with extra-full choke and turkey loads","Comfortable seat cushion"],warning:"Yakima County is renowned for its turkey population. Obtain permission on any private land bordering wildlife area boundaries."}},
  {id:"colville-turkey",deer:"turkey",name:"Colville National Forest",subname:"NE Washington - Merriam's Turkey",lat:48.5500,lng:-117.8000,place_id:"ChIJOdbxAUSGYlMRY9wapV66VhE",gmu:"GMUs 117-124",publicLand:true,difficulty:"Intermediate",
   summary:"Northeast Washington has excellent Merriam's turkey populations in the ponderosa pine forest. Hunt the pine-to-meadow edges in the morning as toms strut after flying down from roost.",
   access:"From Colville: Forest HQ on S Main St. Use Forest Service roads to access timbered ridges with open meadows below. Download Gaia GPS offline.",
   how:{overview:"Merriam's turkeys inhabit the ponderosa pine and mixed forests of NE Washington. They use open ridge parks and meadow edges for strutting and feeding roosting in pines overnight.",steps:["Drive forest roads at dusk listening for gobbling at roost time.","Set up 100-150 yards from roosting area before first light.","Call softly as light fills in - clucks and yelps to start.","Patience is key - toms in NE WA can take 30-60 minutes to work to a call.","If hunting fall scatter a flock and sit in the scatter area calling kee-kee runs."],terrain:"Timbered pines with grassy parks and meadow edges. Moderate terrain. Good forest road access.",bestTime:"Spring - April 15 through May 31. Early morning in the first 2 weeks of season.",gear:["Mouth call plus box call or slate call","Camo head to toe - no orange required for turkey","Shotgun with full choke and premium turkey shells","Decoys optional but effective","Bug spray"],warning:"Turkey and deer seasons can overlap in fall - wear hunter orange if any modern firearm deer season is open in your GMU."}},
  // PHEASANT
  {id:"columbia-basin-pheasant",deer:"pheasant",name:"Columbia Basin Wildlife Area",subname:"Grant County - Best Pheasant in WA",lat:47.1068,lng:-119.2687,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",
   summary:"Washington's top public pheasant destination. Over 192,000 acres with excellent pheasant quail and Hungarian partridge. WDFW releases birds here regularly.",
   access:"From Moses Lake: Head west on SR-170 or SR-28. Multiple unit access points throughout Grant County - download WDFW Columbia Basin Wildlife Area map.",
   how:{overview:"The Columbia Basin Wildlife Area is WA's premier public pheasant hunting area. WDFW releases thousands of pheasants here annually. Excellent habitat mix of CRP grass cattail marshes and crop fields.",steps:["Scout a unit the day before - look for rooster tracks in sandy road edges.","Hunt field edges and CRP grass strips in the morning when birds are moving.","With a dog work into the wind. Without a dog walk grid patterns through cover.","Kick through any brushy draw or cattail patch - roosters hold tight and flush explosively.","Hunt sunny south-facing slopes in the afternoon when birds loaf."],terrain:"Flat to gently rolling. Mix of open grassland crop fields cattail draws. Easy walking.",bestTime:"Late October through November after WDFW bird releases.",gear:["Blaze orange hat and vest (required)","Upland hunting boots","12 or 20 gauge with #5 or #6 shot","Hunting dog is a major advantage","Lots of water"],warning:"Grant County leads WA in both duck and upland bird production. Check which units are currently open and if pheasant releases have occurred at wdfw.wa.gov."}},
  {id:"whitman-pheasant",deer:"pheasant",name:"Palouse - Whitman County",subname:"SE Washington - Wild Pheasant",lat:46.7298,lng:-117.4826,place_id:"ChIJu7pC0K7zqFQREE6nBKMBhLo",gmu:"Whitman County",publicLand:false,difficulty:"Intermediate",
   summary:"The Palouse wheat country of Whitman County is legendary for wild pheasant. Hunt CRP strips and grassy draws between wheat fields. Rooster numbers here are consistently excellent.",
   access:"From Pullman: Explore agricultural roads and CRP strips west and north of town. Much is private - knock on doors and ask permission. Public access along Palouse River corridor.",
   how:{overview:"Whitman County's Palouse region is consistently ranked as one of WA's best wild pheasant areas. Rolling wheat hills with CRP grass corridors create ideal habitat.",steps:["Scout crop fields and CRP strips on a mapping app before your trip.","Knock on farmhouse doors and ask permission - most WA farmers are receptive.","Hunt CRP strips from one end to the other walking into the wind.","Roosters run ahead - push toward a natural barrier to force them to flush.","Mid-morning birds move to loafing cover (tall grass brush) - hunt these areas."],terrain:"Rolling Palouse hills. Mostly private agricultural land. Permission required for best areas.",bestTime:"October through December. Early season birds are less wary but November is peak.",gear:["Upland vest with blaze orange","Light boots","12 or 20 gauge with #5 shot","Dog is extremely helpful on wild birds","Water for you and your dog"],warning:"Most Palouse pheasant hunting is on private land. Always get permission before entering any field. Use OnX Hunt to identify public land pockets."}},
  // GROUSE
  {id:"okanogan-grouse",deer:"grouse",name:"Okanogan Highlands",subname:"Okanogan County - #1 Grouse County",lat:48.7500,lng:-119.2000,place_id:"ChIJPRueGV7XnFQRyWDBGynPyoo",gmu:"GMUs 101-108",publicLand:true,difficulty:"Beginner",
   summary:"Okanogan County leads the state in grouse harvest every year averaging 14600 birds. Walk forest service roads and timber edges - blue grouse hold tight in conifers and often sit in trees.",
   access:"From Tonasket or Oroville: Explore any Forest Service road into the higher elevation pine and fir forest. DNR and USFS lands are extensive throughout the county.",
   how:{overview:"Okanogan County averages 14600 grouse per year - more than any other WA county. Blue grouse live in higher elevation conifer forests and ruffed grouse in lower mixed timber.",steps:["Drive forest roads slowly at first light - grouse often stand on roadsides warming in the morning sun.","Walk logging roads and timber edges listening for wing beats in the trees above.","Blue grouse often sit tight in conifers - look up as they frequently watch you from branches.","With a dog work through dense timber and creek bottoms for ruffed grouse.","Shoot quickly on flush - grouse disappear into timber in seconds."],terrain:"Timbered hillsides and forest roads. Easy to moderate walking.",bestTime:"September through November. Blue grouse are most accessible in September.",gear:[".22 rifle or 20 gauge shotgun with #7.5 or #8 shot","Day pack with water","Good walking boots","No hunter orange required unless deer or elk firearm seasons are open","Gaia GPS"],warning:"Okanogan County also has excellent deer and bear hunting - during firearm deer or elk seasons wear hunter orange even when grouse hunting."}},
  {id:"stevens-grouse",deer:"grouse",name:"Stevens County Timberlands",subname:"NE Washington - Ruffed Grouse",lat:48.2500,lng:-117.5000,place_id:"ChIJTy27ZVtmYlMREECqwv6Kmh8",gmu:"GMUs 117-121",publicLand:true,difficulty:"Beginner",
   summary:"Stevens County is WA's second-best grouse county averaging 13300 birds per year. Walk alder and aspen creek bottoms for ruffed grouse. They explode from the brush with a thunderous flush.",
   access:"From Colville or Chewelah: Any county road leading into the mixed timber and creek drainages. DNR and Colville National Forest lands are widely accessible.",
   how:{overview:"Stevens County averages 13300 grouse per year. Creek drainages and mixed alder-aspen timber hold ruffed grouse while higher pine country holds blue grouse.",steps:["Walk creek bottoms lined with alder aspen and willow - prime ruffed grouse habitat.","Move slowly and quietly stopping every 10-15 yards to listen for feeding birds.","A flushing dog is very helpful - ruffed grouse hold tight until nearly stepped on.","Look for dusting spots and tracks as signs of bird activity.","Blue grouse: walk the higher pine ridges and look for birds sunning on rocks or roads."],terrain:"Creek drainages and timber. Mostly easy walking with some steeper hillsides.",bestTime:"September through January. Best in October when leaves are down.",gear:["20 or 28 gauge shotgun with #7.5 shot","Flushing dog highly recommended","Comfortable walking boots","Blaze orange during deer firearm season","Water"],warning:"NE Washington has both species. Daily bag limit is 4 aggregate across both species."}},
  // CHUKAR
  {id:"snake-river-chukar",deer:"chukar",name:"Snake River Canyon",subname:"Asotin County - Top Chukar in WA",lat:46.3500,lng:-117.0500,place_id:"ChIJuzjzPosCo1QRAbus3O4Sp9U",gmu:"GMU 169",publicLand:true,difficulty:"Advanced",
   summary:"The Snake River breaks are WA's most productive chukar country. Hunt the rocky canyon walls above the river. Birds hold on steep slopes and run uphill when pushed. Fitness is essential.",
   access:"From Clarkston: Head south on US-12 or Snake River Rd into the Asotin County canyon country. Multiple BLM and public access points along the canyon rim.",
   how:{overview:"Asotin County consistently produces 1500-1700 chukar per year - the highest in WA. The key to chukar: get above them. Birds always run and flush downhill so hunt from the top down.",steps:["Start high on the canyon rim and work down - chukar run uphill constantly.","Listen for the loud chuck-chuck-chukar call to locate coveys before closing in.","A pointing dog is invaluable - chukar run until pushed into a corner then hold.","When birds flush they go downhill - mark where they land and follow.","Midday birds sunbathe on rocky south-facing slopes. Look for white droppings on rocks."],terrain:"Extremely steep rocky canyon walls. Very physically demanding. Good boots with ankle support are mandatory.",bestTime:"October through January. November and December birds are in the largest coveys.",gear:["Stout ankle-support hunting boots","Dog is near-essential for chukar","12 or 20 gauge with modified choke and #6 or #7.5 shot","Lots of water - very dry country","Blaze orange vest","Trekking poles help on steep terrain"],warning:"Chukar hunting is notorious for being exhausting. Experienced hunters say you hunt chukar with your legs not your gun. Prepare physically before the season."}},
  {id:"yakima-canyon-chukar",deer:"chukar",name:"Yakima River Canyon",subname:"Kittitas-Yakima County",lat:46.9500,lng:-120.5200,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 335",publicLand:true,difficulty:"Intermediate",
   summary:"The Yakima River canyon offers more accessible chukar hunting than the Snake River. Hunt the rocky slopes above the canyon road. Birds are plentiful and terrain is manageable.",
   access:"From Ellensburg: Head south on SR-821 (Canyon Rd) along the Yakima River. BLM land on both sides offers public access. Park at pullouts along the road.",
   how:{overview:"The Yakima Canyon is more accessible than the Snake River breaks and holds excellent chukar numbers. Kittitas and Yakima counties are both in the top 5 statewide.",steps:["Park at a canyon pullout and hike up the rocky slopes away from the road.","Work the rocky ridgelines and basalt outcrops - chukar love rocky terrain with bunchgrass.","Listen for the distinctive chukar call to locate birds before closing in.","Hunt in the morning when birds are moving. Midday birds are tight in rocks.","A dog makes a big difference - without one walk slowly and deliberately."],terrain:"Rocky canyon slopes with basalt outcrops. Moderately steep but less extreme than the Snake River breaks.",bestTime:"October through December. Kittitas and Yakima counties each produce 1500-1700 chukar per year.",gear:["Boots with ankle support","12 or 20 gauge with #6 or #7.5 shot","Water - very dry country","Dog helpful","Blaze orange vest"],warning:"Yakima Canyon has rattlesnakes in September and October. Watch where you step. Also shared with deer hunters - wear orange during firearm deer season."}},
  // HUNGARIAN PARTRIDGE
  {id:"palouse-hun",deer:"hun",name:"Palouse Wheatlands",subname:"Whitman-Adams County - Best HUN in WA",lat:46.8500,lng:-117.8000,place_id:"ChIJu7pC0K7zqFQREE6nBKMBhLo",gmu:"Whitman County",publicLand:false,difficulty:"Intermediate",
   summary:"Washington's best Hungarian partridge hunting. Walk wheat stubble and CRP strips. Birds hold in coveys of 10-20 and flush in a tight thundering group when approached.",
   access:"From Colfax or Pullman: Explore the agricultural roads throughout the Palouse. Much is private farmland - ask permission. Some public access along Palouse River.",
   how:{overview:"The Palouse region holds WA's top Hungarian partridge populations. Birds live in agricultural areas - CRP grass wheat stubble and brushy draws between fields.",steps:["Scout CRP strips and grassy areas between wheat fields on a mapping app.","Ask farmers permission - HUN hunting is almost entirely on private agricultural land.","Walk slowly into the wind through CRP strips. Birds hold tight and let you get close.","When a covey flushes mark where they land and follow up.","Hunt multiple coveys in the same area - birds often do not move far."],terrain:"Flat to rolling Palouse hills. Easy walking terrain. Mostly private agricultural land.",bestTime:"October through December. Best in November when birds are in largest coveys.",gear:["Blaze orange vest and hat","20 or 28 gauge with #7.5 or #8 shot - open choke","Good upland boots","Dog is very helpful","Water"],warning:"Hungarian partridge hunting in WA is nearly 100% on private farmland. Use OnX Hunt to find public land pockets but the best hunting requires landowner permission."}},
  // QUAIL
  {id:"yakima-quail",deer:"quail",name:"Yakima County Wildlife Areas",subname:"Yakima County - #1 Quail County",lat:46.6000,lng:-120.5000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 335-371",publicLand:true,difficulty:"Beginner",
   summary:"Yakima County produces 25000 quail per year - nearly double the second-best county. Hunt brushy draws and shrubby hillsides near water. Birds flush in large noisy coveys.",
   access:"From Yakima: Head east or south into the shrub-steppe and orchard country. Oak Creek Wildlife Area Cowiche Canyon and numerous WDFW wildlife areas offer public access.",
   how:{overview:"Yakima County is WA's undisputed quail capital averaging 25000 California quail per year. Birds live in brushy coulees orchard edges and shrubby draws near water.",steps:["Scout water sources - quail rarely stray more than a quarter mile from water in dry eastern WA.","Hunt the brushy edges of creek drainages and orchards.","With a dog let the dog work into the wind through thick brush.","When a covey flushes mark where they land - singles hold much tighter after the initial flush.","Hunt morning and evening - quail feed in the open at dawn and dusk holding in cover midday."],terrain:"Flat to hilly shrub-steppe. Brushy creek drainages and orchard edges. Easy to moderate walking.",bestTime:"October through December. Best after cool weather concentrates birds near water and food.",gear:["20 or 28 gauge with #8 shot - open choke for fast close flushes","Dog is very helpful","Light boots","Blaze orange vest","Lots of water"],warning:"Yakima County averages nearly 25000 quail annually - nearly double Grant County (13000). Chelan and Okanogan counties also have excellent populations."}},
  // DOVE
  {id:"eastern-wa-dove",deer:"dove",name:"Columbia Basin Grain Fields",subname:"Grant-Adams County - September",lat:47.2000,lng:-119.5000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",
   summary:"Washington's dove season opens September 1 - one of the year's first hunts. Scout sunflower and grain fields near water. Birds feed in morning water at midday and roost at dusk.",
   access:"From Moses Lake: Explore the Columbia Basin Wildlife Area units and surrounding agricultural land. Find sunflower or milo fields near a pond or creek.",
   how:{overview:"Dove hunting is a social fast-shooting sport perfect for new hunters. The Columbia Basin offers September dove hunting over grain fields before other seasons open.",steps:["Scout a week before season - find sunflower milo or wheat fields near a pond or creek.","Set up at the field edge near a water source on September 1 morning. Bring a folding chair.","Shoot at passing birds using a swing-through technique - dove require 2-3 feet of lead.","Pick up all birds immediately - they are hard to find in tall vegetation without a dog.","Hunt until birds stop moving (usually by 10am) then return in the evening feeding flight."],terrain:"Flat agricultural land. Easy walking. Most areas accessible by vehicle.",bestTime:"September 1-15. Birds are most abundant before migration begins.",gear:["12 or 20 gauge with #7.5 or #8 shot","Plenty of shells - dove are challenging","Dog is very helpful for retrieval","Camo or dull clothing","Folding chair for field-edge sitting"],warning:"Dove are migratory birds requiring a state hunting license and Federal Migratory Bird permit. Non-toxic shot required on some public lands."}},
  // DUCK
  {id:"skagit-ducks",deer:"duck",name:"Skagit Wildlife Area",subname:"Skagit County - Top West-Side Duck",lat:48.3700,lng:-122.3700,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Skagit Valley",publicLand:true,difficulty:"Intermediate",
   summary:"Skagit County hunters take around 50000 ducks per year - the top county west of the Cascades. Hunt the flooded fields and sloughs of the Skagit Delta for mallards widgeon and teal.",
   access:"From Mount Vernon: Head west on Fir Island Rd or dike roads toward the Skagit River delta. WDFW wildlife area parking areas are marked. Boat access also available.",
   how:{overview:"The Skagit Valley and delta is western WA's premier duck hunting destination. Flooded agricultural fields tidal sloughs and marshes attract massive numbers of migrating ducks.",steps:["Scout a week before season - drive dike roads at dusk to watch where birds feed and roost.","Set up a decoy spread of 12-24 decoys in flooded fields or sloughs before first light.","Call with a duck call - mallard hen calls attract birds from a distance.","Shoot birds as they commit to the decoys - wait until they are in range (35 yards or closer).","Pick a good hunting partner - retrieving ducks without a dog in flooded fields is very difficult."],terrain:"Flat flooded agricultural fields and tidal sloughs. Rubber boots or waders required.",bestTime:"October through December. Peak migration November-December when birds move down from Canada.",gear:["Chest waders or hip waders","Non-toxic shot shells (steel or bismuth) - federally required","Duck calls","12-24 decoys","Retriever dog ideal","Camo clothing"],warning:"Skagit County hunters take about 50000 ducks per year - western WA top county. Grant County leads the entire state at 70000 annually. Check WDFW for regulated access area rules."}},
  {id:"grant-county-ducks",deer:"duck",name:"Potholes Reservoir Area",subname:"Grant County - #1 Duck County in WA",lat:46.9800,lng:-119.3500,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Intermediate",
   summary:"Grant County averages nearly 70000 ducks per year - more than any other WA county. The Columbia Basin potholes and reservoir system is world-class duck habitat.",
   access:"From Moses Lake: Head west on SR-170 to Potholes State Park and the Columbia Basin Wildlife Area. Multiple boat launches and walk-in access throughout the basin.",
   how:{overview:"The Columbia Basin potholes region is the jewel of WA duck hunting. Hundreds of small lakes and marshes hold mallards teal widgeon pintail and diving ducks through the entire season.",steps:["Scout small pothole lakes from roads in the week before season. Look for large flocks landing.","Set up on a pothole with a spread of 12-18 mallard and teal decoys before first light.","Call aggressively early - birds want to decoy in the morning feeding flight.","For divers set up on larger reservoirs with big spreads (24+ decoys) pointed into the wind.","Shoot early-season teal with smaller #6 steel then switch to #2 or #3 for November mallards."],terrain:"Flat basin country with potholes and reservoirs. Boat and walk-in access. Waders helpful.",bestTime:"Early season September teal then October-December for full migration. Peak is November.",gear:["Chest waders","12 or 20 gauge non-toxic shot","Duck calls","Decoys (more is better)","Boat optional but useful","Dog for retrieval"],warning:"Grant County is WA's top duck producer averaging just under 70000 birds annually. Read WDFW waterfowl regulations carefully before hunting Potholes."}},
  // GOOSE
  {id:"skagit-geese",deer:"goose",name:"Skagit Valley Farm Fields",subname:"Skagit County - Top WA Goose West Side",lat:48.4000,lng:-122.2000,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Skagit Valley",publicLand:false,difficulty:"Intermediate",
   summary:"Skagit County takes about 5400 geese per year - western WA's top goose county. Hunt flooded or cut corn and grass fields with full-body decoy spreads. Permission from farmers is key.",
   access:"From Burlington or Mount Vernon: Drive the agricultural flats of Fir Island and the Skagit River delta. Most hunting is on private farmland - knock on doors and ask permission.",
   how:{overview:"The Skagit Valley is WA's premier western goose hunting destination. Both giant resident Canada geese and migrating birds use the agricultural flats heavily through fall and winter.",steps:["Scout fields at first light to find where geese are feeding. Ask the farmer permission.","Set up 36-48 full-body decoys in the field before first light. Arrange in family groups not rows.","Call with a Canada goose call - clucks and moans as birds approach go silent when they commit.","Geese respond to motion - flapping flag decoys or windsock decoys improve realism.","Hunt until mid-morning when birds stop moving or stay all day during major migration pushes."],terrain:"Flat agricultural fields. Easy walking. Most access is private farmland.",bestTime:"October through January. Major migration pushes November-December bring the most birds.",gear:["12 gauge with BBB or BB non-toxic shot","Full-body decoys (36-48 minimum)","Canada goose call","Ghillie suit or layout blind","Flagging decoy for motion"],warning:"Most Skagit Valley goose hunting is on private farmland. Verify current Canada goose bag limits at wdfw.wa.gov before hunting as they have changed in recent years."}},
  {id:"grant-geese",deer:"goose",name:"Columbia Basin Potholes Area",subname:"Grant County - #1 State Goose",lat:46.9800,lng:-119.3500,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Intermediate",
   summary:"Grant County leads the state in goose harvest at 17000 birds per year. Hunt over decoy spreads in cut grain fields adjacent to the Columbia Basin reservoir system.",
   access:"From Moses Lake: Head west to the Potholes area. WDFW Columbia Basin Wildlife Area has public hunting access. Some adjacent fields require landowner permission.",
   how:{overview:"Grant County's combination of grain agriculture and the Columbia Basin reservoirs creates perfect goose habitat. Both Canada geese and white-fronted geese (specklebellies) use the area heavily.",steps:["Scout fields from roads at dawn - find where geese are actively feeding in cut grain or grass.","Set up 24-36 full-body decoys plus shells in a feeding pattern before first light.","Hunt field edges adjacent to public wildlife area land - stay on public property.","Canada geese respond to clucks and moans. Specklebellies need high-pitched yelping calls.","Expect shots at 20-40 yards - pass shooting at longer ranges results in cripples."],terrain:"Flat agricultural land and reservoir edges. Easy walking. Waders useful near water.",bestTime:"October through January. Specklebellies (white-fronted geese) peak in October-November.",gear:["12 gauge with BB or BBB non-toxic shot","Full-body or shell decoys","Canada goose and specklebelly calls","Layout blind or natural vegetation blind","Dog ideal for retrieval"],warning:"Grant County averages more than 17000 geese per year - the state top goose county. Check WDFW Columbia Basin Wildlife Area rules for specific access restrictions."}},
  // TEAL
  {id:"columbia-teal",deer:"teal",name:"Columbia Basin Potholes",subname:"Grant County - Early September Teal",lat:47.0000,lng:-119.3000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",
   summary:"The September teal season opens WA hunting season. Small pothole lakes hold blue-winged green-winged and cinnamon teal. Small decoy spreads and early mornings are all you need.",
   access:"From Moses Lake: Drive the Columbia Basin Wildlife Area roads looking for small pothole lakes. Many have walk-in access.",
   how:{overview:"Washington's early teal season (September 1) is one of the most fun hunts of the year. Fast birds over small water with minimal gear needed.",steps:["Find a small pothole or marsh edge with teal present. Scout the day before.","Set up 6-12 teal-sized decoys before first light.","Call with a teal whistle (high-pitched peeps). Do not over-call.","Shoot quickly - teal are the fastest ducks and will not give you long opportunities.","Move to different potholes if action slows - teal move a lot between small waters."],terrain:"Flat basin country with small lakes and marshes. Easy walking. Hip waders helpful.",bestTime:"September 1-15 for the early teal season. Best the first week.",gear:["12 or 20 gauge with #6 steel - non-toxic required","6-12 teal decoys","Teal whistle call","Hip waders or rubber boots","WA + Federal waterfowl license required"],warning:"Teal season is teal species only - no mallards or other ducks. Know your target species before shooting."}},
  // SNOW GOOSE
  {id:"columbia-basin-snow",deer:"snow-goose",name:"Columbia Basin Spring Conservation Hunt",subname:"Grant-Adams County",lat:47.1000,lng:-119.0000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",
   summary:"The spring Light Goose Conservation Order has no bag limit and electronic calls are legal - the most liberal regulations in all of WA hunting. Huge flocks stage here February through April.",
   access:"From Moses Lake: Drive the Columbia Basin in late February-March to find staging snow geese. WDFW wildlife area lands offer public access.",
   how:{overview:"The spring conservation order for light geese runs February through April with extremely liberal rules. No bag limit electronic calls legal shotguns can be unplugged. Snow goose populations have exploded damaging Arctic nesting habitat.",steps:["Scout late February-early March for massive white flocks on agricultural fields.","Set up a large spread of 200-500 rag or shell decoys before dawn - bigger is better.","Use an electronic caller (legal during conservation order) with feeding and landing calls.","Snow geese are very wary - full camo or white coveralls are essential.","Shoot continuously as birds make multiple passes - they will try to land repeatedly."],terrain:"Flat basin agricultural land and reservoir edges. Easy walking.",bestTime:"Late February through early April as birds stage before flying north.",gear:["White coveralls or full camo","200-500 decoys (more is better)","Electronic caller (legal during conservation order)","12 gauge with BB or BBB non-toxic steel","Layout blind"],warning:"Electronic calls are ONLY legal during the spring Light Goose Conservation Order - they are ILLEGAL during regular waterfowl season. Also: unplugged shotguns are legal during the conservation order only."}},
  // BRANT
  {id:"padilla-bay-brant",deer:"brant",name:"Padilla Bay",subname:"Skagit County - Top WA Brant",lat:48.4900,lng:-122.5000,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Coastal Zone",publicLand:true,difficulty:"Intermediate",
   summary:"Padilla Bay is one of Washington's best brant hunting locations. These small coastal geese feed on eelgrass in the tidal flats. Hunt from a kayak or shore blind with floating decoys.",
   access:"From Burlington: Take SR-20 west toward Bayview. Padilla Bay National Estuarine Research Reserve borders public hunting areas. BLM tidal lands are open to hunting.",
   how:{overview:"Brant are small dark sea geese that migrate along the Pacific Coast. Padilla Bay and the surrounding Skagit tidal flats are among WA's best brant locations. Hunting is tide-dependent.",steps:["Check the tide chart - hunt the incoming tide when brant fly from roost to feeding eelgrass flats.","Set up 6-12 brant or small Canada goose decoys on the water edge before first light.","Brant are less call-responsive than Canada geese - decoys and location matter more than calling.","Hunt from a layout boat kayak blind or shore blind concealed in marsh grass.","Be patient - brant flight periods can be short and tide-dependent."],terrain:"Tidal flats and coastal marsh. Boat or kayak highly recommended. Waders essential.",bestTime:"October through January. Brant are most concentrated during fall and winter migration.",gear:["Waders or drysuit (cold water)","Kayak or small boat for best access","6-12 floating decoys","12 gauge with #2 or #3 non-toxic shot","Blind material for shore concealment"],warning:"Bag limits for brant are very limited (typically 2 per day) - confirm current limits at wdfw.wa.gov before hunting."}},
  // RABBIT
  {id:"eastern-wa-rabbit",deer:"rabbit",name:"Columbia Basin Shrub-steppe",subname:"Grant-Adams County - Cottontail",lat:47.0000,lng:-119.4000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",
   summary:"Eastern WA's shrub-steppe and agricultural edges hold abundant cottontail rabbits. A perfect hunt for beginners - walk brush piles and sagebrush clumps and shoot jumping bunnies.",
   access:"From Moses Lake: Any BLM or WDFW land in the Columbia Basin provides access. Look for sagebrush and brush piles near agricultural edges.",
   how:{overview:"Washington's Columbia Basin has excellent cottontail rabbit hunting. Year-round season with no bag limit. Rabbits live in brushy draws sagebrush country and farm field edges.",steps:["Walk slowly through sagebrush brush piles and brushy field edges.","Stomp on or kick any brush pile - rabbits hold tight until nearly stepped on.","Shoot quickly when a rabbit flushes - they accelerate fast and weave through cover.","With a beagle let the dog push rabbits in circles - they always come back toward you.","Mark where rabbits jump up - multiple rabbits often live in the same area."],terrain:"Flat to rolling shrub-steppe and agricultural edges. Very easy walking.",bestTime:"Year-round. Best in November through January when vegetation is down.",gear:[".22 LR rifle or 20 gauge with #6 shot","Good walking shoes","Hunter orange recommended","Dog (beagle) ideal but not required","Water"],warning:"Cottontails are year-round with no bag limit in most of WA. Always confirm you are on public land using OnX Hunt."}},
  // SQUIRREL
  {id:"western-gray-squirrel",deer:"squirrel",name:"Ponderosa Pine and Oak Forests",subname:"Eastern WA - Western Gray Squirrel",lat:47.5000,lng:-120.5000,place_id:"ChIJDdPHo9PTnFQRRqUm89U2VYQ",gmu:"Eastern WA",publicLand:true,difficulty:"Beginner",
   summary:"Western gray squirrels live in the ponderosa pine and oak forests of eastern WA. Hunt under nut-bearing oaks and pine trees in the morning - squirrels are most active at first light.",
   access:"From Wenatchee or Chelan: Head into the lower elevation ponderosa pine and oak timber on DNR or Forest Service land. Eastern slopes of the Cascades and Okanogan Highlands.",
   how:{overview:"Washington has Western Gray Squirrels (in oak and pine forests) and Douglas Squirrels/Chickarees (in conifer forests statewide). Both are excellent small game hunting.",steps:["Find oak or nut-bearing trees - squirrels concentrate where food is abundant in fall.","Sit quietly at the base of a large oak or pine 30 minutes before dawn and wait.","Listen for cutting sounds (squirrels chewing nuts) or chattering alarm calls.","Stalk quietly when you hear activity. Squirrels freeze when alarmed - look for the tail.","A .22 rifle with head shots is most effective and preserves meat."],terrain:"Ponderosa pine and oak forest. Easy to moderate walking.",bestTime:"September through December. Best when acorns and pine seeds are dropping.",gear:[".22 LR rifle with scope","20 gauge shotgun as alternative","Good walking boots","Small game license","No orange required unless big game firearm season is open"],warning:"Western Gray Squirrel season is September 1 - December 31 with a bag limit of 3 per day. Douglas Squirrel (chickaree) is year-round with no bag limit."}},
  // BOBCAT
  {id:"ferry-bobcat",deer:"bobcat",name:"Ferry County Timberlands",subname:"NE Washington",lat:48.4000,lng:-118.7000,place_id:"ChIJTy27ZVtmYlMREECqwv6Kmh8",gmu:"Ferry County GMUs",publicLand:true,difficulty:"Advanced",
   summary:"Ferry County's remote dense forests hold excellent bobcat populations. Predator calling with distress sounds at dawn or dusk can bring bobcats in fast - they respond aggressively to rabbit calls.",
   access:"From Republic: Explore any Forest Service or DNR road into the dense timber country. Colville National Forest and surrounding DNR lands provide extensive public access.",
   how:{overview:"Ferry County is one of WA's top counties for bear and cougar - it also holds excellent bobcat populations. Predator calling is the most productive method.",steps:["Set up at a forest edge or clearing at first light or last light - most productive times.","Use a distress call (rabbit in distress or bird distress) and blow every 2-3 minutes for 30 minutes.","Scan continuously in a 360-degree circle - bobcats come in fast and silently.","If nothing in 20 minutes move at least 500 yards and try a new setup.","Hound hunting is the most reliable method - contact a local outfitter if interested."],terrain:"Dense mixed timber. Moderate to steep terrain. Good forest road access.",bestTime:"Late fall and winter when bobcats are most active and leaves are down.",gear:[".223 or .243 rifle for longer shots","12 gauge #4 buckshot for close calling setups","Electronic or mouth distress call","Camo - bobcats have excellent eyesight","Patience"],warning:"Bobcat has a statewide harvest quota in WA - check the current status before hunting as the season closes when the quota is met. All harvested bobcats must be registered with WDFW within 5 days."}},
  // COYOTE
  {id:"eastern-wa-coyote",deer:"coyote",name:"Eastern WA Agricultural Edges",subname:"Statewide - No Season or Limit",lat:47.0000,lng:-119.8000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Statewide",publicLand:true,difficulty:"Beginner",
   summary:"Coyotes are legal year-round with no bag limit anywhere in Washington. Hunt field edges and shrub-steppe at dawn or dusk with an electronic or mouth call. Excellent off-season hunting.",
   access:"Any public land statewide. Columbia Basin Wildlife Area BLM lands throughout eastern WA and forest service lands all offer coyote hunting. Night hunting with artificial light is legal.",
   how:{overview:"Washington has a healthy coyote population statewide. Year-round season with no bag limit - a great off-season hunt for improving calling and shooting skills.",steps:["Set up at a field edge ridgeline or clearing with a good view in multiple directions.","Use a distress call (rabbit bird or rodent) - start with softer calls and increase volume.","Call for 20-30 minutes at each setup. If nothing comes in move 500+ yards and try again.","Scan constantly - coyotes come in fast and from unexpected directions.","Night hunting with artificial light is legal in WA - a spotlight or red/green light is very effective."],terrain:"Flat to rolling eastern WA. Easy to moderate terrain. Vehicle access to most setups.",bestTime:"Year-round. Most active late fall through winter when pups have dispersed.",gear:[".223 or .224 Valkyrie for long-range shots","Electronic caller with remote control","Camo clothing","Binoculars for spotting incoming coyotes","Red or green spotlight for night hunting"],warning:"Coyote hunting is year-round with no bag limit in WA. Night hunting with artificial light is legal but check local ordinances near populated areas."}}
  ,{id:"skokomish-bt",deer:"black-tail",name:"Skokomish Wildlife Area",subname:"Mason County",lat:47.3400,lng:-123.2800,place_id:"ChIJoyYMj417jlQRWV9OUIXMgJs",gmu:"GMU 636",publicLand:true,difficulty:"Beginner",summary:"Dense alder bottoms along the Skokomish River. Hunt flats at first light where deer cross between river bottom and upland clearcuts.",access:"From Shelton: North on US-101 then west on Skokomish Valley Rd. WDFW wildlife area signs mark parking. Flat roads throughout.",how:{overview:"Productive river bottom with good deer numbers and easy access in Mason County.",steps:["Walk flat river-bottom trails at first light.","Focus on alder bottom transitions to upland brush.","Set up at a creek crossing or funnel 30 min before sunrise.","Midday still-hunt slowly along alder edges.","Evening return to flats as deer move back."],terrain:"Flat river bottom with alder and second growth. Muddy in wet season.",bestTime:"Mid-October through November. Overcast rainy mornings are ideal.",gear:["Rubber boots","Rain jacket","Hunter orange (required)","Binoculars","Quiet fleece"],warning:"Flooding can close river-bottom roads after heavy rain. Check conditions before going."}},
  {id:"green-river-bt",deer:"black-tail",name:"Green River Natural Resources Area",subname:"King County - Closest to Seattle",lat:47.2800,lng:-122.0200,place_id:"ChIJZRRQSy-ckVQRWmYvX4BbDKM",gmu:"GMU 485",publicLand:true,difficulty:"Beginner",summary:"The closest quality public deer hunting to Seattle — just 45 minutes from the city. DNR manages clearcuts and second-growth with road access throughout.",access:"From Auburn: Take SR-164 east toward Enumclaw. Multiple DNR road access points off the highway. Download WA DNR Road Viewer app.",how:{overview:"Green River NRA offers surprisingly good black-tail hunting close to Seattle. Second-growth timber with recent clearcuts attracts deer year-round.",steps:["Download DNR Road Viewer app and find clearcuts 3-7 years old near timber edges.","Drive logging roads slowly at dusk to locate deer before season.","Arrive at clearcut edge before first light. Walk quietly from vehicle.","Hunt clearcut-timber junctions. Deer here are accustomed to road noise.","Arrive early and be patient — this area gets pressure on opening weekend."],terrain:"Rolling Cascade foothills with logging roads. 2WD accessible most of the year.",bestTime:"Opening week of modern firearm season. Weekdays are far quieter than opening weekend.",gear:["Hunter orange (required)","Quiet clothing","Binoculars","DNR Road Viewer app offline","Rain gear"],warning:"Heavy pressure from King County hunters on weekends. Weekdays are far more productive."}},
  {id:"skagit-wildlife-bt",deer:"black-tail",name:"Skagit Wildlife Area",subname:"Skagit County - Western Flats",lat:48.3500,lng:-122.3500,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"GMU 417",publicLand:true,difficulty:"Beginner",summary:"Flat agricultural and timber land in the Skagit Valley. Hunt clearcut edges and brushy field margins. Black-tails here move predictably at dawn.",access:"From Burlington: West on Fir Island Rd or North Fork Ave. Multiple WDFW wildlife area parking areas. Flat terrain accessible by any vehicle.",how:{overview:"Unique flatland black-tail experience in a mix of timber edges brushy thickets and agricultural margins.",steps:["Locate brushy thickets and timber edges bordering agricultural fields on satellite maps.","Set up at the downwind edge of a thicket or timber strip at first light.","Still-hunt quietly along field edges and ditch banks mid-morning.","Watch for deer crossing between wildlife area and adjacent private farmland.","Evening: position between feeding fields and bedding cover at dusk."],terrain:"Flat. Mix of brush thickets timber strips and agricultural fields. Rubber boots recommended.",bestTime:"October through November. Overcast days after early morning frost are excellent.",gear:["Rubber boots","Rain jacket","Hunter orange (required)","Binoculars","Quiet jacket"],warning:"Some portions are closed seasonally for waterfowl. Confirm deer hunting access before going."}},
  {id:"wahkiakum-bt",deer:"black-tail",name:"Wahkiakum County Timberlands",subname:"SW Washington - Lower Columbia",lat:46.3000,lng:-123.4000,place_id:"ChIJp8OQKwHHk1QRoh_arfwe3gk",gmu:"GMU 672",publicLand:true,difficulty:"Intermediate",summary:"Underrated black-tail hunting along the Columbia River corridor. Dense second-growth with abundant deer and very low hunting pressure.",access:"From Cathlamet: Explore DNR or timber company roads north from SR-4. Download DNR Road Viewer app. High-clearance vehicle recommended when wet.",how:{overview:"Wahkiakum County is one of the least-hunted counties in WA despite excellent black-tail numbers. Lower Columbia River corridor with dense second-growth.",steps:["Use DNR Road Viewer to find recent clearcuts 2-8 years old.","Scout roads the evening before — deer often visible at dusk.","Position at clearcut-timber edge junction before first light.","Focus on draws and creek drainages that funnel deer movement.","Midday still-hunt old skid roads through thick second-growth."],terrain:"Rolling to steep timbered hillsides. Muddy logging roads — 4WD recommended.",bestTime:"Late October through November when the rut pushes bucks into the open.",gear:["4WD vehicle recommended","Rain gear and rubber boots","Hunter orange (required)","Binoculars","Gaia GPS offline"],warning:"Very little cell service. Download maps before leaving. Tell someone your plans."}},
  {id:"l-t-murray",deer:"mule-deer",name:"L.T. Murray Wildlife Area",subname:"Kittitas County - Central WA",lat:46.9200,lng:-120.3800,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 328",publicLand:true,difficulty:"Intermediate",summary:"Over 100000 acres of open shrub-steppe and ponderosa pine. One of the largest public hunting areas in WA with consistent mule deer numbers.",access:"From Ellensburg: South on SR-821 or east on I-90 then south. Multiple access roads off US-97. Download Gaia GPS and load wildlife area boundary.",how:{overview:"L.T. Murray Wildlife Area is one of WA's largest public hunting blocks. Rolling shrub-steppe and open pine forest — classic mule deer spot-and-stalk country.",steps:["Drive wildlife area roads slowly at first light glassing open slopes and draws.","Focus on south-facing slopes with bunchgrass — deer feed here in morning sun.","When you spot a deer use terrain to plan your stalk. Open country rewards patience.","Midday hunt creek bottoms and pine draw edges where deer bed in shade.","Late afternoon return to elevated points and glass as deer move back out."],terrain:"Rolling shrub-steppe to open pine. Dirt roads throughout. 2WD accessible when dry.",bestTime:"Mid-October through November. GMU 328 firearm season typically runs mid-October.",gear:["Binoculars (essential)","Layers for big temperature swings","Hunter orange (required)","Good boots for rocky terrain","OnX Hunt or Gaia GPS"],warning:"L.T. Murray is enormous and easy to get disoriented. Download the wildlife area boundary map and tell someone your access route."}},
  {id:"quilomene",deer:"mule-deer",name:"Quilomene Wildlife Area",subname:"Kittitas-Chelan County - Columbia Canyon",lat:47.1500,lng:-119.9500,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 328",publicLand:true,difficulty:"Intermediate",summary:"Dramatic canyon country above the Columbia River. Glass steep basalt canyon walls for mule deer then make careful stalks into the broken terrain.",access:"From Vantage: Cross Columbia on I-90 then north on Huntzinger Rd. WDFW wildlife area access roads clearly marked. Steep terrain — good boots required.",how:{overview:"One of WA's most spectacular mule deer areas. Steep canyon walls above the Columbia River with good buck populations and light pressure away from roads.",steps:["Park at a high point and glass canyon walls and benches with binoculars before moving.","Look for deer feeding on grassy benches in early morning before they drop into canyon shade.","Stalks require careful route planning — the basalt breaks are steep and unstable.","Midday bucks bed in rock outcrops and canyon shadows — scan carefully.","Late afternoon deer move back onto benches and grassy flats above the river."],terrain:"Steep basalt canyon country. Very rough — ankle support boots mandatory. Not for the unfit.",bestTime:"Opening week of firearm season before deer pattern hunting pressure.",gear:["Stout ankle-support boots","Binoculars or spotting scope","Hunter orange (required)","Trekking poles for steep terrain","Lots of water — very dry"],warning:"Heat can be extreme in early season. Rattlesnakes present through October. Do not attempt alone."}},
  {id:"swanson-lakes",deer:"mule-deer",name:"Swanson Lakes Wildlife Area",subname:"Lincoln County - Eastern WA Shrub-steppe",lat:47.6500,lng:-118.5000,place_id:"ChIJu7pC0K7zqFQREE6nBKMBhLo",gmu:"GMU 130",publicLand:true,difficulty:"Beginner",summary:"Classic Lincoln County shrub-steppe mule deer. Wide open terrain perfect for beginners learning spot-and-stalk. Low hunting pressure outside of opening weekend.",access:"From Wilbur or Creston: South on any county road into the wildlife area. Flat roads accessible by 2WD. Download WDFW Swanson Lakes boundary map.",how:{overview:"Perfect beginner mule deer area. Flat to gently rolling open shrub-steppe — glass for miles and plan easy stalks without extreme terrain.",steps:["Drive wildlife area roads at first light stopping to glass draws and shrubby coulees.","Mule deer stand out against the tan landscape — use binoculars systematically.","Plan a simple stalk using coulee edges and shrub lines to stay out of sight.","Midday deer bed in brushier coulees and willow draws. Walk these slowly.","Evening: find a high point and glass as deer move out to feed."],terrain:"Flat to gently rolling shrub-steppe with shallow coulees. Easy walking. 2WD accessible.",bestTime:"Mid-October through November. Lincoln County has consistently good mule deer numbers.",gear:["Binoculars","Earthy-colored clothing","Hunter orange (required)","Light boots — flat terrain","OnX Hunt for public land boundaries"],warning:"Lincoln County has a mix of public and private land. Use OnX Hunt to stay on the Swanson Lakes Wildlife Area at all times."}},
  {id:"colockum",deer:"mule-deer",name:"Colockum Wildlife Area",subname:"Chelan-Kittitas County - Cascade Foothills",lat:47.2700,lng:-120.2800,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMUs 328-334",publicLand:true,difficulty:"Intermediate",summary:"Steep forested ridges dropping into open shrub-steppe. Mule deer bed high and feed low — hunt the transition zone between pine timber and open shrub-steppe.",access:"From Wenatchee: South on US-97 then west into the wildlife area. Rocky unpaved roads — high clearance recommended. Download Gaia GPS before going.",how:{overview:"Colockum bridges the gap between Cascade pine forest and Columbia Basin shrub-steppe. Deer patterns here are vertical — bed high feed low.",steps:["In the morning drive or hike to an elevated position overlooking the lower open country.","Glass deer feeding in the open shrubby flats and slopes before they move uphill to bed.","Make your stalk before 8am when deer are still in the open.","Midday hunt pine timber benches where deer bed. Move very slowly.","Late afternoon reverse the morning pattern — find a vantage over the lower open country."],terrain:"Steep mixed terrain from open shrub-steppe to forested ridges. Rugged and demanding.",bestTime:"Opening week of season. Buck activity increases through November during the rut.",gear:["Hiking boots with ankle support","Binoculars","Hunter orange (required)","Downloaded topo maps","Layers — big elevation change means big temperature swings"],warning:"High clearance or 4WD vehicle recommended. This is demanding terrain — know your fitness limits."}},
  {id:"selkirk-wt",deer:"whitetail",name:"Selkirk Mountains",subname:"Pend Oreille County - Deep Timber",lat:48.8000,lng:-117.2000,place_id:"ChIJTy27ZVtmYlMREECqwv6Kmh8",gmu:"GMU 121",publicLand:true,difficulty:"Advanced",summary:"Deep timber whitetail hunting in the Selkirks near the Idaho and Canada borders. Some of the largest whitetail bucks in Washington come out of this country in November.",access:"From Newport: North on SR-20 into Pend Oreille County. Idaho Panhandle NF and USFS lands have extensive access. Download Avenza Maps offline.",how:{overview:"Pend Oreille County's Selkirk range holds some of WA's best whitetail hunting. Remote dense timber with minimal pressure away from main roads.",steps:["Scout creek drainages and river bottoms on topo maps before season.","Set up a stand or ground blind on a heavily used trail in a creek bottom.","Scent control is critical in this dense timber — spray down before every sit.","The rut (late October through mid-November) is key — bucks cruise widely for does.","Rattle and grunt call during rut peak. Dominant bucks here respond aggressively."],terrain:"Dense mixed conifer and hardwood. Steep drainages and creek bottoms. Demanding terrain.",bestTime:"November 1-20 during peak rut. Best mature bucks move in daylight only during this window.",gear:["Scent eliminator spray","Rattling antlers and grunt call","Tree stand or ground blind","Hunter orange (required)","Warm layered clothing"],warning:"CWD confirmed in Pend Oreille County GMU 121 as of 2025. Mandatory testing required — keep whole head with 3 inches of neck attached."}},
  {id:"ferry-county-wt",deer:"whitetail",name:"Ferry County San Poil Valley",subname:"NE Washington - Mixed Timber",lat:48.2500,lng:-118.5000,place_id:"ChIJTy27ZVtmYlMREECqwv6Kmh8",gmu:"GMU 113",publicLand:true,difficulty:"Intermediate",summary:"Ferry County's San Poil River valley offers excellent whitetail in mixed timber with more open terrain than the dense Selkirks. Good public land access and lighter pressure.",access:"From Republic: South on SR-21 along the San Poil River. DNR and Colville NF lands on both sides. Multiple pull-off parking areas.",how:{overview:"The San Poil Valley is Ferry County's most accessible whitetail country. Mixed pine and fir with river-bottom alder and willow — whitetails use the creek bottom as core travel route.",steps:["Walk river-bottom alder and willow looking for heavily used trails.","Set up a stand on a well-used crossing 30-45 minutes before first light.","San Poil Valley deer are less pressured and respond better to calls.","Rattle and grunt during the rut (late October through November).","Morning and evening are peak. Midday still-hunt the timbered benches."],terrain:"Mostly flat river bottom with timbered hillsides on both sides. Easy to moderate.",bestTime:"Late October through November rut. Ferry County is one of WA's top 5 whitetail counties.",gear:["Scent control spray","Stand or blind","Hunter orange (required)","Grunt call","Warm clothing"],warning:"Ferry County GMU 113 — check current antler restrictions and CWD testing requirements for the Eastern Region."}},
  {id:"oak-creek-turkey",deer:"turkey",name:"Oak Creek Wildlife Area",subname:"Yakima County - Tieton River Canyon",lat:46.6500,lng:-121.0000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 360",publicLand:true,difficulty:"Beginner",summary:"One of WA's best known public turkey areas. Tieton River canyon holds large flocks year-round. Glass canyon walls at dawn for gobbling toms on roost.",access:"From Yakima: West on US-12 to Naches then continue west. Oak Creek Wildlife Area clearly marked on US-12. Large WDFW parking area.",how:{overview:"Oak Creek's Tieton River canyon has one of WA's densest turkey populations. Birds roost in canyon wall pines and feed in open flats below.",steps:["Scout the canyon the evening before — listen for gobbling at roost time 30 min before dark.","Set up 150 yards from a roosting tree before first light. Arrive at least 45 min early.","Call with soft tree yelps and clucks as the sky lightens. Increase volume after flydown.","If gobbler hangs up try going quiet for 10-15 minutes then call again softly.","For fall hunting scatter a flock then call scattered birds back."],terrain:"Canyon bottom and open flats with pine timber on the walls. Easy walking on main area roads.",bestTime:"Spring season April 15 - May 31. Opening week is best before birds pattern hunters.",gear:["Mouth call and box call","Full camo including face mask","12 gauge with extra-full choke and turkey loads","Hen decoy","Seat cushion"],warning:"Oak Creek is also a major elk winter feeding area. Respect any closures or restrictions during spring setup."}},
  {id:"klickitat-turkey",deer:"turkey",name:"Klickitat Wildlife Area",subname:"Klickitat County - Columbia Gorge",lat:45.9000,lng:-121.0000,place_id:"ChIJp8OQKwHHk1QRoh_arfwe3gk",gmu:"GMU 382",publicLand:true,difficulty:"Beginner",summary:"Open oak and pine woodland of Klickitat County holds excellent turkey with easy access. One of WA's most scenic turkey locations with Columbia Gorge views.",access:"From Goldendale: Northwest on county roads into the Klickitat River watershed. WDFW wildlife area access points on Glenwood Hwy and Satus Pass Road.",how:{overview:"Klickitat County's open oak woodlands and pine forest make classic Merriam's turkey habitat. Birds here are huntable with strong populations.",steps:["Scout the evening before — listen for gobbling at roost time at dusk.","Set up in open oak or pine timber 100-150 yards from roost trees before first light.","Set a hen decoy to give birds a visual target in the open timber.","Call moderately — birds are not heavily pressured and tend to respond well.","Mid-morning hunt is often productive — hens leave gobblers around 9am."],terrain:"Open oak and pine woodland. Gently rolling. Easy walking. Most areas accessible by 2WD.",bestTime:"Spring April 15 - May 31. Mid-morning hunts from day 3-10 of season are often best.",gear:["Mouth call and box call","Hen decoy","Camo — no orange required for turkey","12 gauge with extra-full choke","Folding stool"],warning:"Klickitat County has both Rio Grande and Merriam's turkey subspecies. Spring season is bearded birds only."}},
  {id:"gifford-pinchot-turkey",deer:"turkey",name:"Gifford Pinchot National Forest",subname:"SW Washington - West Side Turkey",lat:46.2000,lng:-121.7500,place_id:"ChIJp8OQKwHHk1QRoh_arfwe3gk",gmu:"GMU 578",publicLand:true,difficulty:"Intermediate",summary:"Merriam's turkeys in the ponderosa pine on the east flanks of the Cascades in Skamania County. Great option for western WA hunters who want a shorter drive than Yakima.",access:"From White Salmon or Stevenson: North on SR-14 or SR-142 into the Gifford Pinchot NF. Forest Service roads provide access. Download Gaia GPS or Avenza Maps.",how:{overview:"The Gifford Pinchot NF offers turkey hunting much closer to Portland and Vancouver than the Yakima Valley. Merriam's birds inhabit pine forest on the drier east-facing slopes.",steps:["Scout the week before season driving FS roads and listening for gobbling at sunrise and sunset.","Set up near pine timber with open meadow or clearcut adjacent.","Call softly at first — birds have less hunting pressure and may come in quietly.","If a bird hangs up at distance try moving 50 yards toward it aggressively.","Afternoon hunts can be productive — birds come to water sources in dry spring weather."],terrain:"Mixed pine and fir forest with open meadows. Moderate terrain. Good forest road access.",bestTime:"Spring season April 15 - May 31. Morning hunts on days 1-5 of season.",gear:["Mouth call and box call","Camo head to toe","12 gauge with full choke and #5 turkey loads","Decoys optional but effective","Bug spray"],warning:"Gifford Pinchot also has spring black bear season open simultaneously. Be aware of what is moving in the forest."}},
  {id:"asotin-county-turkey",deer:"turkey",name:"Asotin County Timber",subname:"SE Washington - Overlooked Turkey",lat:46.2500,lng:-117.2000,place_id:"ChIJuzjzPosCo1QRAbus3O4Sp9U",gmu:"GMU 169",publicLand:true,difficulty:"Intermediate",summary:"Asotin County is best known for chukar but holds a strong turkey population in the timbered draws above the Snake River canyon. Far less pressure than Yakima County.",access:"From Clarkston: Drive south or west into the timbered hills above town. DNR and USFS lands accessible off county roads.",how:{overview:"The timbered draws above the Snake River in Asotin County hold good turkey numbers with much lighter pressure than the Yakima Valley.",steps:["Scout the night before driving roads at dusk listening for gobbling from roost trees.","Set up well back from roost trees before first light. Steep terrain — allow extra time.","Birds here are more call-shy — be patient. Work the timbered draws and canyon edges.","For fall turkey scatter a flock then set up and call them back from exactly where they scattered.","Combine with a morning turkey hunt and afternoon chukar hunt for a unique two-species day."],terrain:"Steep timbered canyon draws. More demanding than Yakima County terrain.",bestTime:"Spring April 15 - May 31. Morning of opening day through opening week.",gear:["Mouth call and slate call","Full camo with face mask","12 gauge extra-full choke with premium turkey loads","Trekking poles for steep terrain","Water — very dry country"],warning:"Asotin County also has Snake River chukar season in fall. Know your quarry and target species rules for each season."}},
  {id:"wenas-pheasant",deer:"pheasant",name:"Wenas Wildlife Area",subname:"Yakima County - WDFW Pheasant Releases",lat:46.9000,lng:-120.6500,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 340",publicLand:true,difficulty:"Beginner",summary:"WDFW releases thousands of pheasants in the Wenas area each fall. Hunt CRP strips and brushy draws on or within a few days of a release for best results.",access:"From Selah: Drive north on Wenas Rd. Multiple wildlife area parking pullouts. Download WDFW pheasant release schedule at wdfw.wa.gov before your trip.",how:{overview:"The Wenas Wildlife Area gets regular WDFW pheasant releases throughout the fall season. Perfect for beginners learning the sport.",steps:["Check the WDFW pheasant release schedule before your trip.","Hunt on or within 1-3 days of a release for best results.","Walk CRP strips and brushy draws into the wind systematically.","Without a dog: kick through every clump of tall grass — released birds hold tighter than wild birds.","With a dog: let the dog work ahead into the wind."],terrain:"Rolling to gentle terrain with CRP grass and brushy draws. Easy walking.",bestTime:"October through December with peak hunting around WDFW release dates.",gear:["Blaze orange hat and vest (required)","12 or 20 gauge with #5 or #6 shot","Good upland boots","Dog helpful but not required with released birds","Water"],warning:"WDFW release schedules change annually. Check the current schedule at wdfw.wa.gov/hunting/gamebirds/pheasant."}},
  {id:"desert-wa-pheasant",deer:"pheasant",name:"Desert Wildlife Area",subname:"Grant County - Moses Lake Area",lat:47.0000,lng:-119.1000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",summary:"Part of the Columbia Basin Wildlife Area complex near Moses Lake. Mix of cattail marshes and CRP grass holds both WDFW-released and some wild resident pheasants.",access:"From Moses Lake: West on SR-17. Desert Wildlife Area access roads are signed. Multiple parking areas. Flat terrain accessible by any vehicle.",how:{overview:"The Desert Wildlife Area is part of Washington's best public pheasant complex. Cattail marshes mixed with CRP grass create varied habitat that holds birds throughout the season.",steps:["Hunt upland CRP edges in the morning and cattail draws in the afternoon.","Systematic walking in a grid pattern covers the most ground in open CRP areas.","Cattail patches hold roosters especially in cold or wet weather.","Walk slowly and listen for the cackle of a flushing rooster before you see it.","Without a dog push toward fence lines or road edges to corner running roosters."],terrain:"Flat. Mix of CRP grass cattail draws and grain stubble. Easy walking. 2WD accessible.",bestTime:"Late October through December. Post-release hunting is best in early November.",gear:["Blaze orange vest and hat (required)","12 or 20 gauge with #5 shot","Good upland boots","Dog is a major advantage","Water"],warning:"Check for area-specific regulations at wdfw.wa.gov before your trip."}},
  {id:"walla-walla-pheasant",deer:"pheasant",name:"Walla Walla County Agricultural Edges",subname:"SE Washington - Wild Pheasant",lat:46.0600,lng:-118.3400,place_id:"ChIJuzjzPosCo1QRAbus3O4Sp9U",gmu:"GMU 157",publicLand:false,difficulty:"Intermediate",summary:"Walla Walla County has excellent wild pheasant in the wheat and onion field margins. Private land but farmers here are receptive to polite hunting requests.",access:"From Walla Walla: Drive county roads north and east into the wheat country. Ask permission at farmhouses. Some public access along the Walla Walla River corridor.",how:{overview:"Walla Walla County sits in classic WA pheasant country. Wheat farming irrigation canals and CRP grasslands create ideal wild pheasant habitat.",steps:["Identify target farms using satellite imagery — look for CRP strips adjacent to crop fields and water.","Approach farmhouses politely mid-week.","Hunt field margins and CRP strips walking slowly into the wind.","Focus on irrigation canal margins and brushy ditches.","Push toward a road or water feature to prevent roosters from running out."],terrain:"Flat to gently rolling Palouse hills. Mostly private agricultural land.",bestTime:"October through December. Wild birds are most concentrated in November when vegetation dies back.",gear:["Upland vest with blaze orange","Light boots","12 or 20 gauge #4 or #5 shot","Dog is extremely valuable on wild birds","Water for you and your dog"],warning:"Walla Walla County GMU 157 — the Mill Creek Watershed has hunting restrictions. Confirm you are not in the closed watershed area using OnX Hunt."}},
  {id:"blue-mountains-grouse",deer:"grouse",name:"Blue Mountains Timber",subname:"Columbia-Walla Walla County - Ruffed Grouse",lat:46.0500,lng:-117.8000,place_id:"ChIJuzjzPosCo1QRAbus3O4Sp9U",gmu:"GMUs 145-154",publicLand:true,difficulty:"Intermediate",summary:"The Blue Mountains hold both ruffed grouse in creek bottoms and blue grouse on higher timbered ridges. Hunt creek drainages in the morning and move uphill mid-day.",access:"From Dayton: South on US-12 into the Umatilla National Forest. USFS roads provide good access. Download Avenza Maps or Gaia GPS — no cell service.",how:{overview:"Blue Mountains produce excellent grouse hunting. Creek drainages hold ruffed grouse and the upper pine timber holds blue grouse.",steps:["Walk alder and creek bottom drainages slowly in the morning for ruffed grouse.","A flushing dog is very helpful in dense creek bottom cover.","Mid-morning transition uphill to open pine timber where blue grouse are more visible.","Look for blue grouse sunning themselves on logging roads and open slopes.","Drive forest roads slowly in the evening — grouse often stand on roads at dusk."],terrain:"Creek drainages to open pine ridges. Significant elevation change. Moderate physical demand.",bestTime:"September through November. Combined blue and ruffed grouse on the same outing is possible.",gear:["20 gauge with #7.5 shot","Flushing dog helpful for ruffed grouse in creek bottoms","Good hiking boots","No orange required unless firearm deer season is open","Gaia GPS offline"],warning:"Blue Mountains see heavy deer and elk pressure in October and November. Wear hunter orange during all firearm big game seasons."}},
  {id:"north-cascades-grouse",deer:"grouse",name:"North Cascades Whatcom County",subname:"NW Washington - Blue Grouse",lat:48.7500,lng:-121.8000,place_id:"ChIJoyYMj417jlQRWV9OUIXMgJs",gmu:"GMUs 418-426",publicLand:true,difficulty:"Intermediate",summary:"The North Cascades hold abundant sooty (blue) grouse in the high elevation pine and fir forest. Hunt forest roads and alpine meadow edges at 3000-5000 feet elevation.",access:"From Bellingham or Burlington: East on SR-20 (North Cascades Highway). Numerous FS roads branch into the high country. Download offline maps.",how:{overview:"Whatcom and Skagit counties have excellent blue (sooty) grouse at elevation. Birds are often visible on forest roads and in edges of subalpine meadows.",steps:["Drive forest roads slowly at first light — grouse stand on roads in the morning.","Walk the edges of any subalpine meadow or recent clearcut adjacent to dense fir timber.","Blue grouse often hold tight and sit in low branches — look up as well as at ground level.","Without a dog walk a grid pattern through sparse subalpine timber stopping every 20 yards.","Call with a deep hooting sound — blue grouse sometimes respond to owl-like calls."],terrain:"High elevation (3000-5000 ft) subalpine forest. Moderate terrain. Forest roads provide access.",bestTime:"September is best before hunting season crowds and before snow closes high roads.",gear:[".22 rifle or 20 gauge with #7.5 or #8 shot","Good hiking boots","Layers — weather changes fast in the North Cascades","Offline maps — no cell service","Water"],warning:"North Cascades Highway (SR-20) closes in late fall. Check WSDOT road conditions before driving to high elevation areas."}},
  {id:"yakima-grouse",deer:"grouse",name:"Wenas and Naches Area",subname:"Yakima County - Blue Grouse",lat:47.0000,lng:-120.8000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 340",publicLand:true,difficulty:"Beginner",summary:"The ponderosa pine forest above the Wenas and Naches valleys holds consistent blue grouse. Drive the FS roads at dawn and walk timber edges — birds are abundant and approachable.",access:"From Naches: North on SR-410 or west on US-12. Multiple forest roads branch into the pine timber above the valley. 2WD accessible on most roads when dry.",how:{overview:"Yakima County highlands offer easy-access blue grouse hunting. Do a grouse morning and pheasant afternoon in the same area for a two-species day.",steps:["Drive forest roads slowly at first light. Blue grouse often stand on roads warming themselves.","Walk slowly through open ponderosa pine timber stopping every 20-30 yards.","Scan tree branches as well as the ground — blue grouse frequently perch in low branches.","Kick through any brush pile or dense shrub patch to flush holding birds.","Combine with a Wenas area pheasant hunt in the afternoon."],terrain:"Open ponderosa pine forest. Mostly gently rolling. Easy walking. 2WD accessible.",bestTime:"September through October before bird season pressure builds on other species.",gear:[".22 rifle or 20 gauge with #7.5 shot","Good walking shoes","No orange required unless deer season is open","Water","Small daypack"],warning:"Yakima County has both major deer seasons and turkey season overlapping with grouse season. Know which seasons are open and wear orange appropriately."}},
  {id:"grande-ronde-chukar",deer:"chukar",name:"Grande Ronde River Canyon",subname:"Asotin-Garfield County - Remote Chukar",lat:46.1000,lng:-117.3500,place_id:"ChIJuzjzPosCo1QRAbus3O4Sp9U",gmu:"GMU 166",publicLand:true,difficulty:"Advanced",summary:"The most remote and demanding chukar hunting in WA. Steep canyon walls above the Grande Ronde River hold exceptional bird densities with very little pressure. Fit hunters with a dog only.",access:"From Clarkston: South on Snake River Rd to Heller Bar boat launch. Many hunters jet boat down the Snake to the Grande Ronde confluence. Vehicle access via Asotin Creek Rd.",how:{overview:"The Grande Ronde canyon is WA's most remote and productive chukar hunting. Steep basalt walls and rocky benches hold birds all season with almost no pressure.",steps:["Access via jet boat is most common and most rewarding — allows you to cover remote canyon sections.","Hunt from the top down — chukar always run and flush downhill so stay above the birds.","In cold weather birds concentrate on warm south-facing rocky slopes mid-day.","Cover as much elevation as possible in the morning before birds move into thermal cover.","Mark bird locations with GPS when you flush a covey — they will be in the same drainage the next day."],terrain:"Extremely steep rocky basalt canyon. Among the most physically demanding hunting in WA. Not for beginners.",bestTime:"November through January. Cold weather pushes birds into the largest coveys on south slopes.",gear:["Stout ankle support hunting boots — mandatory","Dog is near-essential","Lots of water — extremely dry","Trekking poles (carry in hand — need them constantly)","Blaze orange vest","Jet boat access recommended"],warning:"The Grande Ronde canyon is remote wilderness. Only experienced fit hunters with a dog should attempt this area. Always tell someone your exact access route."}},
  {id:"chelan-chukar",deer:"chukar",name:"Lake Chelan Canyon Walls",subname:"Chelan County - Accessible Canyon",lat:47.8000,lng:-120.0000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 247",publicLand:true,difficulty:"Intermediate",summary:"The rocky canyon walls above Lake Chelan hold a consistent chukar population with boat or road access. Less demanding than the Snake River but still productive canyon hunting.",access:"From Chelan: Drive the south shore road or take a boat up the lake. BLM and state land on the canyon walls above the lake. Download BLM Surface Management maps.",how:{overview:"Lake Chelan's canyon walls offer more accessible chukar hunting than the Snake River. Rocky basalt cliffs with bunchgrass benches — classic habitat with water access making logistics easier.",steps:["Access the canyon walls via road from the south shore or boat access from Chelan.","Hunt from the ridge top down — work the rocky benches systematically.","Listen for chukar calling from below — the loud chuck-chuck-chukar is audible from 300 yards.","Without a dog walk slowly and push birds to the canyon wall where they flush down toward the lake.","In early season birds are scattered. November-December birds are in large coveys on south slopes."],terrain:"Rocky canyon walls above a lake. Steep but less extreme than Snake River. Boat access adds options.",bestTime:"October through December. Chelan County averages 500-700 chukar annually.",gear:["Ankle support boots","12 or 20 gauge with modified choke","Water — bone dry canyon country","Dog helpful","BLM Surface Management map offline"],warning:"Lake Chelan ferry and boat service schedules are limited in fall. Confirm transportation logistics before planning a boat-access hunt."}},
  {id:"methow-chukar",deer:"chukar",name:"Methow Valley Coulees",subname:"Okanogan County - Northern Chukar Range",lat:48.3000,lng:-119.8000,place_id:"ChIJPRueGV7XnFQRyWDBGynPyoo",gmu:"GMU 215",publicLand:true,difficulty:"Intermediate",summary:"The rocky coulees of the Methow Valley represent the northern edge of WA's chukar range. Birds here see less pressure and the terrain is more forgiving than the Snake River.",access:"From Twisp or Winthrop: Drive any road south and east into the shrub-steppe country. BLM and state lands interspersed with private — use OnX Hunt to navigate.",how:{overview:"Okanogan County's Methow Valley coulees hold chukar at the northern extent of their WA range. Very productive with lower hunting pressure.",steps:["Scout the rocky coulees and basalt outcroppings on satellite maps before season.","Hunt the rocky slopes and cliff bands above the shrubby valley floor.","Morning hunts focus on south-facing rocky slopes where birds warm in early sun.","A pointing dog is useful here — birds hold well in the rockier areas.","Walk the coulee rims and look down — chukar are often visible on rocky ledges below."],terrain:"Moderate coulees and rocky slopes. Less extreme than Snake River breaks. Mix of public and private land.",bestTime:"October through December. Okanogan County averages 300-400 chukar per year.",gear:["Good boots with ankle support","20 gauge or 12 gauge with #6 or #7.5 shot","Dog is helpful","OnX Hunt for land boundaries","Water"],warning:"Okanogan County has large mix of public and private land. Use OnX Hunt at all times to stay on legal hunting ground."}}
,
  // ── WHITETAIL (add 1 public) ────────────────────────────────────────────
  {id:"pend-oreille",deer:"whitetail",name:"Pend Oreille River WDFW Access",subname:"Newport — Public River Corridor",lat:48.6000,lng:-117.3000,place_id:"ChIJTy27ZVtmYlMREECqwv6Kmh8",gmu:"GMUs 117-121",publicLand:true,difficulty:"Intermediate",region:"NE — Pend Oreille County",summary:"WDFW public access along the Pend Oreille River gives you stand sites in the best whitetail county in WA. Set up pinch points between river timber and adjacent open areas.",access:"From Newport: Head north on US-2 along the Pend Oreille River. WDFW public access signs mark river corridor hunting areas. Download OnX Hunt before going.",how:{overview:"Pend Oreille County is arguably WA's best whitetail county. WDFW maintains river corridor public access that puts hunters in the heart of excellent timber-edge habitat.",steps:["Use OnX Hunt to locate WDFW public access parcels along the river — they are marked green.","Scout the edges where timber meets any open area. Deer travel these edges every morning and evening.","Set up a stand or ground blind at a pinch point where terrain funnels deer movement.","Spray scent eliminator on boots and clothing before every sit. Always approach from downwind.","The rut (late October to mid-November) is peak — bucks cruise river corridors searching for does."],terrain:"Flat to gently rolling river valley. Mix of riparian timber and open areas. Easy walking.",bestTime:"November during the rut. Cold fronts trigger major deer movement.",gear:["Scent eliminator spray (essential)","Quiet fleece clothing","Portable tree stand or ground blind","Hunter orange (required during firearm season)","OnX Hunt for access boundaries"],warning:"CWD has been confirmed in Pend Oreille County. Hunters must submit samples before transporting carcasses out of the Eastern Region. Check current WDFW rules."}},

  // ── HUN — 5 public spots ──────────────────────────────────────────────
  {id:"columbia-basin-hun",deer:"hun",name:"Columbia Basin Wildlife Area",subname:"Grant County — Public HUN Hunting",lat:47.1000,lng:-119.2000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",region:"Central — Grant County",summary:"The Columbia Basin Wildlife Area holds Hungarian partridge in its CRP grass and agricultural transition zones. Public land hunting alongside pheasant and quail for a great mixed-bag day.",access:"From Moses Lake: Head west on SR-170 to the Columbia Basin Wildlife Area. WDFW map shows all unit access roads. Download before going.",how:{overview:"Grant County's Columbia Basin Wildlife Area provides public access to HUN habitat in the agricultural transition zone. Birds use the same CRP strips and grass edges as pheasant and quail.",steps:["Download the WDFW Columbia Basin Wildlife Area map — it shows all open units and access roads.","Hunt CRP grass strips and brushy margins bordering crop fields in the morning.","HUN flush in tight fast coveys — they often go in all directions, then land and hold tight as singles.","Mark the covey landing spot and approach immediately — singles hold much tighter than the initial covey.","Combine with pheasant and quail hunting on the same day in the same areas."],terrain:"Flat to gently rolling basin country. Easy walking. Well-maintained wildlife area roads.",bestTime:"October through December. Best in November when coveys are largest.",gear:["20 gauge with #7.5 or #8 shot — open choke","Dog is very helpful","Blaze orange vest and hat","Water — dry basin country","WDFW Columbia Basin Wildlife Area map"],warning:"Columbia Basin Wildlife Area units have specific open dates and regulations. Check the WDFW website for which units are currently open for upland birds."}},
  {id:"wenas-hun",deer:"hun",name:"Wenas Wildlife Area",subname:"Yakima County — Mixed-Bag HUN",lat:46.9000,lng:-120.5000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 340",publicLand:true,difficulty:"Intermediate",region:"Central — Yakima County",summary:"The Wenas Wildlife Area holds Hungarian partridge alongside turkeys and mule deer. Hunt the grassy slopes and brushy draws for a classic Yakima County mixed-bag upland experience.",access:"From Selah: Head north on Wenas Rd into the Wenas Valley. WDFW wildlife area with multiple parking pullouts along the road.",how:{overview:"Wenas Wildlife Area is Yakima County's famous turkey spot but also holds good HUN populations in its grassy slopes and brushy draws. A mixed-bag hunt here can include HUN turkey quail and grouse.",steps:["Hunt the grassy slopes and brushy draws in the lower Wenas Valley for HUN.","Birds are often found on the open grassy hillsides feeding in morning before retreating to brush.","HUN coveys in the Wenas tend to be 8-15 birds — listen for their distinctive call before closing in.","A pointing dog dramatically improves your success rate on the open Wenas slopes.","Combine HUN hunting with a turkey scouting trip or early season mule deer hunt."],terrain:"Rolling hills with grassy slopes and brushy draws. Moderate terrain. Good road access.",bestTime:"October through December. Yakima County is excellent HUN country year after year.",gear:["20 or 28 gauge with #7.5 shot","Dog recommended","Blaze orange vest","Good walking boots","Water"],warning:"Wenas Wildlife Area is heavily hunted for turkey in spring and deer in fall. Check for concurrent hunting seasons that require hunter orange."}},
  {id:"yakima-training-hun",deer:"hun",name:"Yakima Training Center — Public Hunt Program",subname:"Kittitas County — Army Base Access",lat:46.8000,lng:-120.3000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 371",publicLand:true,difficulty:"Beginner",region:"Central — Kittitas County",summary:"The Yakima Training Center (US Army) runs a free public hunting program. The extensive shrub-steppe holds pheasant HUN quail and chukar with much less pressure than typical public land.",access:"From Yakima or Ellensburg: Register with YTC Environmental office (free) before hunting. Access is permitted on designated open areas. Check the YTC website for current open days.",how:{overview:"The Yakima Training Center is a US Army base that manages a large free public hunting program. The extensive shrub-steppe and grassland habitat holds HUN quail pheasant and chukar with far less pressure than typical public lands.",steps:["Register with the YTC Environmental office online — free and required before your visit.","Download the current YTC hunting map showing open vs. closed training areas for your hunt date.","Hunt brushy drainages CRP strips and grass edges in the morning when birds are most active.","HUN on YTC tend to be in larger coveys than heavily pressured public areas — good numbers.","Combine HUN hunting with pheasant quail and chukar in the same day — all use similar habitat."],terrain:"Open shrub-steppe and grassland. Easy terrain. Well-maintained military roads.",bestTime:"October through January. YTC is open when training activities permit — check the schedule.",gear:["YTC hunting permit (free from YTC Environmental office — required)","20 gauge with #7.5 shot","Blaze orange vest and hat","Dog recommended","Water"],warning:"You MUST register with YTC before entering. Training schedules affect access — check the YTC website before every trip. Closed areas are strictly enforced."}},
  {id:"colockum-hun",deer:"hun",name:"Colockum Wildlife Area",subname:"Kittitas County — Central WA",lat:47.2500,lng:-120.2500,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMUs 328-337",publicLand:true,difficulty:"Intermediate",region:"Central — Kittitas County",summary:"The Colockum Wildlife Area's grassland and shrub-steppe transition zones hold Hungarian partridge alongside mule deer. Public WDFW land with excellent road access from Ellensburg.",access:"From Ellensburg: Head north on Reecer Creek Rd or take Vantage Hwy north. WDFW Colockum Wildlife Area has multiple access points.",how:{overview:"The Colockum is a large WDFW managed wildlife area with open sagebrush ridges and grassland that provide good HUN habitat in addition to its famous mule deer hunting.",steps:["Focus on the grassland and CRP-style grass areas in the lower Colockum — HUN prefer grass edges.","Hunt the transition between open grassland and the shrubby draws — coveys use both areas.","Drive the Green Dot roads slowly in the morning looking for coveys near the road.","A dog is very helpful in the open Colockum terrain — birds may run ahead of hunters without a dog.","Combine with a mule deer hunt or deer scout on the same trip."],terrain:"Open sagebrush and grassland ridges with draws. Moderately hilly. Good road access on Green Dot system.",bestTime:"October through December. Colockum HUN hunting is underutilized — good birds with less pressure.",gear:["Green Dot Road permit (free from WDFW Yakima office)","20 gauge with #7.5 shot","Dog recommended","Blaze orange vest","Water — dry country"],warning:"Colockum straddles several GMUs with different antler restrictions for deer. Confirm rules for your specific unit. Green Dot permit required for vehicle access to interior roads."}},
  {id:"sinlahekin-hun",deer:"hun",name:"Sinlahekin Wildlife Area",subname:"Okanogan County — Northern HUN",lat:48.6000,lng:-119.7000,place_id:"ChIJDdPHo9PTnFQRRqUm89U2VYQ",gmu:"GMU 108",publicLand:true,difficulty:"Beginner",region:"NE — Okanogan County",summary:"The Sinlahekin Valley holds Hungarian partridge in the grassy slopes and agricultural margins alongside the famous mule deer hunting. A great mixed-bag destination in north-central WA.",access:"From Tonasket: US-97 north, west on Loomis-Oroville Rd, south on Sinlahekin Creek Rd. Paved to gravel. WDFW wildlife area with open access.",how:{overview:"The Sinlahekin Wildlife Area is famous for mule deer but also holds good HUN populations in its valley grasslands and adjacent ag edges. Far less hunting pressure than the Palouse.",steps:["Hunt the grassy valley floor and lower slopes adjacent to any agricultural areas in the valley.","HUN in the Sinlahekin tend to be in smaller coveys (6-10 birds) but hunting pressure is very low.","Combine HUN hunting in the morning with mule deer spotting from the ridge tops in the afternoon.","Walk slowly through any grass strips and low brush near the valley floor — birds hold surprisingly well.","A dog dramatically improves success on these lightly pressured birds."],terrain:"Open valley floor with grassy slopes. Easy terrain. Well-maintained wildlife area roads.",bestTime:"October through December. Lightly pressured birds in an underutilized area.",gear:["20 or 28 gauge with #7.5 shot","Dog recommended","Blaze orange vest","Water","Good walking boots"],warning:"Sinlahekin is famous for mule deer — during the modern firearm deer season it gets heavy hunting pressure. Plan HUN hunting for the archery deer season window or after the deer season closes."}},

  // ── QUAIL — 4 more public ─────────────────────────────────────────────
  {id:"chelan-quail",deer:"quail",name:"Chelan County DNR and BLM Hillsides",subname:"Wenatchee-Chelan — Apple Country",lat:47.8500,lng:-120.1500,place_id:"ChIJDdPHo9PTnFQRRqUm89U2VYQ",gmu:"GMU 215-231",publicLand:true,difficulty:"Beginner",region:"NC — Chelan County",summary:"Chelan County averages 8000-9000 quail per year — third in the state. The DNR and BLM hillsides above the apple orchard country hold large coveys accessible without permission.",access:"From Wenatchee or Chelan: The hillsides above the orchards on DNR and BLM land are public. Orchard Road north of Wenatchee leads to public hillside access. Download OnX Hunt.",how:{overview:"Chelan County quail hunting on the public DNR and BLM hillsides above the orchards provides excellent access without needing landowner permission. Large coveys use the brushy draws and shrubby hillsides.",steps:["Use OnX Hunt to identify DNR and BLM parcels on the hillsides above the apple orchards.","Hunt the brushy coulees and draws that cut through the hillsides — quail concentrate in these.","Water sources on the public hillsides draw quail from a wide area — find springs or stock tanks.","Work brushy draws from the top down pushing birds toward the valley — they tend to fly downhill.","Morning is best — birds feed on the open slopes at dawn then retreat to cover by 9am."],terrain:"Hilly public land above the orchard valley floor. Moderate terrain.",bestTime:"October through December — one of WA's best late-season options as season extends through January.",gear:["20 or 28 gauge with #8 shot","Dog highly recommended","Good walking boots for hilly terrain","Blaze orange vest","Water — dry Chelan hillsides"],warning:"The orchards below are private — stay on the public hillsides confirmed by OnX Hunt. The boundary between public and private can be hard to see on the ground."}},
  {id:"benton-quail",deer:"quail",name:"Benton County — Desert Wildlife Area",subname:"Tri-Cities Area — Public Access",lat:46.2000,lng:-119.2000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Benton County",publicLand:true,difficulty:"Beginner",region:"SE — Benton County",summary:"Benton County near the Tri-Cities has excellent quail on the WDFW Desert Wildlife Area and surrounding BLM lands. Large coveys near the Columbia River with easy public access.",access:"From Kennewick or Richland: Head east on SR-397 toward the Desert Wildlife Area or east of Pasco to the BLM Juniper Dunes area. Both are well-marked public areas.",how:{overview:"The Tri-Cities area may be the most accessible quail hunting in all of Washington. WDFW and BLM lands provide public hunting right outside a major city with good bird populations.",steps:["The Desert Wildlife Area south of Moses Lake and BLM Juniper Dunes area east of Pasco both hold quail.","Hunt the shrubby draws and brushy margins of coulees — quail avoid open sagebrush flats.","Water tanks and irrigation canals on public land are magnets for quail in dry Benton County.","Large coveys of 30-50 birds are common near good water sources — the initial flush can be spectacular.","Hunt morning and late afternoon when birds are most active."],terrain:"Flat sagebrush and shrub-steppe with brushy coulees. Very easy terrain. Good public land access.",bestTime:"October through December. Benton County is one of WA's most accessible public-land quail areas.",gear:["20 or 28 gauge with #8 shot","Dog is very helpful","Water — very dry desert country","Blaze orange vest","BLM and WDFW area maps"],warning:"Desert Wildlife Area and Juniper Dunes BLM area are excellent options. Check for any seasonal closures at BLM.gov before visiting."}},
  {id:"okanogan-quail",deer:"quail",name:"Okanogan County DNR Lands",subname:"Omak-Okanogan — Northern Quail",lat:48.3500,lng:-119.5000,place_id:"ChIJPRueGV7XnFQRyWDBGynPyoo",gmu:"GMU 108-113",publicLand:true,difficulty:"Beginner",region:"NE — Okanogan County",summary:"Okanogan County averages 8000-9000 quail per year on publicly accessible DNR and BLM land. Northern range of California quail in WA with good numbers and minimal hunting pressure.",access:"From Omak or Okanogan: Head east of the Okanogan River on DNR and BLM roads into the shrub-steppe. Use OnX Hunt to confirm public parcels.",how:{overview:"The northern range of California quail in Washington the Okanogan Valley holds good populations on publicly accessible DNR and BLM land. Very little hunting pressure compared to Yakima County.",steps:["Hunt brushy cottonwood and willow draws along the Okanogan River tributaries on DNR land.","Water is the key in dry Okanogan country — concentrate near any creek irrigation ditch or pond.","Morning feeding flights bring birds out of cover — hunt the open edges before 9am.","DNR land east of the Okanogan River provides public access without needing permission.","Combine with mule deer and grouse hunting on the same Okanogan County trip."],terrain:"Flat valley floor to rolling shrub-steppe. Easy to moderate terrain. Good public land access.",bestTime:"October through December. Much less pressure than Yakima County with comparable bird numbers.",gear:["20 or 28 gauge with #8 shot","Dog is helpful","Water","Light boots","Blaze orange vest"],warning:"Okanogan County quail hunting is underutilized. Confirm public land boundaries on OnX Hunt before hunting."}},
  {id:"columbia-basin-quail",deer:"quail",name:"Columbia Basin Wildlife Area",subname:"Grant County — Mixed-Bag Public Land",lat:47.0000,lng:-119.5000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Grant County",publicLand:true,difficulty:"Beginner",region:"Central — Grant County",summary:"Grant County averages 13000 quail per year — second in the state. The Columbia Basin Wildlife Area public land holds coveys alongside pheasant and waterfowl for excellent mixed-bag days.",access:"From Moses Lake: Head west on SR-170 to Columbia Basin Wildlife Area units. WDFW map shows all access points throughout the basin.",how:{overview:"Grant County quail hunting on the Columbia Basin Wildlife Area public land produces impressive bags alongside pheasant and duck hunting. The shrubby margins hold large California quail coveys.",steps:["Download the WDFW Columbia Basin Wildlife Area map before going — shows all unit access.","Hunt the brushy edges and shrubby draws within the wildlife area.","Quail here live adjacent to pheasant habitat — a mixed-bag day of both is common.","Water sources within the wildlife area concentrate quail during dry periods.","Mark where the covey lands after the initial flush — hunt singles immediately afterward."],terrain:"Flat to gently rolling basin country with shrubby draws. Easy walking on public land.",bestTime:"October through December. Pairs well with pheasant and duck hunting trips to the Columbia Basin.",gear:["20 or 28 gauge with #8 shot","Dog beneficial","Water","Blaze orange vest","WDFW Columbia Basin Wildlife Area map"],warning:"Check WDFW for which units are currently open for upland birds before making the drive."}},

  // ── DOVE — 4 more public ──────────────────────────────────────────────
  {id:"franklin-dove",deer:"dove",name:"Ringold Wildlife Area",subname:"Franklin County — Public Dove",lat:46.3000,lng:-118.9000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Franklin County",publicLand:true,difficulty:"Beginner",region:"SE — Franklin County",summary:"The Ringold Wildlife Area and adjacent BLM lands near Pasco offer public dove hunting on September 1. The desert agricultural surroundings produce large dove concentrations.",access:"From Pasco: Head east on SR-124 or south on US-395 toward Ringold. WDFW Ringold Wildlife Area has marked parking areas along the Columbia River corridor.",how:{overview:"Franklin County sits at the heart of the Columbia Basin migration route. Dove concentrate here in early September. Ringold Wildlife Area provides public access without needing farmer permission.",steps:["Scout the Ringold Wildlife Area edges and surrounding BLM fields in late August for dove activity.","Set up at any field edge or water source on public land before first light on September 1.","Irrigation canals and Columbia River ponds on public land draw dove all day long.","Shoot quickly — dove are small fast targets requiring 2-3 feet of lead for a hit.","Hunt until bird activity stops then return in the evening feeding flight."],terrain:"Flat desert agricultural land and Columbia River corridor. Very easy terrain.",bestTime:"September 1-15. One of the warmest parts of WA — birds concentrate early.",gear:["12 or 20 gauge with #7.5 or #8 shot","Plenty of shells","Dog for retrieval","Folding chair","Water — very hot in early September"],warning:"Franklin County is extremely hot in early September — start early and be done by 10am. Carry plenty of water for you and your dog."}},
  {id:"columbia-basin-dove",deer:"dove",name:"Columbia Basin Wildlife Area",subname:"Grant County — Public CRP Dove",lat:47.2000,lng:-119.5000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",region:"Central — Grant County",summary:"The Columbia Basin Wildlife Area CRP grass and grain field edges hold dove on September 1 without needing farmer permission. Combine with early teal season for a full September public-land trip.",access:"From Moses Lake: Head west to Columbia Basin Wildlife Area units along SR-170 and SR-28. Download WDFW Columbia Basin Wildlife Area map for unit access.",how:{overview:"The Columbia Basin Wildlife Area provides public dove hunting over CRP and grain field edges — no permission needed. This is one of the best public-land dove hunting opportunities in WA.",steps:["Download the WDFW Columbia Basin Wildlife Area map and find units bordering crop fields.","Set up at the field edge or near any pond or water source on the public wildlife area.","Morning is best — birds fly between roost and feed from first light through 10am.","Return in the evening feeding flight for a second round of shooting.","Mark down every bird immediately — dove are hard to find in tall cover without a dog."],terrain:"Flat basin country with CRP grass and field edges. Very easy terrain.",bestTime:"September 1-15. Best the first week before birds begin migrating south.",gear:["12 or 20 gauge with #7.5 or #8 shot","Extra shells — dove are challenging","Dog for retrieval","Folding chair","WDFW Columbia Basin Wildlife Area map"],warning:"Check which Columbia Basin Wildlife Area units are open for dove hunting. Non-toxic shot is required on some public land parcels."}},
  {id:"wenas-dove",deer:"dove",name:"Wenas Wildlife Area",subname:"Yakima County — September Opener",lat:46.9000,lng:-120.5000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 340",publicLand:true,difficulty:"Beginner",region:"Central — Yakima County",summary:"The Wenas Wildlife Area is a public land dove hunting option at the September 1 opener. The warm dry Yakima foothills hold dove well and the WDFW land is easily accessible.",access:"From Selah: Head north on Wenas Rd. WDFW Wenas Wildlife Area parking pullouts are marked along the road. No permission required.",how:{overview:"The Wenas Wildlife Area gives hunters a public land dove option in Yakima County without needing farmer permission. The warm Wenas Valley holds dove through the full September season.",steps:["Set up at any field edge or brushy area on the Wenas Wildlife Area before first light September 1.","The Wenas Valley warms quickly — dove are active in the early morning and evening.","Pass shooting incoming birds is the most common method — set up at a natural flight line.","Bring a dog or a willing partner to help find downed birds in the tall grass.","Combine with turkey scouting in the morning and dove hunting in the evening."],terrain:"Rolling Wenas Valley. Easy terrain. Wildlife area roads are accessible.",bestTime:"September 1-30. Yakima dove hunting is productive well beyond the first week.",gear:["12 or 20 gauge with #7.5 or #8 shot","Extra shells","Dog ideal","Folding chair or shooting stool","Water"],warning:"Wenas Wildlife Area is also heavily used by turkey hunters in spring and deer hunters in fall. Dove season opens September 1 before most deer seasons — no orange required for dove."}},
  {id:"l-t-murray-dove",deer:"dove",name:"L.T. Murray Wildlife Area",subname:"Yakima County — Open Country Dove",lat:46.8500,lng:-120.5000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMUs 335-372",publicLand:true,difficulty:"Beginner",region:"Central — Yakima County",summary:"The L.T. Murray Wildlife Area is Washington's largest WDFW area at 100000+ acres. Its open grasslands and grain field edges provide excellent September dove hunting without any permission needed.",access:"From Ellensburg: Head south on SR-10 or from Yakima head north on SR-821. Multiple WDFW access points throughout the wildlife area. Green Dot permit required for interior vehicle roads.",how:{overview:"The L.T. Murray is an enormous public land area with diverse habitat including grasslands that hold dove in September. The scale of the area means hunters can spread out and find birds without pressure.",steps:["Drive Green Dot roads to locate dove-producing areas — look for birds on power lines and fence posts.","Hunt near any water source within the wildlife area — stock tanks springs and creek crossings attract dove.","Set up at a natural flight line between roost timber and feeding grassland.","The huge size of the L.T. Murray means you can always find a quiet uncrowded spot.","Combine dove hunting with chukar or quail scouting on the same September trip."],terrain:"Open shrub-steppe grassland and canyon country. Easy terrain. Green Dot road vehicle access.",bestTime:"September 1-30. L.T. Murray dove hunting is lightly used and productive.",gear:["Green Dot Road permit (free from WDFW Yakima office)","12 or 20 gauge with #7.5 or #8 shot","Extra shells","Dog helpful","Water — dry country"],warning:"Green Dot Road permit is required for vehicle access to interior roads at the L.T. Murray. Get the free permit from the WDFW Yakima office before your trip."}},

  // ── DUCK — 3 more public ──────────────────────────────────────────────
  {id:"turnbull-ducks",deer:"duck",name:"Turnbull NWR — Controlled Hunt",subname:"Spokane County — Register Required",lat:47.4200,lng:-117.5700,place_id:"ChIJOdbxAUSGYlMRY9wapV66VhE",gmu:"Spokane County",publicLand:true,difficulty:"Beginner",region:"NE — Spokane County",summary:"Turnbull NWR is one of eastern WA's best public duck hunting locations just 15 miles south of Spokane. Register in advance for the controlled hunt program and enjoy excellent mallard and teal action.",access:"From Cheney: Head south on Cheney-Plaza Rd about 5 miles to Turnbull NWR entrance. Well-signed from Cheney. Check fws.gov/refuge/turnbull for the current hunt program and registration.",how:{overview:"Turnbull NWR runs a managed hunt program on its excellent wetland complex. Mallard teal and diving ducks use the potholes and marshes throughout the season. Easy terrain makes it beginner-friendly.",steps:["Register for the Turnbull NWR hunt program online at fws.gov/refuge/turnbull before September 1 — spots fill quickly.","Set up on your assigned pond before first light with a small spread of 6-12 decoys.","Small mallard and teal spreads work well — Turnbull ponds are intimate not big water.","Hunt the September teal opener here for fast action on blue-winged and green-winged teal.","Mallard hunting improves through October and November as migration birds move in."],terrain:"Flat NWR wetland complex. Easy terrain. Walk-in from parking areas.",bestTime:"September teal opener through January. October-November peak for mallards.",gear:["Hip waders or chest waders","12 or 20 gauge non-toxic shot","6-12 decoys","Duck call","Turnbull NWR hunt permit (required — free)","Dog helpful for retrieval"],warning:"Advance registration is REQUIRED. Do not show up at Turnbull NWR to duck hunt without registering. Check fws.gov/refuge/turnbull for the current program schedule."}},
  {id:"potholes-ducks",deer:"duck",name:"Potholes State Park — Walk-in",subname:"Grant County — Public Pothole Duck Hunting",lat:46.9800,lng:-119.3500,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",region:"Central — Grant County",summary:"Potholes State Park gives walk-in public access to the famous Columbia Basin potholes. Small spreads on the park potholes produce excellent teal in September and mallards through winter.",access:"From Moses Lake: Take SR-170 west to Potholes State Park. Camping and day-use parking available. Walk to potholes from the park. No boat required for shore hunting.",how:{overview:"Potholes State Park is the most accessible public entry point into the famous Grant County pothole duck hunting. Walk-in from the park to dozens of small potholes.",steps:["Park at Potholes State Park and walk to any pothole not already claimed by another hunter.","A small spread of 6-12 mallard or teal decoys works well on the intimate pothole water.","Call with a mallard hen call in the morning flight — birds come in fast and close on small water.","Hunt the September early teal season here for some of the best action in the state.","Rotate between multiple potholes throughout the morning to find active birds."],terrain:"Flat basin with walk-in access to potholes. Easy terrain. Hip waders helpful.",bestTime:"September teal season through January. Peak mallard hunting is October-November.",gear:["Hip waders or rubber boots","12 or 20 gauge non-toxic shot","6-12 decoys","Mallard or teal call","State park day-use or camping fee required","Dog for retrieval"],warning:"Potholes State Park has camping fees. Day-use access is available. Very popular on opening weekends — arrive very early or hunt midweek for less competition on the best potholes."}},
  {id:"skagit-wdfw-ducks",deer:"duck",name:"Skagit Wildlife Area — Regulated Units",subname:"Skagit County — Registered Blind System",lat:48.3500,lng:-122.4000,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Skagit Valley",publicLand:true,difficulty:"Intermediate",region:"NW — Skagit County",summary:"The WDFW Skagit Wildlife Area runs a registered blind system giving public hunters assigned spots in premier Skagit Delta mallard widgeon and pintail habitat. Register with WDFW Region 4.",access:"From Mount Vernon: Head west on Fir Island Rd toward the delta. Register with WDFW Region 4 office (360-775-1311) for the blind assignment system. Parking areas are marked.",how:{overview:"The WDFW Skagit Wildlife Area regulated blind program provides structured public access to one of the best duck hunting locations in western Washington. Flooded fields and delta sloughs hold huge numbers of mallards widgeon and pintail.",steps:["Contact WDFW Region 4 (360-775-1311) or check wdfw.wa.gov for the current blind registration program.","Register for an assigned blind — registration opens before the season and popular spots go fast.","Set up your assigned blind with 12-24 mallard and widgeon decoys before first light.","Call with mallard hen sounds on the morning flight — birds are active from first light through 9am.","A retriever dog is very important — downed birds in flooded fields are extremely hard to find without one."],terrain:"Flooded agricultural fields and tidal sloughs. Waders required. Flat terrain.",bestTime:"October through December. November-December peak when migration birds arrive from Canada.",gear:["Chest waders","12 gauge non-toxic shot (#2 or #3 steel)","12-24 mallard decoys","Duck call","Assigned blind registration","Retriever dog strongly recommended"],warning:"The Skagit regulated blind program may have changed since this was written. Always contact WDFW Region 4 to confirm current program rules and registration requirements."}},

  // ── GOOSE — 4 more public ─────────────────────────────────────────────
  {id:"turnbull-geese",deer:"goose",name:"Turnbull NWR — Canada Geese",subname:"Spokane County — Public Goose",lat:47.4200,lng:-117.5700,place_id:"ChIJOdbxAUSGYlMRY9wapV66VhE",gmu:"Spokane County",publicLand:true,difficulty:"Beginner",region:"NE — Spokane County",summary:"Turnbull NWR holds Canada geese throughout its wetland complex and adjacent grain areas. The controlled hunt program registration gives public hunters access to excellent goose hunting near Spokane.",access:"From Cheney: Head south on Cheney-Plaza Rd to Turnbull NWR. Register with the hunt program at fws.gov/refuge/turnbull before the season.",how:{overview:"Turnbull NWR Canada geese use the wetland complex and surrounding grain fields. The controlled hunt program provides public hunters access to goose habitat just 15 miles from Spokane.",steps:["Register for the Turnbull NWR hunt program well before the season — registration fills up.","Set up a spread of 18-24 full-body Canada goose decoys on or near your assigned hunting area.","Call with standard Canada goose clucks and moans as birds approach.","Geese at Turnbull see some hunting pressure — be deliberate with your calling and concealment.","Combine goose hunting in the early morning with duck hunting on the NWR potholes in the same trip."],terrain:"Flat NWR wetland complex and surrounding fields. Easy terrain.",bestTime:"October through January. Resident Canada geese provide consistent hunting through the season.",gear:["12 gauge with BB non-toxic shot","18-24 full-body or shell decoys","Canada goose call","Layout blind or natural concealment","Turnbull NWR hunt program permit (free)","Dog for retrieval"],warning:"Advance registration is required for Turnbull NWR hunting. Do not show up without registering. Check fws.gov/refuge/turnbull for the current program."}},
  {id:"potholes-geese",deer:"goose",name:"Columbia Basin Wildlife Area — Geese",subname:"Grant County — Public Canada Goose",lat:47.1000,lng:-119.3000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Intermediate",region:"Central — Grant County",summary:"The Columbia Basin Wildlife Area public land borders grain fields used by Canada and white-fronted geese. Public goose hunting without needing farmer permission in WA's top goose county.",access:"From Moses Lake: Head west to Columbia Basin Wildlife Area units. Download WDFW map before going. Some units border actively farmed areas where geese feed.",how:{overview:"Grant County leads the state in goose harvest. The Columbia Basin Wildlife Area provides public land goose hunting without private land permission — a major advantage in WA's best goose county.",steps:["Download the WDFW Columbia Basin Wildlife Area map and find units adjacent to active grain fields.","Set up 24-36 full-body or shell decoys in a field or on the wildlife area land adjacent to grain.","Both Canada geese and specklebellies (white-fronted geese) use this area heavily in October-November.","Specklebelly calling requires a high-pitched yelping call — different from Canada goose honking.","Hunt early morning when geese fly from roost to feed — action can be fast and intense."],terrain:"Flat basin agricultural and wildlife area land. Easy terrain. Good road access.",bestTime:"October through January. White-fronted geese peak in October-November.",gear:["12 gauge with BB or BBB non-toxic shot","24-36 full-body or shell decoys","Canada and specklebelly calls","Layout blind or ground blind","Dog for retrieval"],warning:"Columbia Basin Wildlife Area goose hunting requires following specific unit rules. Download the current WDFW unit map and check for any goose-specific regulations."}},
  {id:"umatilla-geese",deer:"goose",name:"Umatilla National Wildlife Refuge",subname:"Benton-Franklin County — Public Geese",lat:45.9000,lng:-119.4000,place_id:"ChIJBQdD9witolQR46-P7-buLsI",gmu:"SE Columbia River Zone",publicLand:true,difficulty:"Beginner",region:"SE — Benton County",summary:"The Umatilla NWR along the OR-WA border provides excellent public goose hunting on the Columbia River. Canada geese and white-fronted geese use the refuge grain areas heavily.",access:"From Kennewick: Head east on SR-14 along the Columbia River toward Patterson and the Umatilla NWR. Refuge access roads are well-marked. Check fws.gov/refuge/umatilla for current hunt info.",how:{overview:"Umatilla NWR sits on the Columbia River and is a major Pacific Flyway staging area. Canada geese and white-fronted geese use the refuge grain areas heavily from October through January.",steps:["Check the Umatilla NWR hunt program at fws.gov/refuge/umatilla — some areas require special permits.","Set up decoys on the refuge lands open to hunting before first light.","Both Canada and white-fronted geese use the Umatilla area — bring calls for both species.","The Columbia River setting concentrates geese as they move along the flyway.","Hunting here combines well with mule deer hunting in the adjacent shrub-steppe GMUs."],terrain:"Flat Columbia River bottomland and shrub-steppe. Easy terrain. Good refuge roads.",bestTime:"October through January. White-fronted geese peak in October-November at Umatilla.",gear:["12 gauge with BB non-toxic shot","Full-body or shell decoys (24+)","Canada goose and specklebelly calls","Layout blind","Check if refuge permit required"],warning:"Umatilla NWR has specific hunt area regulations separate from general WA rules. Confirm open areas season dates and any permit requirements at fws.gov/refuge/umatilla before hunting."}},
  {id:"skagit-wdfw-geese",deer:"goose",name:"Skagit Wildlife Area — Goose Units",subname:"Skagit County — Registered Public Blinds",lat:48.4000,lng:-122.3000,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Skagit Valley",publicLand:true,difficulty:"Intermediate",region:"NW — Skagit County",summary:"WDFW Skagit Wildlife Area regulated units provide public goose hunting in WA's top western goose county. Register with WDFW Region 4 for access to prime Skagit Delta goose habitat.",access:"From Burlington: Head west toward Fir Island and the Skagit River delta. WDFW wildlife area parking areas are marked. Register with WDFW Region 4 (360-775-1311).",how:{overview:"The Skagit Wildlife Area regulated program gives public hunters structured access to prime goose habitat in Skagit County — WA's top western goose county at 5400 birds per year.",steps:["Contact WDFW Region 4 for current blind registration program details and availability.","Set up 36-48 full-body Canada goose decoys in your assigned area before first light.","Resident Canada geese here know their home territory — good concealment is essential.","Flag decoys and motion decoys improve realism for pressured Skagit Delta geese.","Mid-November through January brings the best hunting as migration birds join the resident population."],terrain:"Flat flooded agricultural delta land. Easy walking. Waders or rubber boots required.",bestTime:"October through January. November-December migration push is peak season.",gear:["12 gauge with BB non-toxic shot","Full-body decoys (36-48)","Canada goose call","Layout blind or vegetation blind","WDFW blind registration permit","Dog for retrieval"],warning:"The Skagit Wildlife Area regulated program requires advance registration. Contact WDFW Region 4 (360-775-1311) well before the season for current program details."}},

  // ── TEAL — 4 more public ──────────────────────────────────────────────
  {id:"yakima-teal",deer:"teal",name:"Yakima Valley Wetlands",subname:"Yakima Wildlife Area — Public Teal",lat:46.5000,lng:-120.2000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 335-371",publicLand:true,difficulty:"Beginner",region:"Central — Yakima County",summary:"The Yakima Valley small marshes and irrigation return ponds on WDFW land hold blue-winged and cinnamon teal in early September. Fast fun close-range public land teal hunting.",access:"From Ellensburg or Yakima: WDFW Yakima Wildlife Area has access points throughout the valley. Oak Creek Wildlife Area also provides public wetland access.",how:{overview:"Central Washington's irrigated Yakima Valley creates small wetlands on public WDFW land that hold teal in early September. Cinnamon teal are especially common here.",steps:["Scout WDFW Yakima Wildlife Area wetlands in late August for teal activity — look for birds on small ponds.","Set up 6-12 small teal decoys before first light on any public pond showing bird activity.","Cinnamon teal are common in the Yakima area — beautiful fast targets that decoy readily.","Blue-winged teal leave by mid-September while green-winged and cinnamon stay longer.","Combine teal hunting with an afternoon scouting trip for quail or chukar."],terrain:"Flat irrigated valley wetlands on public WDFW land. Easy terrain. Hip waders helpful.",bestTime:"September 1-15. Cinnamon and blue-winged teal peak in the first two weeks.",gear:["12 or 20 gauge with #6 steel non-toxic","6-12 teal decoys","Teal call","Hip waders or rubber boots","WA and Federal waterfowl licenses"],warning:"Confirm public land boundaries with OnX Hunt — some small wetlands in the Yakima Valley border private agricultural land."}},
  {id:"skagit-teal",deer:"teal",name:"Skagit Wildlife Area — Teal Season",subname:"Skagit County — Western WA Green-wing",lat:48.3500,lng:-122.4000,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Skagit Valley",publicLand:true,difficulty:"Intermediate",region:"NW — Skagit County",summary:"The Skagit Wildlife Area sloughs and marshes hold green-winged teal through fall. Unlike blue-wings green-wings stay into November making the Skagit a top late-season teal location.",access:"From Mount Vernon: Head west on Fir Island Rd toward the Skagit River delta. WDFW wildlife area parking areas are marked. Register with WDFW Region 4 for regulated areas.",how:{overview:"The Skagit is known for mallards but green-winged teal are abundant in its sloughs and marshes especially in October and November. Small decoy spreads in tight slough cover are most effective.",steps:["Green-winged teal are late migrants in the Skagit — unlike blue-wings they stay into November.","Set up 6-12 small teal decoys in a slough edge or marsh. Avoid large spreads in tight cover.","Green-wing teal whistle calls are different from blue-wing calls — bring both early in September.","Combine Skagit teal hunting with excellent mallard and widgeon hunting in the same morning.","WDFW regulated access areas for Skagit Wildlife Area — register with Region 4 if hunting those units."],terrain:"Flooded sloughs and tidal marshes. Waders required. Mostly flat terrain.",bestTime:"October through December for green-winged teal. Blue-winged earlier in September-October.",gear:["12 gauge with #4 or #6 steel non-toxic","6-12 teal and/or mallard decoys","Teal and mallard calls","Chest waders","WDFW access registration for regulated Skagit units"],warning:"Some Skagit Wildlife Area units require registration for regular season hunting. Contact WDFW Region 4 to confirm current regulated access requirements."}},
  {id:"umatilla-teal",deer:"teal",name:"Umatilla NWR — Early Teal Season",subname:"Benton County — Public Teal",lat:45.9000,lng:-119.4000,place_id:"ChIJBQdD9witolQR46-P7-buLsI",gmu:"SE Columbia River Zone",publicLand:true,difficulty:"Beginner",region:"SE — Benton County",summary:"Umatilla NWR provides public land early teal season hunting on the Columbia River. The refuge wetlands hold blue-winged and cinnamon teal in September with easy public access.",access:"From Kennewick: Head east on SR-14 along the Columbia River to Umatilla NWR. Check fws.gov/refuge/umatilla for early teal season access and any permit requirements.",how:{overview:"Umatilla NWR on the Columbia River is a major migration stopover for teal in September. The refuge wetlands provide public teal hunting with easy access from the Tri-Cities area.",steps:["Check the refuge early teal season at fws.gov/refuge/umatilla — confirm open areas and dates.","Set up 6-12 teal decoys on any refuge pond or wetland before first light.","Blue-winged and cinnamon teal both use the Umatilla area in September before migrating south.","The Columbia River setting concentrates migrating teal — peak action is September 1-10.","Combine with early goose or dove hunting in the same SE Washington trip."],terrain:"Flat Columbia River bottomland. Easy terrain. Refuge roads are well-maintained.",bestTime:"September 1-15 for early teal season. Blue-winged teal peak first week of September.",gear:["12 or 20 gauge with #6 steel non-toxic","6-12 teal decoys","Teal whistle call","Hip waders or rubber boots","WA and Federal waterfowl licenses","Check if refuge permit required"],warning:"Umatilla NWR has specific hunt area regulations. Confirm open areas and any permit requirements at fws.gov/refuge/umatilla before hunting."}},
  {id:"desert-wa-teal",deer:"teal",name:"Desert Wildlife Area and BLM Ponds",subname:"Benton-Grant County — Public Potholes",lat:46.8000,lng:-119.5000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",region:"Central — Grant County",summary:"BLM and WDFW public ponds throughout the Columbia Basin shrub-steppe hold teal on September 1. Find a pothole away from the crowds at Potholes State Park for a more solitary early season experience.",access:"From Moses Lake or Kennewick: Explore BLM public land roads in the Columbia Basin looking for isolated potholes. Use OnX Hunt to identify public water.",how:{overview:"Away from the crowds at the famous Potholes area there are hundreds of smaller BLM and WDFW potholes throughout the Columbia Basin that hold teal in September. Less competition more birds.",steps:["Use OnX Hunt to find BLM and WDFW potholes well away from Potholes State Park — less competition.","Small isolated potholes often hold 5-20 teal that have never been hunted.","Scout these potholes by vehicle the evening before season — drive BLM roads looking for birds.","Set up a very small spread of 4-8 decoys — big spreads are overkill on small water.","Move between potholes through the morning as birds migrate between small water bodies."],terrain:"Flat desert shrub-steppe with scattered potholes. Easy terrain. BLM roads required for access.",bestTime:"September 1-10. Isolated BLM potholes have much less competition than Potholes State Park.",gear:["12 or 20 gauge with #6 steel non-toxic","4-8 small teal decoys","Teal whistle","Hip waders","OnX Hunt to confirm BLM public water","WA and Federal waterfowl licenses"],warning:"Confirm potholes are on BLM or WDFW public land before hunting. Some potholes in the Columbia Basin are on private land. Never hunt water without confirming public access."}},

  // ── SNOW GOOSE — 4 more public ────────────────────────────────────────
  {id:"skagit-snow-regular",deer:"snow-goose",name:"Skagit Delta — Regular Season Snows",subname:"Skagit County — Nov-Jan Standard Rules",lat:48.3500,lng:-122.4000,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Skagit Valley",publicLand:true,difficulty:"Intermediate",region:"NW — Skagit County",summary:"The Skagit Delta hosts spectacular snow geese November through January. Regular season rules apply before Feb 1 — no electronic calls. WDFW Skagit Wildlife Area provides public access.",access:"From Mount Vernon: Head west on Fir Island Rd to the Skagit Wildlife Area. WDFW parking areas are marked. Register with WDFW Region 4 for regulated blind access.",how:{overview:"The Skagit Valley winter snow goose concentration is spectacular. During the regular season (October-January) standard hunting rules apply — large decoy spreads and goose calls without electronics.",steps:["Register with WDFW Region 4 for Skagit Wildlife Area blind access during snow goose season.","Set up 150-300 white shell or sock decoys on the active field before first light.","During regular season no electronic calls — use snow goose calls with high-pitched yelping.","Layout blinds with white covers are essential — snow geese have exceptional eyesight.","The late regular season (December-January) before the conservation order is prime time."],terrain:"Flat delta agricultural and wildlife area land. Easy walking. Waders or rubber boots.",bestTime:"November through January for regular season. Best hunting in December-January.",gear:["12 gauge with BB non-toxic shot","150-300 white decoys (socks or shells)","Snow goose yelping call (no electronics in regular season)","White camo layout blind","WDFW registration for Skagit Wildlife Area"],warning:"Electronic calls are NOT legal during the regular season — they are only legal during the spring Light Goose Conservation Order (February 1 onward). Violations carry significant fines."}},
  {id:"columbia-basin-snow-spring",deer:"snow-goose",name:"Columbia Basin — Spring Conservation Order",subname:"Grant County — No Bag Limit Hunt",lat:47.1000,lng:-119.0000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",region:"Central — Grant County",summary:"The spring Light Goose Conservation Order (February 1 - April 30) has no bag limit and electronic calls are LEGAL. Huge flocks of snow geese stage in the Columbia Basin. The most liberal hunting rules in WA.",access:"From Moses Lake: Drive Columbia Basin Wildlife Area roads and surrounding BLM land in late February-March looking for staging snow geese. Public land is abundant throughout the basin.",how:{overview:"The spring conservation order for light geese has extremely liberal rules because snow goose populations have exploded and are damaging Arctic nesting habitat. WDFW wants hunters to take as many as possible.",steps:["Scout the Columbia Basin in late February-early March for massive white flocks staging on agricultural fields and reservoir edges.","Set up 200-500 rag or shell decoys before dawn — bigger spreads are far more effective.","Electronic callers are LEGAL during conservation order — use feeding and landing sounds.","Full camo or white coveralls are essential — snow geese have exceptional eyesight.","Shoot continuously as birds make multiple passes — they will try to land repeatedly in a large spread."],terrain:"Flat basin agricultural and wildlife area land. Easy terrain.",bestTime:"Late February through early April as snow geese stage before flying north to the Arctic.",gear:["White coveralls or full camo","200-500 decoys — more is always better","Electronic caller (LEGAL during conservation order only)","12 gauge with BB or BBB non-toxic steel","Layout blind with white cover"],warning:"Electronic calls are ONLY legal during the spring Light Goose Conservation Order (Feb 1+). They are ILLEGAL during the regular waterfowl season. Unplugged shotguns also legal during conservation order only."}},
  {id:"whatcom-snow-spring",deer:"snow-goose",name:"Nooksack River Valley — Spring Order",subname:"Whatcom County — Spring Conservation Hunt",lat:48.7000,lng:-122.3000,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Whatcom County",publicLand:true,difficulty:"Intermediate",region:"NW — Whatcom County",summary:"Whatcom County's Nooksack River valley holds snow geese through winter with public access on WDFW and BLM lands along the river corridor during the spring conservation order.",access:"From Bellingham: Head east on SR-542 (Mount Baker Hwy) into the Nooksack River valley. WDFW public access areas exist along the river corridor.",how:{overview:"The Nooksack Valley in Whatcom County provides public land access to snow goose habitat during the spring conservation order. Birds move between the Skagit Valley and Whatcom County regularly.",steps:["Find WDFW public access areas along the Nooksack River corridor using OnX Hunt.","Set up 150-300 white decoys on public land near active snow goose feeding areas.","Electronic callers are legal during the conservation order — use feeding calls.","Birds in the Nooksack Valley may be less concentrated than the Skagit Delta but hunting pressure is lower.","The Nooksack River WDFW access areas provide legal hunting without private land permission."],terrain:"Flat river valley agricultural and flood plain. Easy walking. Waders helpful near the river.",bestTime:"February through early April during the spring Light Goose Conservation Order.",gear:["White camo or coveralls","150-300 white decoys","Electronic caller (legal during conservation order)","12 gauge with BB non-toxic shot","Layout blind","WDFW Nooksack River access map"],warning:"Conservation order rules apply — electronic calls and unplugged shotguns legal during the conservation order period only. Regular season rules apply before February 1."}},
  {id:"columbia-skagit-winter-snow",deer:"snow-goose",name:"Skagit Delta — Spring Conservation Order",subname:"Skagit County — Best WA Snow Goose Hunt",lat:48.3000,lng:-122.5000,place_id:"ChIJ1dNt8JFjkFQRZdDqYWsxCOQ",gmu:"Skagit Valley",publicLand:true,difficulty:"Intermediate",region:"NW — Skagit County",summary:"The Skagit Delta spring conservation order hunt is arguably the best light goose hunting in the Pacific Northwest. Tens of thousands of snow geese stage here February through April with no bag limit.",access:"From Mount Vernon: Head west toward Fir Island and the Skagit River delta. WDFW wildlife area provides some public access. Scout from roads in late February to find active flocks.",how:{overview:"The Skagit Delta spring conservation order hunt is a world-class experience. No bag limit electronic calls legal unplugged shotguns legal. Enormous flocks of snow geese provide incredible shooting.",steps:["Scout the Fir Island and Conway areas in late February for massive white flocks — they are unmissable.","Find public land access using OnX Hunt or use WDFW Skagit Wildlife Area units.","Set up 300-500+ white rag or sock decoys with your layout blind hidden among them.","Electronic callers are legal — use high-quality snow goose feeding and landing call sequences.","Snow geese will make multiple passes over a large spread. Shoot until they stop coming."],terrain:"Flat flooded delta agricultural land. Easy walking. Waders required.",bestTime:"February through early April. Peak concentrations in mid-February to mid-March.",gear:["White coveralls or full ghillie suit","300-500+ white rag or sock decoys","Quality electronic caller with remote","12 gauge with BB or BBB non-toxic steel and multiple shells","White layout blind"],warning:"This is the Skagit Delta at its peak birding season — expect other hunters field scouts and birdwatchers. Respect WDFW boundaries and obtain permission for any private field access."}},

  // ── BRANT — 4 more public ─────────────────────────────────────────────
  {id:"dungeness-brant",deer:"brant",name:"Dungeness Bay",subname:"Clallam County — Olympic Peninsula",lat:48.1500,lng:-123.1500,place_id:"ChIJoyYMj417jlQRWV9OUIXMgJs",gmu:"Coastal Zone",publicLand:true,difficulty:"Intermediate",region:"NW — Clallam County",summary:"Dungeness Bay near Sequim is a premier WA brant location. The bay eelgrass beds hold brant October through January. Small boat hunting over floating decoys on tidal flats is most effective.",access:"From Sequim: Head north on Kitchen-Dick Rd to the Dungeness NWR area. Boat launch at Cline Spit county park. The bay is easily accessible from the Olympic Peninsula.",how:{overview:"Dungeness Bay is one of Washington's most productive brant locations. The protected bay with extensive eelgrass beds attracts brant from throughout the Pacific Flyway.",steps:["A small boat is essential for the best Dungeness brant hunting — shore access is limited.","Scout from the shore at low tide to find active eelgrass beds with brant feeding.","Set up 6-12 brant or small goose decoys at the water edge on the incoming tide.","Brant fly at low altitude following eelgrass beds — be ready for quick shots.","The Dungeness NWR portion is closed to hunting — hunt the adjacent county park tidal area only."],terrain:"Protected bay with tidal flats. Small boat recommended. Cold water conditions.",bestTime:"October through January. Peak brant concentrations in November-December.",gear:["Small seaworthy boat or kayak","Waders or drysuit","6-12 brant decoys","12 gauge with #2 or #3 non-toxic shot","Tide chart","WA and Federal waterfowl licenses"],warning:"The Dungeness NWR is closed to hunting. Hunt outside the NWR boundaries only — confirm boundaries before setting up. Brant bag limits are very limited (typically 2 per day)."}},
  {id:"hood-canal-brant",deer:"brant",name:"Hood Canal Tidal Flats",subname:"Mason-Kitsap County — South Puget Sound",lat:47.4500,lng:-122.9000,place_id:"ChIJp8OQKwHHk1QRoh_arfwe3gk",gmu:"Puget Sound Zone",publicLand:true,difficulty:"Intermediate",region:"NW — Mason County",summary:"Hood Canal holds brant along its eelgrass-lined tidal flats. Public tidal land provides shore hunting opportunities from several county parks and public boat launches.",access:"From Belfair or Shelton: Explore the Hood Canal shore road (SR-106 and SR-3) looking for brant concentrations on the tidal flats. County parks provide public tidal land access.",how:{overview:"Hood Canal is a long narrow fjord-like inlet with extensive eelgrass beds that attract brant during migration. Public tidal land provides hunting access at several points along the canal.",steps:["Scout the Hood Canal shore road in late October-November for brant feeding on tidal flats.","Public tidal land (below the mean high water mark) is public in Washington — access is legal.","Set up 6-12 floating brant decoys at the edge of active eelgrass beds.","Brant typically fly along the canal at low altitude — lead them generously.","Incoming tides are the most productive as birds move onto freshly covered eelgrass."],terrain:"Tidal flats and canal shores. Shore hunting possible from public tidal land. Waders essential.",bestTime:"October through January. Peak concentrations during fall migration in November.",gear:["Chest waders or drysuit","6-12 brant or small goose decoys","12 gauge with #2 non-toxic shot","Tide chart (critical)","WA and Federal waterfowl licenses"],warning:"Bag limits for brant are very limited — typically 2 per day. Confirm current limits at wdfw.wa.gov. The narrow Hood Canal can have strong currents — exercise caution in tidal areas."}},
  {id:"grays-harbor-brant",deer:"brant",name:"Grays Harbor Bay",subname:"Grays Harbor County — Pacific Coast",lat:46.9500,lng:-124.0000,place_id:"ChIJp8OQKwHHk1QRoh_arfwe3gk",gmu:"Coastal Zone",publicLand:true,difficulty:"Advanced",region:"SW — Grays Harbor",summary:"Grays Harbor on the Pacific Coast hosts brant during fall migration. Less pressure than Puget Sound with good numbers in October-November. A seaworthy boat is essential.",access:"From Westport or Aberdeen: Access the bay by boat from the Westport Marina or Hoquiam boat launch. The outer harbor has extensive eelgrass beds accessible by boat.",how:{overview:"Grays Harbor is part of the outer Pacific Coast migration corridor for brant. Birds use eelgrass beds extensively in October and November. Very few hunters make the effort here.",steps:["A seaworthy boat is essential for Grays Harbor brant hunting — the bay can be very rough.","Check marine weather carefully before going — Grays Harbor is exposed to Pacific swells.","Set up on protected inner bay eelgrass beds on incoming tides.","Brant use Grays Harbor as a staging area on migration — concentrations can be excellent for a few days.","Combine brant hunting with Pacific Coast surf scoter and other sea duck hunting."],terrain:"Pacific coastal bay. Boat essential. Exposed to Pacific weather — conditions can be rough.",bestTime:"October through November during peak Pacific coast migration.",gear:["Seaworthy boat with safety gear — mandatory","Dry suit or heavy waders","6-12 brant decoys","12 gauge with #2 non-toxic shot","Marine weather radio","WA and Federal waterfowl licenses"],warning:"Grays Harbor can be DANGEROUS in Pacific storms. Never hunt here without checking marine weather first. A capsized boat in cold Pacific water is life-threatening."}},
  {id:"sequim-bay-brant",deer:"brant",name:"Sequim Bay State Park",subname:"Clallam County — Protected Inner Bay",lat:48.0800,lng:-123.0300,place_id:"ChIJoyYMj417jlQRWV9OUIXMgJs",gmu:"Coastal Zone",publicLand:true,difficulty:"Intermediate",region:"NW — Clallam County",summary:"Sequim Bay is a protected inner bay on the Olympic Peninsula with excellent eelgrass habitat for brant. The state park provides public shore access making this the most accessible WA brant hunting.",access:"From Sequim: Head east on US-101 about 5 miles to Sequim Bay State Park. Boat launch available at the park. Public tidal land access along the shore.",how:{overview:"Sequim Bay is one of the most sheltered and accessible brant hunting locations in Washington. The protected bay with excellent eelgrass habitat draws brant through the winter migration season.",steps:["Scout from the state park boat launch dock for brant activity on the bay.","A small boat or kayak is helpful but shore hunting from public tidal land is possible.","Set up 6-12 floating brant or small goose decoys at the eelgrass bed edge.","Brant in the protected inner bay are somewhat less wary than birds on exposed Puget Sound.","Hunt on incoming tides when birds are actively moving onto fresh eelgrass."],terrain:"Protected inner bay. Shore access possible from state park public tidal land. Easy terrain.",bestTime:"October through January. Sequim Bay is one of the milder and most consistent brant locations in WA.",gear:["Small boat or kayak (recommended but not essential)","Waders","6-12 brant decoys","12 gauge with #2 or #3 non-toxic shot","Tide chart","WA and Federal waterfowl licenses"],warning:"Brant bag limits are very limited — typically 2 per day. Confirm current regulations at wdfw.wa.gov before hunting Sequim Bay."}},

  // ── RABBIT — 4 more public ────────────────────────────────────────────
  {id:"l-t-murray-rabbit",deer:"rabbit",name:"L.T. Murray Wildlife Area",subname:"Yakima County — Sagebrush Cottontail",lat:46.8500,lng:-120.5000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMUs 335-372",publicLand:true,difficulty:"Beginner",region:"Central — Yakima County",summary:"The massive L.T. Murray Wildlife Area (100000+ acres) holds excellent cottontail populations in its sagebrush and shrubby draws. Year-round hunting with no bag limit on a huge public land area.",access:"From Ellensburg or Yakima: Multiple access points throughout the L.T. Murray Wildlife Area off SR-10 and SR-821. Green Dot permit required for interior vehicle roads.",how:{overview:"The L.T. Murray Wildlife Area is enormous and holds cottontail rabbits throughout its sagebrush and brushy draw habitat. Year-round hunting with no bag limit and excellent public access.",steps:["Drive the Green Dot roads slowly looking for rabbits near brushy draws and sagebrush clumps.","Walk the brushy draws and coulee edges — cottontails hide in the dense shrubby cover.","Kick brush piles and dense shrubs — rabbits hold very tight and flush at close range.","A beagle dog is very helpful — rabbits circle predictably when pushed by a dog.","Combine rabbit hunting with chukar or quail hunting on the same L.T. Murray trip."],terrain:"Open sagebrush and shrubby draws. Easy terrain. Green Dot road vehicle access.",bestTime:"Year-round. Best November through February when vegetation is down.",gear:["20 gauge with #6 shot or .22 LR rifle","Dog (beagle) is ideal","Hunter orange recommended","Green Dot Road permit (free from WDFW Yakima office)","Water — dry country"],warning:"Green Dot Road permit is required for vehicle access to interior roads. Get the free permit from the WDFW Yakima office before your trip."}},
  {id:"umatilla-rabbit",deer:"rabbit",name:"Umatilla National Wildlife Refuge",subname:"SE Washington — Cottonail Along the Columbia",lat:45.9000,lng:-119.4000,place_id:"ChIJBQdD9witolQR46-P7-buLsI",gmu:"SE Columbia River Zone",publicLand:true,difficulty:"Beginner",region:"SE — Benton County",summary:"The Umatilla NWR shrub-steppe and brushy margins along the Columbia River hold excellent cottontail populations. Year-round hunting provides a great winter option after duck season.",access:"From Kennewick: Head east on SR-14 along the Columbia River to Umatilla NWR. Check fws.gov/refuge/umatilla for current access and hunt program.",how:{overview:"Umatilla NWR's brushy shrub-steppe margins hold cottonail rabbits year-round. A great fall and winter small game option in the same area as excellent duck and goose hunting.",steps:["Check the Umatilla NWR small game hunting program at fws.gov/refuge/umatilla.","Hunt the brushy margins and shrubby draws throughout the open refuge areas.","Cottontails at Umatilla concentrate near any water source or dense brush patch.","Walk slowly through sagebrush and brush clumps — rabbits flush at very close range.","Combine rabbit hunting with duck scouting or late season waterfowl hunting on the same trip."],terrain:"Flat shrub-steppe along the Columbia River. Easy terrain. Refuge roads accessible.",bestTime:"Year-round. Best November through March when vegetation is down and rabbits are more visible.",gear:["20 gauge with #6 shot or .22 LR rifle","Good walking shoes","No orange required unless big game season is concurrent","Water","Check if NWR small game permit required"],warning:"Umatilla NWR small game hunting may require a refuge access permit. Check fws.gov/refuge/umatilla before visiting."}},
  {id:"colockum-rabbit",deer:"rabbit",name:"Colockum Wildlife Area",subname:"Kittitas County — Shrub-steppe Cottontail",lat:47.2500,lng:-120.2500,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMUs 328-337",publicLand:true,difficulty:"Beginner",region:"Central — Kittitas County",summary:"The Colockum Wildlife Area's sagebrush and shrub-steppe holds good cottontail populations year-round. An excellent mixed-bag hunt combining rabbits with quail HUN and mule deer.",access:"From Ellensburg: Head north on Reecer Creek Rd to the Colockum Wildlife Area. Multiple access points with the Green Dot road system.",how:{overview:"The Colockum Wildlife Area offers cottontail rabbit hunting in its sagebrush and shrubby draw habitat. Combine with quail HUN and mule deer hunting for a great mixed-bag central WA trip.",steps:["Hunt the brushy draws and shrubby margins throughout the Colockum Wildlife Area.","Walk slowly through sagebrush patches — cottontails sit tight and flush at close range.","A dog is very helpful — cottontails in open country can run fast when not pushed by a dog.","Combine rabbit hunting with quail and HUN hunting in the morning and evening.","Green Dot roads provide vehicle access to most productive rabbit areas."],terrain:"Open sagebrush and shrubby draws. Easy terrain. Green Dot road access.",bestTime:"Year-round. Best in fall and winter when brush is thinner and rabbits are more visible.",gear:["20 gauge with #6 shot or .22 LR","Dog is helpful","Hunter orange during concurrent deer season","Green Dot Road permit (free from WDFW Yakima office)","Water"],warning:"Green Dot Road permit required for vehicle access to interior Colockum roads. Colockum straddles multiple GMUs — confirm you are in the correct GMU for any concurrent big game season."}},
  {id:"wdfw-access-rabbits",deer:"rabbit",name:"WDFW Access Program Lands",subname:"Eastern WA Statewide — Ask Locally",lat:47.0000,lng:-119.0000,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Eastern WA Statewide",publicLand:true,difficulty:"Beginner",region:"Central — Multi-county",summary:"WDFW's Open Space Habitat Program has enrolled thousands of acres of private land in eastern WA for public hunting access including cottontail rabbit hunting. Ask at local WDFW offices for maps.",access:"Contact your local WDFW regional office or visit wdfw.wa.gov/hunting/access for a list of currently enrolled Open Space Habitat Program parcels near your location.",how:{overview:"WDFW's Open Space Habitat Program provides public hunting access on enrolled private lands throughout eastern Washington. These lands often include excellent cottontail rabbit habitat in agricultural and shrub-steppe settings.",steps:["Download the WDFW Open Space Habitat Program map at wdfw.wa.gov — it shows all enrolled public access parcels.","Find parcels near your target area — many include brushy agricultural edges ideal for cottontails.","These lands are private but enrolled for public hunting — no additional permission is needed.","Hunt the brushy draws and field edges on enrolled parcels the same way you would other public land.","Respect the enrolled land carefully — these are private landowners who have voluntarily opened their land."],terrain:"Varies widely by parcel — from flat agricultural edges to rolling shrub-steppe. Generally easy.",bestTime:"Year-round. Best fall through winter.",gear:["20 gauge with #6 shot or .22 LR","Dog helpful","Hunter orange when concurrent big game season is open","WDFW Open Space Habitat Program map","Water"],warning:"Respect WDFW Open Space Habitat Program land carefully. These are private landowners who chose to allow public hunting — please leave the land as you found it and follow all posted rules."}},

  // ── SQUIRREL — 4 more public ──────────────────────────────────────────
  {id:"okanogan-squirrel",deer:"squirrel",name:"Okanogan Highlands Oak-Pine Forests",subname:"Okanogan County — Western Gray Squirrel",lat:48.5000,lng:-119.3000,place_id:"ChIJPRueGV7XnFQRyWDBGynPyoo",gmu:"Okanogan County",publicLand:true,difficulty:"Beginner",region:"NE — Okanogan County",summary:"Okanogan County oak and ponderosa pine forests hold excellent western gray squirrel populations on public DNR and USFS land. September through December season with a bag limit of 3 per day.",access:"From Tonasket or Oroville: Head into the lower elevation oak and pine timber on DNR and Forest Service land. Extensive public land access throughout the county.",how:{overview:"The Okanogan Highlands provide prime western gray squirrel habitat in their oak and ponderosa pine forests. A morning squirrel hunt precedes an afternoon grouse or chukar outing perfectly.",steps:["Focus on oak trees with full acorn crops — squirrels concentrate where food is most abundant in fall.","Arrive at first light and sit quietly under productive trees — squirrels are most active early.","Western gray squirrels can be surprisingly wary — move quietly and avoid sudden movements.","Look for cut cones and fresh nut shells on the ground under trees to find active feeding areas.","A .22 LR with head shots is most effective and preserves the meat perfectly."],terrain:"Lower elevation oak and ponderosa pine forest. Easy walking. Good public land access.",bestTime:"September through December during the regulated western gray squirrel season.",gear:[".22 LR rifle with scope or 20 gauge","Good walking boots","No orange required unless deer firearm season is open","Small game license","Water"],warning:"Western Gray Squirrel season is September 1 - December 31 with a 3-bird daily bag limit. Douglas Squirrel (chickaree) is year-round with no bag limit."}},
  {id:"gifford-pinchot-squirrel",deer:"squirrel",name:"Gifford Pinchot National Forest",subname:"Lewis-Skamania County — Douglas Squirrel",lat:46.1000,lng:-121.7000,place_id:"ChIJp8OQKwHHk1QRoh_arfwe3gk",gmu:"SW Cascades",publicLand:true,difficulty:"Beginner",region:"SW — Lewis County",summary:"The Gifford Pinchot National Forest holds abundant Douglas squirrels (chickarees) in its mature conifer forests. Year-round hunting with no bag limit makes this a great all-season small game option.",access:"From Randle or Packwood: Head south on US-12 or Forest Road 23 into the Gifford Pinchot National Forest. USFS roads provide access throughout the forest.",how:{overview:"Douglas squirrels are incredibly abundant in the Gifford Pinchot's mature fir and hemlock forests. Their loud chattering call makes them one of the easiest small game animals to locate in WA.",steps:["Listen for the loud buzzing chatter call — Douglas squirrels vocalize constantly and are easy to find.","Hunt under mature Douglas fir and hemlock — these are the squirrels primary food trees.","A .22 LR with subsonic ammunition is ideal — quiet and accurate for close shots.","Fresh cone debris scattered beneath a tree indicates active squirrel feeding overhead.","Douglas squirrel hunting combines perfectly with grouse hunting in the same forest areas."],terrain:"Mature conifer forest. Easy to moderate walking. USFS roads provide vehicle access.",bestTime:"Year-round but fall through winter is best when squirrels are most active caching food.",gear:[".22 LR rifle (subsonic ammo preferred)","Good waterproof boots","Rain gear — western WA is wet","No hunter orange required for squirrel","Small game license"],warning:"Douglas squirrel (chickaree) is year-round with no bag limit. Do not confuse with the western gray squirrel which has a regulated season (September 1 - December 31) and 3-bird bag limit."}},
  {id:"wenatchee-squirrel",deer:"squirrel",name:"Wenatchee National Forest",subname:"Chelan-Kittitas County — Both Species",lat:47.5000,lng:-120.8000,place_id:"ChIJDdPHo9PTnFQRRqUm89U2VYQ",gmu:"NC — Chelan County",publicLand:true,difficulty:"Beginner",region:"NC — Chelan County",summary:"The Wenatchee National Forest provides access to both western gray squirrels (lower pine zone) and Douglas squirrels (upper fir zone) on excellent public land in the eastern Cascades.",access:"From Leavenworth or Wenatchee: Head into the Wenatchee National Forest on any of the forest roads. The pine-to-fir transition zone between 2000-4000 feet elevation is most productive.",how:{overview:"Chelan County eastern Cascade forests provide access to both squirrel species. The transition zone between ponderosa pine (western gray) and mixed conifer (Douglas squirrel) is the most productive area.",steps:["Target the mixed pine-fir transition zone between 2000-4000 feet elevation.","Western gray squirrels are more common in the lower ponderosa pine areas below 3000 feet.","Douglas squirrels are abundant throughout the higher fir and hemlock forest above 3500 feet.","Forest roads provide excellent access throughout the Wenatchee National Forest.","Fall squirrel hunting combines well with early mule deer archery hunting in the same area."],terrain:"Mixed conifer forest on moderate terrain. Good forest road access.",bestTime:"September through December for western gray (regulated). Year-round for Douglas squirrel.",gear:[".22 LR rifle","Small game license","Good boots","Rain gear for western slopes","Hunter orange if during concurrent big game season"],warning:"Check whether any deer or elk firearm seasons are open before squirrel hunting in Chelan County — wear hunter orange during any concurrent firearm season."}},
  {id:"okanogan-wenatchee-squirrel",deer:"squirrel",name:"Okanogan-Wenatchee National Forest",subname:"North Cascades Foothills — Western Gray",lat:48.2000,lng:-120.5000,place_id:"ChIJDdPHo9PTnFQRRqUm89U2VYQ",gmu:"North Cascades",publicLand:true,difficulty:"Beginner",region:"NC — Okanogan County",summary:"The lower elevation ponderosa pine and oak forests of the Okanogan-Wenatchee National Forest hold excellent western gray squirrel populations. Combine with blue grouse hunting for a great September outing.",access:"From Twisp or Winthrop: Head into the lower elevation pine and oak timber on Okanogan-Wenatchee National Forest roads. Download Gaia GPS offline before going.",how:{overview:"The Methow Valley foothills of the Okanogan-Wenatchee National Forest provide prime western gray squirrel habitat in their oak and ponderosa pine forests.",steps:["Drive forest roads slowly looking for productive oak and pine trees with heavy nut crops.","Sit quietly under productive trees at first light — squirrels feed intensively in the morning hours.","Listen for the distinctive chattering alarm call of western gray squirrels to locate active individuals.","A .22 LR with head shots is the preferred method — minimal meat damage and low noise.","Combine with blue grouse hunting higher up in the fir and subalpine forest on the same day."],terrain:"Lower elevation ponderosa pine and oak. Easy walking. Good USFS road access.",bestTime:"September through December during regulated western gray squirrel season.",gear:[".22 LR rifle with scope","Good walking boots","No orange required unless deer season is open","Small game license","Downloaded offline Gaia GPS maps"],warning:"Okanogan-Wenatchee NF roads can be gated or washed out in early fall. Check USFS website for current road conditions before going."}},

  // ── BOBCAT — 4 more public ────────────────────────────────────────────
  {id:"klickitat-bobcat",deer:"bobcat",name:"Klickitat County Canyon Country",subname:"South-Central WA — Predator Calling",lat:45.8500,lng:-120.6000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 382",publicLand:true,difficulty:"Intermediate",region:"SC — Klickitat County",summary:"The rocky canyon country of Klickitat County holds bobcats in its rimrock and brushy draws. Predator calling at canyon edges at dawn produces results and hunting pressure here is very low.",access:"From Goldendale: Explore the canyon roads and BLM access areas south and east. Rocky rimrock country near the Columbia River Gorge is prime bobcat habitat on public BLM land.",how:{overview:"Klickitat County's diverse canyon terrain with rocky rimrock and brushy draws is classic bobcat habitat. Animals here are lightly pressured compared to NE Washington and very willing to respond to calls.",steps:["Set up on a rocky canyon rim at first light facing downwind into the canyon.","Use rabbit distress calls — bobcats in canyon country respond very aggressively.","Look for bobcat sign: tracks in sandy canyon wash bottoms and scat on prominent rocks.","Canyon terrain can produce fast close encounters — have your rifle ready when calling.","BLM land throughout the Klickitat canyon country provides extensive public hunting access."],terrain:"Rocky canyon terrain. Moderate with some steep areas. BLM public access.",bestTime:"November through February when bobcats are most active and furbearers are in prime condition.",gear:[".223 or .243 rifle for longer shots","Mouth or electronic distress call","Earth-tone camo — bobcats have excellent eyesight","BLM map for public access","Good boots for rocky terrain"],warning:"Klickitat County bobcat hunting is underutilized — very low hunting pressure. Harvest quota applies statewide — check current quota status at wdfw.wa.gov before hunting."}},
  {id:"yakima-bobcat",deer:"bobcat",name:"L.T. Murray and Oak Creek Wildlife Areas",subname:"Yakima County — Public Bobcat Access",lat:46.6000,lng:-120.3000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 335-371",publicLand:true,difficulty:"Intermediate",region:"Central — Yakima County",summary:"Yakima County's large public WDFW wildlife areas hold a healthy bobcat population. Predator calling on the open ridges and rocky hillsides produces year after year — no private land permission needed.",access:"From Yakima or Ellensburg: The L.T. Murray Oak Creek and Wenas Wildlife Areas all provide public bobcat hunting access. Green Dot permit required for L.T. Murray interior roads.",how:{overview:"Yakima County has one of WA's better accessible bobcat populations on public land. The large WDFW wildlife areas give predator callers access to prime bobcat habitat without needing permission.",steps:["Set up at a rocky hillside or timber edge facing into the wind 30 minutes before first light.","Rabbit distress calls work well in the Yakima open country.","The L.T. Murray Wildlife Area has extensive rocky hillside habitat that bobcats use heavily.","Snow tracking after fresh snowfall is extremely effective — follow tracks directly to bedded animals.","Multiple setups per morning are key — move 500+ yards between each 20-minute calling session."],terrain:"Shrub-steppe to pine timber on WDFW wildlife areas. Easy to moderate terrain.",bestTime:"November through February. Snow tracking after fresh snowfall is the most productive method.",gear:[".223 or .243 rifle","Electronic or mouth call","White camo in snow conditions","Good insulated boots","Hunter orange not required for predator hunting"],warning:"Yakima County bobcat hunting on WDFW lands does not require landowner permission — a major advantage. Harvest quota applies statewide. Check current quota at wdfw.wa.gov."}},
  {id:"umatilla-forest-bobcat",deer:"bobcat",name:"Umatilla National Forest",subname:"Blue Mountains — SE Washington",lat:46.3000,lng:-117.9000,place_id:"ChIJuzjzPosCo1QRAbus3O4Sp9U",gmu:"GMUs 145-149",publicLand:true,difficulty:"Intermediate",region:"SE — Blue Mountains",summary:"The Blue Mountains of Umatilla National Forest hold good bobcat populations in their timbered draws and rocky ridges. Predator calling on forest edges and road cuts at dawn produces well.",access:"From Dayton: Head south on US-12 into the Umatilla National Forest. Forest Service roads provide access throughout. Download Gaia GPS or Avenza Maps offline — no cell service.",how:{overview:"The Blue Mountains Umatilla National Forest holds bobcats in its diverse terrain of rocky ridges timbered draws and open parks. Remote hunting with excellent public land access.",steps:["Set up at forest openings and road cuts that provide good visibility in multiple directions.","Use louder calls than open country — sound carries less in timber.","Blue Mountains bobcats are experienced at exploiting the diverse terrain — be ready for approaches from any direction.","Snow tracking after winter storms is very effective — fresh tracks on forest roads are easy to follow.","Combine bobcat hunting with post-season mule deer scouting or grouse hunting on the same trip."],terrain:"Steep timbered ridges and rocky draws. Moderate terrain. Forest Service road access.",bestTime:"December through February. Snow makes tracking dramatically more effective.",gear:[".223 rifle","Mouth or electronic caller","White or camo depending on conditions","Downloaded offline topo maps — no cell service","Good insulated boots for winter conditions"],warning:"The Blue Mountains receive significant snowfall starting in November. Higher Forest Service roads may be closed by snow — check conditions before going. Harvest quota applies statewide."}},
  {id:"colville-bobcat",deer:"bobcat",name:"Colville National Forest",subname:"Stevens County — NE Washington",lat:48.5000,lng:-117.8000,place_id:"ChIJOdbxAUSGYlMRY9wapV66VhE",gmu:"GMUs 117-124",publicLand:true,difficulty:"Intermediate",region:"NE — Stevens County",summary:"The Colville National Forest holds WA's best bobcat densities in its dense NE Washington timber. Combine calling with snow tracking for the most productive winter bobcat hunting available.",access:"From Colville: Forest HQ on S Main St. Extensive forest road network — download Avenza Maps offline before going.",how:{overview:"Stevens County NE Washington has a high density of bobcats relative to other parts of WA. The Colville National Forest provides millions of acres of public bobcat hunting ground.",steps:["After fresh snowfall get out early to cut fresh tracks on forest roads — bobcat tracks are unmistakable.","Follow tracks methodically — they travel in straight lines when hunting then meander when in good prey habitat.","Predator calling from forest edges also produces — set up at any clearing or logging road cut.","Hound hunting is the most reliable method if you have trained hounds available.","Bobcats bed in dense timber and rocky outcrops during the day — push these areas when tracking."],terrain:"Dense mixed timber with forest roads and clearings. Moderate terrain. Snow conditions in winter.",bestTime:"December through February when snow tracking is possible. Peak bobcat activity is winter.",gear:[".22 Magnum or .223 rifle","Mouth distress call or electronic caller","White camo for snow hunting","Insulated waterproof boots","Hunter orange if concurrent deer season is open"],warning:"NE Washington bobcats must be registered with WDFW within 5 days of harvest. Statewide harvest quota — check current status at wdfw.wa.gov before hunting."}},

  // ── COYOTE — 4 more public ────────────────────────────────────────────
  {id:"l-t-murray-coyote",deer:"coyote",name:"L.T. Murray Wildlife Area",subname:"Yakima County — Year-round Calling",lat:46.8500,lng:-120.5000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMUs 335-372",publicLand:true,difficulty:"Beginner",region:"Central — Yakima County",summary:"The L.T. Murray Wildlife Area (100000+ acres) is prime coyote country with year-round hunting and no bag limit. Open ridgelines and coulee setups provide long-range calling opportunities on massive public land.",access:"From Ellensburg or Yakima: Multiple access points throughout the L.T. Murray. Green Dot permit required for interior roads. Free from WDFW Yakima office.",how:{overview:"The L.T. Murray Wildlife Area's enormous open sagebrush landscape is perfect for predator calling. Ridgeline setups with 360-degree visibility produce consistently and no permission is ever needed.",steps:["Drive Green Dot roads to high ridgelines or coulee rims with good all-direction visibility.","Set up before first light with a clear view in all directions — watch for approaching coyotes with binoculars.","Use rabbit or rodent distress calls — start soft and increase volume if no response in 5 minutes.","Electronic callers with remote controls work very well on the L.T. Murray's open terrain.","Night hunting with red or green lights is legal on public land — check specific WDFW wildlife area rules."],terrain:"Open sagebrush ridgelines and coulees. Easy terrain. Green Dot road vehicle access.",bestTime:"Year-round. January-February when coyotes are most territorial is best.",gear:[".223 or .22-250 for long-range shots","Electronic caller with remote control","Binoculars for spotting incoming coyotes","Green Dot Road permit (free from WDFW Yakima)","Camo"],warning:"Check individual WDFW wildlife area regulations for any specific coyote hunting restrictions — most allow coyote hunting year-round but some have specific rules about electronic callers or night hunting."}},
  {id:"ferry-county-coyote",deer:"coyote",name:"Ferry County Forest Edges",subname:"Republic Area — Timber Coyotes",lat:48.3000,lng:-118.5000,place_id:"ChIJTy27ZVtmYlMREECqwv6Kmh8",gmu:"Ferry County",publicLand:true,difficulty:"Intermediate",region:"NE — Ferry County",summary:"Ferry County coyotes in the forested NE Washington tend to be larger and darker than agricultural coyotes. Set up at forest openings and clearcut edges for productive calling sessions.",access:"From Republic: Any Forest Service or DNR road in Ferry County provides access. Set up at forest openings meadow edges and old clearcuts.",how:{overview:"Forested Ferry County coyotes respond well to calls but require different setups than open country. Dense timber means shorter shot opportunities and coyotes can appear at close range very suddenly.",steps:["Set up at forest openings meadow edges or clearcut corners — coyotes need open areas to approach comfortably.","In dense timber coyotes may appear at 20-30 yards without warning — be ready for a fast close shot.","Use louder calls than you would in open country — sound does not carry as far in dense forest.","Howling sequences work exceptionally well with Ferry County territorial winter coyotes.","Combine coyote and bobcat calling in the same morning — both species respond to similar calls."],terrain:"Dense mixed timber with forest openings and old clearcuts. Moderate terrain.",bestTime:"Year-round. Winter calling is most productive when coyotes are territorial.",gear:[".223 rifle or 12 gauge for close timber shots","Mouth call or electronic caller","Camo","Hunter orange when deer firearm season is open","Patience in dense timber"],warning:"Ferry County timber coyotes can appear silently at very close range. Be mentally prepared for a fast shot at 20-30 yards when calling in dense forest."}},
  {id:"colockum-coyote",deer:"coyote",name:"Colockum Wildlife Area",subname:"Kittitas County — Central WA Coyotes",lat:47.2500,lng:-120.2500,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMUs 328-337",publicLand:true,difficulty:"Beginner",region:"Central — Kittitas County",summary:"The Colockum Wildlife Area's open sagebrush ridges and coulee country provide excellent coyote calling setups on public land. Combine with deer scouting or quail hunting on the same trip.",access:"From Ellensburg: Head north on Reecer Creek Rd or take Vantage Hwy north. WDFW Colockum Wildlife Area with multiple access points. Green Dot permit for interior roads.",how:{overview:"The Colockum Wildlife Area provides excellent year-round public coyote hunting in its sagebrush and coulee landscape. No permission needed on this large WDFW managed area.",steps:["Set up on any ridge or coulee rim with good 360-degree visibility in the Colockum.","Call with rabbit distress sounds — Colockum coyotes respond aggressively to prey sounds.","The Colockum's open terrain allows you to see incoming coyotes at long distances — use binoculars.","Green Dot roads provide vehicle access to remote setups throughout the wildlife area.","Night hunting is an option — check WDFW Colockum Wildlife Area specific rules for night hunting."],terrain:"Open sagebrush ridges and coulees. Easy terrain. Green Dot road access.",bestTime:"Year-round. Best in late fall through winter when pups have dispersed and coyotes are most territorial.",gear:[".223 or .243 rifle","Electronic or mouth caller","Binoculars","Green Dot permit (free from WDFW Yakima)","Camo — earth tones"],warning:"Green Dot Road permit required for vehicle access to Colockum interior roads. Confirm any specific coyote hunting rules for the Colockum on the WDFW website."}},
  {id:"umatilla-coyote",deer:"coyote",name:"Umatilla National Wildlife Refuge",subname:"SE Washington — Shrub-steppe Coyotes",lat:45.9000,lng:-119.4000,place_id:"ChIJBQdD9witolQR46-P7-buLsI",gmu:"SE Columbia River Zone",publicLand:true,difficulty:"Beginner",region:"SE — Benton County",summary:"Umatilla NWR holds coyotes year-round in its shrub-steppe and agricultural margins along the Columbia River. Excellent off-season hunting that combines with late season duck or goose trips.",access:"From Kennewick: Head east on SR-14 along the Columbia River to Umatilla NWR. Check fws.gov/refuge/umatilla for current access rules regarding predator hunting on the refuge.",how:{overview:"Umatilla NWR's shrub-steppe and agricultural margins are prime coyote habitat. Year-round hunting with no bag limit makes this a great option for improving calling skills in the off-season.",steps:["Check the Umatilla NWR hunting program at fws.gov/refuge/umatilla — confirm predator hunting is permitted.","Set up at any field edge or coulee on the refuge with good visibility in multiple directions.","Rabbit and rodent distress calls work well in the flat open Umatilla terrain.","The Columbia River setting makes for great coyote hunting during the off-season between waterfowl seasons.","Night hunting with a light — confirm NWR regulations for night hunting before going."],terrain:"Flat shrub-steppe along the Columbia River. Very easy terrain. Refuge roads accessible.",bestTime:"Year-round. Best late fall through winter when coyotes are most territorial.",gear:[".223 or .243 rifle","Electronic or mouth caller","Camo — earth tones for the open basin","Water","Check if NWR coyote hunting permit required"],warning:"Umatilla NWR may have specific rules about predator hunting and electronic callers. Always check the current refuge hunting program at fws.gov/refuge/umatilla before going."}}
,
  {id:"yakima-training-pheasant",deer:"pheasant",name:"Yakima Training Center — Public Hunt Program",subname:"Kittitas County — Free Army Base Access",lat:46.8000,lng:-120.3000,place_id:"ChIJA16pYIzqmlQRzT0Rp6a9Y-k",gmu:"GMU 371",publicLand:true,difficulty:"Beginner",region:"Central — Kittitas County",summary:"The Yakima Training Center (US Army) runs a free public hunting program with much less pressure than typical public land. The extensive shrub-steppe holds pheasant quail HUN and chukar.",access:"Register with the YTC Environmental office online before hunting — free and required. Check the YTC website for current open training days before every trip.",how:{overview:"YTC manages a large free public hunting program on its shrub-steppe and grassland. Pheasant quail chukar and HUN all use the same habitat here with far less hunting pressure than typical WA public land.",steps:["Register with the YTC Environmental office at the YTC website — free but required before hunting.","Download the current YTC hunting map showing which training areas are open on your hunt date.","Hunt brushy draws CRP strips and grass edges in the morning when birds are feeding.","Without a dog walk grid patterns through cover — YTC pheasants hold well due to less pressure.","Combine pheasant hunting with quail chukar and HUN in the same outing."],terrain:"Open shrub-steppe and grassland. Easy terrain. Well-maintained military roads.",bestTime:"October through January. YTC is open on non-training days — check the schedule before going.",gear:["YTC hunting permit (free — required from YTC Environmental office)","Blaze orange vest and hat","12 or 20 gauge with #5 or #6 shot","Dog recommended","Water"],warning:"You MUST register with YTC before entering. Training schedules affect access — check the YTC website before every trip. Closed areas are strictly enforced."}},
  {id:"columbia-basin-pheasant-units",deer:"pheasant",name:"Columbia Basin Wildlife Area — Pheasant Release Units",subname:"Grant County — WDFW Stocked Pheasant",lat:47.1068,lng:-119.2687,place_id:"ChIJgR2Z1YeFplQRmM7KxoHX-hc",gmu:"Columbia Basin",publicLand:true,difficulty:"Beginner",region:"Central — Grant County",summary:"WDFW releases thousands of pheasants into the Columbia Basin Wildlife Area units every fall. The top public pheasant hunting destination in Washington with over 192000 acres of access.",access:"From Moses Lake: Head west on SR-170 or SR-28. Multiple unit access points throughout Grant County. Download the WDFW Columbia Basin Wildlife Area map before going.",how:{overview:"The Columbia Basin Wildlife Area is WA premier public pheasant hunting area. WDFW releases thousands of birds here annually into habitat with CRP grass cattail marshes and crop field edges.",steps:["Download the WDFW Columbia Basin Wildlife Area map — it shows all open units and access roads.","Check the WDFW website or call WDFW for the current pheasant release schedule before going.","Hunt field edges and CRP grass strips in the morning when birds are feeding and moving.","Without a dog walk grid patterns through the cover — kick every brush pile and cattail patch.","Hunt the sunny south-facing slopes in the afternoon when birds are loafing in the warmth."],terrain:"Flat to gently rolling. Mix of open grassland crop fields and cattail draws. Very easy walking.",bestTime:"Late October through November after WDFW bird releases. Call WDFW to confirm recent releases.",gear:["Blaze orange hat and vest (required)","12 or 20 gauge with #5 or #6 shot","Hunting dog is a major advantage","Lots of water — dry eastern WA","WDFW Columbia Basin Wildlife Area map"],warning:"Grant County leads WA in pheasant and waterfowl production. Check which units are open and whether recent pheasant releases have occurred at wdfw.wa.gov before making the drive."}}
];

