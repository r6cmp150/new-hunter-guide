const ANIMAL_CATEGORIES = {
  "deer-elk": [
    {id:"black-tail",icon:"🌲",name:"Black-tailed Deer",sub:"West of Cascades",color:"#4ade80",
     intro:"Washington's most common deer, found in dense western forests and logged clearcuts. Most beginner-friendly deer in the state with excellent public land access.",
     identification:["Bucks 100–175 lbs","Fully black or dark tail raised when alarmed","Reddish-brown coat in summer, grey-brown in winter","Compact forked antlers"],
     huntingMethods:["Still-hunt clearcut edges at dawn and dusk","Set up stand at forest-clearcut boundary","Drive logging roads slowly at first light"],
     behavior:"Most active dawn and dusk. Bed in thick timber midday. Rut: late October–November. Rely heavily on their nose.",
     calibers:[
       {name:".243 Winchester",rec:"Good Choice",recColor:"#facc15",desc:"Flat-shooting and light recoil — excellent for new hunters. Effective to 200 yards on deer. Popular in western WA."},
       {name:".308 Winchester",rec:"Best Choice",recColor:"#4ade80",desc:"The gold standard deer cartridge. Versatile, widely available, manageable recoil. Works at all ranges you'll encounter in WA timber."},
       {name:".30-06 Springfield",rec:"Best Choice",recColor:"#4ade80",desc:"Classic all-around WA deer and elk cartridge. Slightly more recoil than .308 but excellent performance across all conditions."},
       {name:"6.5 Creedmoor",rec:"Great Choice",recColor:"#4ade80",desc:"Modern favorite. Flat trajectory, low recoil, excellent accuracy. Great for longer shots in eastern WA or open clearcuts."},
       {name:".270 Winchester",rec:"Great Choice",recColor:"#4ade80",desc:"Flat-shooting with moderate recoil. Very popular in WA. Good for dense timber and open country alike."},
       {name:".223 / 5.56",rec:"Not Recommended",recColor:"#fb923c",desc:"Legal in WA for deer but marginal for ethical kills. Too light for reliable one-shot stops. Use a heavier caliber."},
     ],
     waRegs:[{rule:"Season",detail:"Archery: mid-Sept–mid-Oct. Modern firearm: mid-Oct–mid-Nov. Muzzleloader: late Oct–early Nov. Exact dates vary by GMU."},{rule:"License",detail:"WA Hunting License + Deer Tag. Buy at fishhunt.dfw.wa.gov."},{rule:"Antler Restrictions",detail:"Many western WA GMUs require 3+ points on one side for bucks. Check your specific GMU."},{rule:"Hunter Orange",detail:"400+ sq. in. of orange or fluorescent pink above the waist including hat during firearm season."},{rule:"Bag Limit",detail:"One deer per license year. Tag must be immediately validated at kill."},{rule:"Harvest Report",detail:"Due January 31 at fishhunt.dfw.wa.gov. Failure results in license suspension."}]},
    {id:"mule-deer",icon:"🏔️",name:"Mule Deer",sub:"East of Cascades",color:"#facc15",
     intro:"Larger than black-tails with big mule-like ears and a white rump patch. Lives in open shrub-steppe and pine forests of eastern WA. Great for beginners — visible from long range.",
     identification:["Bucks 150–250 lbs","Very large ears, white rump with black-tipped tail","Bifurcated (forked) antlers","Bouncing 'stotting' gait when alarmed"],
     huntingMethods:["Spot and stalk: glass from high points then approach","Drive roads at first light to locate deer","Still-hunt through open pine timber"],
     behavior:"Active dawn and dusk. Bed on shaded hillsides midday. Unlike whitetails, stop and look before running. Rut: late November–December.",
     calibers:[
       {name:".308 Winchester",rec:"Best Choice",recColor:"#4ade80",desc:"Ideal for eastern WA's varied ranges — from tight canyon shots to 300-yard open country shots. Hard to beat."},
       {name:".30-06 Springfield",rec:"Best Choice",recColor:"#4ade80",desc:"Outstanding all-around choice. More than enough power at any range you'll hunt mule deer in WA."},
       {name:"6.5 Creedmoor",rec:"Best Choice",recColor:"#4ade80",desc:"Excellent for long shots in open eastern WA terrain. Very flat trajectory with manageable recoil."},
       {name:".270 Winchester",rec:"Great Choice",recColor:"#4ade80",desc:"Classic mule deer cartridge. Flat-shooting for open country. Widely available across eastern WA."},
       {name:".300 Win Mag",rec:"Good Choice",recColor:"#facc15",desc:"More than enough — but increased recoil. Best if you're also hunting elk. Otherwise .308 or 6.5 is sufficient."},
       {name:".243 Winchester",rec:"Works",recColor:"#a0a0c0",desc:"Legal and effective at close ranges but marginal for longer shots. Use a premium bullet if this is your only rifle."},
     ],
     waRegs:[{rule:"Season",detail:"Archery: mid-Sept–mid-Oct. Modern firearm: mid-Oct–mid-Nov. Exact dates vary significantly by GMU in eastern WA."},{rule:"License",detail:"WA Hunting License + Deer Tag. fishhunt.dfw.wa.gov."},{rule:"Antler Restrictions",detail:"GMUs 105, 108, 121 and others have specific minimum antler point requirements. Check your exact GMU."},{rule:"Special Permits",detail:"Some premium eastern WA GMUs require a special permit by lottery. Apply through WDFW each spring."},{rule:"Shared Tag",detail:"In most GMUs, mule deer and whitetail share one tag — killing either fills your tag."},{rule:"Harvest Report",detail:"January 31 deadline. Required even if unsuccessful in some GMUs."}]},
    {id:"whitetail",icon:"🌾",name:"White-tailed Deer",sub:"NE Washington",color:"#fb923c",
     intro:"The most challenging deer to hunt in North America. Wary, with an incredible nose. Found in NE Washington near the Idaho border. Requires patience and excellent scent control.",
     identification:["Bucks 150–250 lbs","Large tail pure white underneath — 'flags' when alarmed","Single main beam antlers with upward tines","Blue-grey coat in winter"],
     huntingMethods:["Stand hunting near heavily-used trails","Rattling and grunt calling during rut","Field edge hunting at dusk"],
     behavior:"Almost entirely nocturnal except during the rut (late Oct–mid-Nov). Follow precise daily patterns. Scent is their primary defense. Rut bucks move unpredictably in daylight.",
     calibers:[
       {name:".308 Winchester",rec:"Best Choice",recColor:"#4ade80",desc:"Perfect for NE WA timber — enough power for shots through dense brush, widely available, manageable recoil."},
       {name:".30-06 Springfield",rec:"Best Choice",recColor:"#4ade80",desc:"Classic and effective. Slightly more punch for potential elk bonus — many NE WA hunters use this for both species."},
       {name:"6.5 Creedmoor",rec:"Great Choice",recColor:"#4ade80",desc:"Excellent accuracy for precise shots through timber gaps. Increasingly popular in NE WA."},
       {name:".243 Winchester",rec:"Good Choice",recColor:"#facc15",desc:"Works well at close to medium ranges in timber. Light recoil good for beginners. Use premium bonded bullets."},
       {name:".350 Legend",rec:"Good Choice",recColor:"#facc15",desc:"Newer cartridge designed specifically for deer in heavy cover. Low recoil, effective to 200 yards."},
     ],
     waRegs:[{rule:"Season",detail:"Archery: mid-Sept–mid-Oct. Modern firearm: mid-Oct–mid-Nov in NE WA GMUs 117, 121, 124."},{rule:"License",detail:"WA Hunting License + Deer Tag. fishhunt.dfw.wa.gov."},{rule:"Shared Tag",detail:"Mule deer and whitetail share one tag in most NE WA GMUs."},{rule:"Hunter Orange",detail:"400+ sq. in. above the waist during firearm season."},{rule:"Wolf Awareness",detail:"Wolf packs established in NE WA. Don't leave harvested game unattended."},{rule:"CWD",detail:"Mandatory CWD testing in areas where CWD has been detected. Check current rules before transporting carcasses."}]},
    {id:"elk",icon:"🦌",name:"Rocky Mountain Elk",sub:"Statewide",color:"#f97316",
     intro:"Washington's most prized big game animal. Bulls can exceed 700 lbs. Found statewide but concentrated in the Blue Mountains, North Cascades, and Olympic Peninsula. A true trophy and a significant source of high-quality wild meat.",
     identification:["Bulls 500–700+ lbs, cows 400–500 lbs","Tan body with dark brown neck and legs","Massive antlers on bulls — 5–7 points per side typical","Loud bugling call during the rut"],
     huntingMethods:["Bugling and cow calling during rut (September)","Spot and stalk in open parks and meadows","Still-hunting timbered draws","Stand hunting near wallows and trails"],
     behavior:"Highly social. Live in herds with distinct home ranges. Rut is September–October — bulls bugle and fight for cows. Post-rut bulls become reclusive. Heavy migration to lower elevations in winter.",
     calibers:[
       {name:".300 Win Mag",rec:"Best Choice",recColor:"#4ade80",desc:"The standard elk caliber in WA. More power and range than needed for deer — exactly right for elk. Can anchor a bull at 400+ yards with proper shot placement."},
       {name:".338 Win Mag",rec:"Best Choice",recColor:"#4ade80",desc:"Favored by guides and experienced elk hunters. Hard-hitting for thick cover and quartering shots. Significant recoil but confidence-inspiring on big bulls."},
       {name:".30-06 Springfield",rec:"Great Choice",recColor:"#4ade80",desc:"With premium 180–220 grain bullets, the .30-06 is perfectly capable on elk at reasonable ranges. WA hunters have filled many freezers with it."},
       {name:".308 Winchester",rec:"Good Choice",recColor:"#facc15",desc:"Minimum recommended. Use premium 168–180 grain bonded bullets and limit shots to 250 yards. Shot placement is critical."},
       {name:"6.5 Creedmoor",rec:"Works — With Limits",recColor:"#a0a0c0",desc:"Legal but marginal for elk. If this is your rifle, use the heaviest premium bullet available and limit shots to 200 yards with precise placement."},
       {name:"7mm Rem Mag",rec:"Great Choice",recColor:"#4ade80",desc:"Flat-shooting and powerful. Popular in WA for combination deer/elk hunters. Good compromise between the .308 and .300 Win Mag."},
     ],
     waRegs:[{rule:"License",detail:"WA Hunting License + Elk Tag. General season tags available over-the-counter. Some premium areas require special permit."},{rule:"Archery Season",detail:"Typically mid-September through mid-October. Archery elk during the rut is one of the most exciting hunts in WA."},{rule:"Modern Firearm",detail:"Typically late October through mid-November depending on GMU. Check wdfw.wa.gov for your specific unit."},{rule:"Antler Restrictions",detail:"Many WA GMUs require branch-antlered bulls (at least one antler with 2+ points). Check your GMU."},{rule:"Mandatory Check",detail:"All harvested elk must be reported within 72 hours via fishhunt.dfw.wa.gov."},{rule:"Special Permits",detail:"Premium units (like the famous Blue Mountains units) require special permit drawn by lottery. Apply in spring."}]},
    {id:"roosevelt-elk",icon:"🫎",name:"Roosevelt Elk",sub:"Olympic Peninsula & Western WA",color:"#fb923c",
     intro:"The Roosevelt elk is the largest elk subspecies in North America, found on the Olympic Peninsula and western Cascades. Bigger and darker than the Rocky Mountain elk of eastern WA, these animals live in dense rainforest and logged clearcuts. A spectacular and challenging hunt.",
     identification:["Bulls 600–900+ lbs — noticeably larger than Rocky Mountain elk","Darker brown coat, heavier body","Antlers typically wider and more massive than Rocky Mountain elk","Found almost exclusively west of the Cascades"],
     huntingMethods:["Still-hunting old-growth and clearcut edges","Bugling during the September rut","Spot and stalk in clearcuts at dawn","Hound hunting for post-season tracking"],
     behavior:"Live in dense rainforest. More secretive than Rocky Mountain elk. Rut runs September into October — bulls bugle but respond less aggressively than eastern bulls. Clearcuts are prime feeding areas year-round.",
     calibers:[
       {name:".300 Win Mag",rec:"Best Choice",recColor:"#4ade80",desc:"Ideal for big Roosevelt bulls in heavy timber — penetrates brush better than lighter cartridges. 180–200 grain bonded bullets."},
       {name:".338 Win Mag",rec:"Best Choice",recColor:"#4ade80",desc:"Preferred by many Olympic Peninsula guides for the heaviest bulls. Excellent penetration through quartering shots."},
       {name:".30-06 Springfield",rec:"Great Choice",recColor:"#4ade80",desc:"Proven on Roosevelt elk for generations. Use 200–220 grain premium bullets for the best performance on these large animals."},
       {name:"7mm Rem Mag",rec:"Great Choice",recColor:"#4ade80",desc:"Good compromise — flatter than .30-06, more energy than .308. Works well in the mixed open/timber terrain of western WA."},
     ],
     waRegs:[{rule:"License",detail:"WA Hunting License + Elk Tag. Most western WA units are over-the-counter but some require special permits."},{rule:"Archery Season",detail:"Mid-September through mid-October — coincides with the peak rut."},{rule:"Modern Firearm",detail:"Typically late October through mid-November in western WA GMUs. Check wdfw.wa.gov for your unit."},{rule:"Antler Restrictions",detail:"Many western WA GMUs have branch-antlered bull restrictions. Check your specific GMU."},{rule:"Pack Out",detail:"Roosevelt elk can exceed 900 lbs — plan your pack-out before you pull the trigger. Thick terrain makes retrieval challenging."},{rule:"Harvest Report",detail:"Required within 72 hours at fishhunt.dfw.wa.gov."}]},
    {id:"moose",icon:"🫎",name:"Moose",sub:"NE Washington (Rare — Special Permit)",color:"#a78bfa",
     intro:"Washington has a small but growing moose population in the northeast corner of the state (Pend Oreille and Ferry counties). Hunting requires a very rare special permit — only a handful are issued per year statewide.",
     identification:["Largest member of the deer family — bulls 800–1,200 lbs","Massive palmated antlers on bulls","Long legs, humped shoulders, pendulous dewlap (bell)","Dark brown to black coat"],
     huntingMethods:["Calling with cow calls near lakes and wetlands","Still-hunting willow thickets and riparian areas","Spot and stalk in open areas"],
     behavior:"Solitary and found near water, willows, and aquatic vegetation. Rut in September–October. Can be aggressive during the rut — approach with caution.",
     calibers:[
       {name:".338 Win Mag",rec:"Best Choice",recColor:"#4ade80",desc:"The go-to moose cartridge in North America. Enough power to reliably stop 1,000+ lb animals at hunting ranges."},
       {name:".300 Win Mag",rec:"Best Choice",recColor:"#4ade80",desc:"Excellent for moose with 200+ grain premium bullets. Very capable and more common in WA than .338."},
       {name:".30-06 Springfield",rec:"Good Choice",recColor:"#facc15",desc:"Minimum for moose. Use the heaviest premium bullets available (200–220 grain). Shot placement is critical — hit the vitals precisely."},
     ],
     waRegs:[{rule:"Special Permit Only",detail:"Moose require a special hunt permit in WA. Only a small number are issued annually by lottery."},{rule:"Apply in Spring",detail:"Applications available at fishhunt.dfw.wa.gov during the spring special permit application period (typically April–May)."},{rule:"Region",detail:"Available only in NE Washington (WDFW Regions 1 and 2 near the Idaho/Canada border)."}]},
  ],
  "bear": [
    {id:"black-bear",icon:"🐻",name:"Black Bear",sub:"Statewide — Most Common",color:"#8b5cf6",
     intro:"Washington has an estimated 25,000–30,000 black bears — one of the highest populations in the lower 48. Found in forested areas statewide. Can be hunted in both spring and fall seasons.",
     identification:["150–400 lbs typical in WA","Black, brown, or cinnamon color (all same species)","Flat facial profile, no shoulder hump","Short curved claws for climbing"],
     huntingMethods:["Over bait (legal in WA — requires permit in some units)","Still-hunting huckleberry patches and clear cuts","Spot and stalk in open areas","Calling with prey distress calls"],
     behavior:"Omnivore — eats berries, roots, insects, and carrion. Active at dawn and dusk. Hibernate November–April. Sows with cubs should never be targeted.",
     calibers:[
       {name:".308 Winchester",rec:"Best Choice",recColor:"#4ade80",desc:"More than adequate for black bear at any range. Use 165–180 grain bonded bullets for reliable penetration."},
       {name:".30-06 Springfield",rec:"Best Choice",recColor:"#4ade80",desc:"Classic bear cartridge. 180 grain Core-Lokt or similar is a proven combination on black bear."},
       {name:".300 Win Mag",rec:"Great Choice",recColor:"#4ade80",desc:"Overkill on smaller bears but excellent insurance on large boars. Bears can be tough."},
       {name:".243 Winchester",rec:"Works — With Limits",recColor:"#a0a0c0",desc:"Legal but marginal for bears over 200 lbs. Use the heaviest premium bullet available and limit shots to close range."},
     ],
     waRegs:[{rule:"Spring Season",detail:"April 1 through May 31 in most units. Spring bears are actively moving after hibernation."},{rule:"Fall Season",detail:"Late August through November in most units, concurrent with deer/elk seasons."},{rule:"License",detail:"WA Hunting License + Bear Tag required. Available at fishhunt.dfw.wa.gov."},{rule:"Baiting",detail:"Legal in some WA units but requires a bait site registration permit. Check regulations for your specific unit."},{rule:"No Cubs or Sows with Cubs",detail:"It is illegal to kill a female black bear with cubs, or cubs under 1 year. If in doubt, don't shoot."},{rule:"Harvest Report",detail:"Required within 5 days of harvest at fishhunt.dfw.wa.gov."}]},
    {id:"cougar",icon:"🐆",name:"Cougar (Mountain Lion)",sub:"Statewide",color:"#f59e0b",
     intro:"Washington's apex predator. Cougars are elusive and rarely seen, but can be hunted with dogs or by spot-and-stalk. Most hunters encounter cougars incidentally while hunting deer or elk.",
     identification:["Adult males 130–180 lbs, females 80–100 lbs","Tawny tan coat with white belly","Long thick tail (about 1/3 of body length)","Round face with small rounded ears"],
     huntingMethods:["Hound hunting (with trained dogs — most common method)","Spot and stalk in rocky terrain","Calling with prey distress sounds"],
     behavior:"Solitary, territorial, and mostly nocturnal. Follow deer and elk herds. Leave scrapes and kills covered with debris. Home ranges of 50–150 square miles.",
     calibers:[
       {name:".243 Winchester and up",rec:"Legal Minimum Area",recColor:"#facc15",desc:"WA has no minimum caliber for cougar. A .243 or .308 is plenty for cougars — most shots are close-range over hounds."},
       {name:".308 Winchester",rec:"Best Choice",recColor:"#4ade80",desc:"More than adequate. If you're already hunting deer, your deer rifle works perfectly for cougar."},
     ],
     waRegs:[{rule:"Season",detail:"Year-round season in most of WA — cougars can be taken during any big game season with an appropriate tag."},{rule:"License",detail:"WA Hunting License + Cougar Tag required."},{rule:"Harvest Quota",detail:"Each cougar management unit has an annual harvest quota. Season closes when quota is met — check current status."},{rule:"Mandatory Check",detail:"All harvested cougars must be presented to WDFW within 5 business days for biological sampling."},{rule:"Hound Hunting",detail:"Hunting with hounds is legal in WA but requires coordination and trained dogs — typically done with professional outfitters."}]},
  ],
  "mountain": [
    {id:"mountain-goat",icon:"🐐",name:"Mountain Goat",sub:"Special Permit Only",color:"#e2e8f0",
     intro:"One of the most challenging and rewarding hunts in Washington. Mountain goats live in steep, rocky terrain above timberline. Only a handful of special permits issued annually by lottery.",
     identification:["Both sexes have short black horns (females slightly smaller)","Pure white thick coat","Sturdy build, cloven hooves with rubbery pads for grip on rock","Males (billies) 125–250 lbs"],
     huntingMethods:["Spot and stalk — glass rocky cliff bands from a distance","Extremely technical terrain — requires mountain fitness","Most hunts require several miles of hiking at elevation"],
     behavior:"Found in steep rocky terrain year-round. Defend themselves from predators by going where predators can't follow. Billies are solitary in summer; herds form in fall.",
     calibers:[
       {name:".300 Win Mag",rec:"Best Choice",recColor:"#4ade80",desc:"Preferred — shots on steep terrain can be at awkward angles and long range. Premium 180 grain bonded bullet."},
       {name:".30-06 Springfield",rec:"Great Choice",recColor:"#4ade80",desc:"Perfectly capable on mountain goats. Many WA goats have been taken with the .30-06."},
       {name:"6.5 Creedmoor",rec:"Great Choice",recColor:"#4ade80",desc:"Excellent for long-range shots in open alpine terrain. Flat trajectory is valuable in the mountains."},
     ],
     waRegs:[{rule:"Special Permit Only",detail:"Mountain goat is by special permit only in WA. Permits are extremely limited — often just 1–5 per unit."},{rule:"Apply Spring",detail:"Applications at fishhunt.dfw.wa.gov during spring permit period."},{rule:"Physical Fitness",detail:"Not a regulation, but critical: goat hunts require excellent physical fitness and mountain experience. Dangerous terrain."}]},
    {id:"bighorn-sheep",icon:"🐏",name:"Bighorn Sheep",sub:"Special Permit Only",color:"#d97706",
     intro:"One of North America's most coveted big game animals. Washington has limited bighorn sheep populations in the eastern Cascades and Blue Mountains. Permits are extremely rare.",
     identification:["Rams have massive curved brown horns","Tan to brown coat with white rump patch","Stocky muscular build","Rams 150–300 lbs"],
     huntingMethods:["Spot and stalk in open rocky terrain","Similar techniques to mountain goat hunting"],
     behavior:"Live in steep open terrain. Rams form bachelor groups; ewes and lambs in separate groups except during rut (November–December). Expert climbers.",
     calibers:[
       {name:".300 Win Mag or 6.5 Creedmoor",rec:"Best Choice",recColor:"#4ade80",desc:"Flat-shooting rifles preferred for open terrain where shots can be 200–400 yards. Premium expanding bullets only."},
     ],
     waRegs:[{rule:"Special Permit Only",detail:"Among the rarest tags in WA — just a few permits issued statewide annually."},{rule:"Apply Spring",detail:"Spring permit application period at fishhunt.dfw.wa.gov."},{rule:"Region",detail:"Limited to specific management units in eastern Cascades and NE WA. Units vary by year."}]},
    {id:"pronghorn",icon:"🦌",name:"Pronghorn Antelope",sub:"Eastern WA — Special Permit",color:"#fbbf24",
     intro:"North America's fastest land animal — pronghorn can sustain speeds over 55 mph. Washington has a small but huntable population in the Columbia Basin shrub-steppe of eastern WA. Special permit required. An exciting and unique western hunt.",
     identification:["Both sexes have horns — males much larger with distinctive prong","Tan and white body with white rump patch","Very large eyes for detecting predators at great distance","Bucks 100–130 lbs"],
     huntingMethods:["Spot and stalk across open shrub-steppe","Decoy hunting — pronghorn are territorial and will approach decoys","Glassing from elevated points and making long stalks"],
     behavior:"Live in open flat or rolling terrain with no trees. Rely entirely on eyesight for predator detection — exceptional vision. Very curious animals but spook easily if they smell you. Rut is August–September.",
     calibers:[
       {name:"6.5 Creedmoor",rec:"Best Choice",recColor:"#4ade80",desc:"Flat-shooting at the longer ranges common in pronghorn country. Excellent accuracy for precise shots in open terrain."},
       {name:".270 Winchester",rec:"Best Choice",recColor:"#4ade80",desc:"Classic pronghorn cartridge. Flat trajectory, adequate power, very popular in eastern WA open country."},
       {name:".243 Winchester",rec:"Great Choice",recColor:"#4ade80",desc:"Plenty of power for pronghorn at 300 yards or less. Light recoil helps with precision in the field."},
       {name:".300 Win Mag",rec:"Good Choice",recColor:"#facc15",desc:"More than needed but useful if also hunting elk. The extra recoil can cause flinching on small targets at distance."},
     ],
     waRegs:[{rule:"Special Permit Only",detail:"Pronghorn require a special permit in WA. Tags are issued by lottery — apply annually through WDFW."},{rule:"Apply Spring",detail:"Spring special permit application window at fishhunt.dfw.wa.gov. Apply every year — odds improve with preference points."},{rule:"Region",detail:"Limited to eastern WA GMUs in the Columbia Basin shrub-steppe. Check available units at wdfw.wa.gov."},{rule:"Season",detail:"Typically late August through September — coincides with the rut when bucks are most active."}]},
  ],
  "upland": [
    {id:"turkey",icon:"🦃",name:"Wild Turkey",sub:"Statewide — Spring & Fall",color:"#ea580c",
     intro:"Washington has excellent wild turkey hunting across most of the state. The Rio Grande subspecies dominates eastern WA; Merriam's are present in some areas. Very exciting to hunt — birds gobble and respond to calls.",
     identification:["Adult toms 15–25 lbs with distinctive beard and spurs","Bronze/copper iridescent body feathers","Red, white, and blue head coloring","Fan-shaped tail display during breeding"],
     huntingMethods:["Spring: Call with mouth calls, slate calls, or box calls — gobblers respond aggressively","Fall: Scatter a flock then call them back with yelps","Decoys can be very effective"],
     behavior:"Spring toms gobble from the roost at dawn and search for hens. Flock up in fall. Come to calls year-round. Roosting in tall trees at dusk.",
     calibers:[
       {name:"12 Gauge Shotgun",rec:"Best Choice",recColor:"#4ade80",desc:"Standard turkey load — #4, #5, or #6 shot with a full or extra-full choke. Maximum 40-yard effective range."},
       {name:"20 Gauge Shotgun",rec:"Good Choice",recColor:"#facc15",desc:"Effective for turkeys — especially for youth hunters. Use premium turkey loads."},
       {name:".22-250 or similar rifle",rec:"Specialty Use",recColor:"#a0a0c0",desc:"Legal in some WA units. Head/neck shots only. Most hunters use shotguns for cleaner ethical kills."},
     ],
     waRegs:[{rule:"Spring Season",detail:"April 1 – May 31 (general). Bearded birds only during spring."},{rule:"Fall Season",detail:"September 1 – January 31 in most units. Either sex legal in fall."},{rule:"License",detail:"WA Hunting License + Turkey Tag. Some areas require special permits."},{rule:"Bag Limit",detail:"2 bearded birds per license year (1 per spring season, 1 in fall)."},{rule:"Hunter Orange",detail:"Not required for turkey hunting but recommended for safety."}]},
    {id:"pheasant",icon:"🐦",name:"Ring-necked Pheasant",sub:"Eastern WA — Agricultural Areas",color:"#16a34a",
     intro:"The classic upland bird. Ring-necked pheasants thrive in eastern WA's agricultural areas, river bottoms, and CRP grasslands. Good dog work and fast shooting make this a favorite.",
     identification:["Roosters: brilliant copper/green plumage, long tail, white ring on neck","Hens: mottled brown, much duller than roosters","Strong fast fliers — can reach 40 mph"],
     huntingMethods:["Walk-up hunting with or without a flushing dog","Drive: line of hunters walking through cover while others post at ends","Dog work: pointing dogs locate and hold birds"],
     behavior:"Roost in thick brush at night. Move to feed in grain fields at dawn. Loaf in brush midday. Return to roost at dusk.",
     calibers:[
       {name:"12 Gauge #4, #5, or #6 Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Standard pheasant load. #4 or #5 lead for close to medium flushes. Non-toxic shot required near water."},
       {name:"20 Gauge",rec:"Good Choice",recColor:"#facc15",desc:"Very popular for pheasant — lighter gun, less fatigue on all-day hunts."},
       {name:"28 Gauge",rec:"Specialty",recColor:"#a0a0c0",desc:"For experienced wing shots only. Fun but limits effective range."},
     ],
     waRegs:[{rule:"Season",detail:"Generally October through January in eastern WA. Check specific GMU dates at wdfw.wa.gov."},{rule:"License",detail:"WA Hunting License + Upland Bird Validation."},{rule:"Bag Limit",detail:"Typically 3 roosters per day, 9 in possession. Hens illegal during most seasons."},{rule:"Non-Toxic Shot",detail:"Required within 200 yards of water. Lead shot is legal elsewhere for pheasant."}]},
    {id:"grouse",icon:"🦚",name:"Blue & Ruffed Grouse",sub:"Forests Statewide",color:"#6d7a5a",
     intro:"Two species of forest grouse are common in WA — Blue Grouse (Sooty Grouse) in western mountain forests and Ruffed Grouse in eastern timber areas. Both are excellent eating and fun to hunt.",
     identification:["Blue/Sooty Grouse: Blue-grey males 2–3 lbs with orange eye comb","Ruffed Grouse: Brown mottled pattern, fan tail, black ruff around neck"],
     huntingMethods:["Walk through timber and shoot at flushes","Dog work with pointing or flushing dogs","Blue grouse often sit tight in trees — spot and shoot"],
     behavior:"Blue Grouse move to higher elevation conifer forests in winter. Ruffed Grouse stay in deciduous/mixed forests year-round near alder and aspen.",
     calibers:[
       {name:"20 or 28 Gauge Shotgun",rec:"Best Choice",recColor:"#4ade80",desc:"#7.5 or #8 shot is standard for grouse. Light loads for these smaller birds."},
       {name:".22 LR Rifle",rec:"Good Choice",recColor:"#facc15",desc:"Legal in WA for grouse. Head shots preserve the meat perfectly. Great for hikers who encounter birds opportunistically."},
     ],
     waRegs:[{rule:"Season",detail:"Sooty/Blue Grouse: mid-September through December. Ruffed Grouse: mid-September through January."},{rule:"License",detail:"WA Hunting License + Upland Bird Validation."},{rule:"Bag Limit",detail:"Sooty Grouse: 3 per day / 9 in possession. Ruffed Grouse: 4 per day / 12 in possession."}]},
    {id:"sharptail",icon:"🐦",name:"Sharp-tailed Grouse",sub:"Eastern WA — Shrub-steppe",color:"#a16207",
     intro:"Washington's only native prairie grouse, the sharp-tailed grouse is found in the shrub-steppe and grasslands of eastern WA. A sleek, fast-flying bird that requires a good dog and quick shooting.",
     identification:["Mottled brown/white pattern with pointed tail feathers (not fan-shaped)","Slightly larger than pheasant hens — about 2 lbs","Fast, direct flight with rapid wingbeats"],
     huntingMethods:["Walk-up hunting with a pointing dog in grasslands and shrub-steppe","Hunt near food sources: grain fields, rose hips, chokecherries","Early morning when birds are feeding"],
     behavior:"Form large winter flocks. Display on traditional dancing grounds (leks) in spring. Prefer grasslands and brushy coulees in eastern WA.",
     calibers:[
       {name:"12 or 20 Gauge #6 or #7.5 Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Standard upland bird load. Full or modified choke. Same setup works for pheasant and chukar."},
     ],
     waRegs:[{rule:"Season",detail:"Typically mid-September through December in eastern WA. Season length varies annually."},{rule:"License",detail:"WA Hunting License + Upland Bird Validation."},{rule:"Bag Limit",detail:"Typically 3 per day / 9 in possession. Check current WDFW regulations as populations vary."},{rule:"Area",detail:"Limited to specific eastern WA GMUs — Lincoln, Adams, Grant, and Spokane counties have best populations."}]},
    {id:"chukar",icon:"🐦",name:"Chukar Partridge",sub:"Eastern WA — Rocky Canyons",color:"#dc2626",
     intro:"The chukar is one of Washington's most physically demanding upland hunts. These birds live on the steepest, rockiest slopes of eastern WA canyons — hunting them requires serious fitness. The reward is delicious table fare and an unforgettable experience.",
     identification:["Round reddish-brown bird with bold black and white barring on flanks","Bright red bill and legs","White face with black mask","About the size of a small chicken"],
     huntingMethods:["Hunt steep canyon walls and rocky slopes in eastern WA river breaks","Dogs are essential — chukar run uphill constantly","Hunt from the top down when possible — birds fly downhill when flushed"],
     behavior:"Run uphill constantly rather than flying. Flush in explosive coveys when cornered. Live in family groups (coveys) of 10–30 birds. Call with loud 'chuck-chuck-chukar' sound.",
     calibers:[
       {name:"12 or 20 Gauge #6 or #7.5 Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Modified to full choke for the longer shots common when chukar flush down steep slopes."},
       {name:"28 Gauge",rec:"Good Choice",recColor:"#facc15",desc:"Popular with experienced chukar hunters — lighter to carry up steep terrain all day."},
     ],
     waRegs:[{rule:"Season",detail:"Typically mid-September through January in eastern WA canyon areas."},{rule:"License",detail:"WA Hunting License + Upland Bird Validation."},{rule:"Bag Limit",detail:"Typically 8 per day / 24 in possession."},{rule:"Top Areas",detail:"Snake River breaks, Yakima River canyon, Methow Valley, and Grande Ronde River canyon are classic WA chukar spots."}]},
    {id:"hun",icon:"🐦",name:"Hungarian Partridge",sub:"Eastern WA — Agricultural Areas",color:"#78716c",
     intro:"The 'Hun' is a covey bird of eastern WA's wheat and grain country. Smaller and faster than pheasant, they flush in tight coveys and provide exciting shooting across open agricultural landscapes.",
     identification:["Small round grey-brown bird — about 1 lb","Orange-red face, chestnut horseshoe marking on belly","Flush in tight coveys of 8–15 birds","Very fast direct flight"],
     huntingMethods:["Walk wheat stubble and CRP fields with a pointing dog","Cover large areas — coveys range over wide territory","Hunt field edges and brushy draws adjacent to grain fields"],
     behavior:"Live in coveys year-round in agricultural eastern WA. More cold-hardy than pheasant. Rely on running before flushing. Best hunting in October–November.",
     calibers:[
       {name:"20 or 28 Gauge #7.5 or #8 Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Lighter loads for these smaller birds. Open choke (improved cylinder or modified) recommended — covey flushes are close."},
       {name:"12 Gauge #7.5 Shot",rec:"Good Choice",recColor:"#facc15",desc:"Works fine but heavier than needed for these small birds."},
     ],
     waRegs:[{rule:"Season",detail:"Typically mid-September through December in eastern WA."},{rule:"License",detail:"WA Hunting License + Upland Bird Validation."},{rule:"Bag Limit",detail:"Typically 8 per day / 24 in possession."},{rule:"Co-bag",detail:"Often hunted alongside pheasant and sharp-tailed grouse in the same areas."}]},
    {id:"quail",icon:"🐦",name:"California Quail",sub:"Eastern WA — Shrubby Areas",color:"#65a30d",
     intro:"The California quail (Valley quail) is Washington's most abundant native quail species, found in brushy coulees, orchards, and shrubby areas of eastern WA. They flush in large coveys and provide exciting fast shooting.",
     identification:["Small round grey bird with distinctive curved head plume","Males have black face with white stripe","Coveys of 20–50+ birds common in fall","Flush low and fast with loud wingbeat noise"],
     huntingMethods:["Walk brushy draws and orchard edges — quail hold tight until nearly stepped on","Dog hunting with a flushing breed","Focus on water sources in dry eastern WA — quail rarely stray far from water"],
     behavior:"Live in large coveys. Use thick shrubs for cover and roosting. Very dependent on water. Most active early morning and late afternoon. Run rather than fly when possible.",
     calibers:[
       {name:"20 or 28 Gauge #7.5 or #8 Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Open choke (skeet or improved cylinder) — quail flush close and fast. Light loads preserve meat on these small birds."},
       {name:"12 Gauge #8 Shot",rec:"Good Choice",recColor:"#facc15",desc:"Works well but a lighter gun is easier to swing on fast-flushing coveys."},
     ],
     waRegs:[{rule:"Season",detail:"Typically mid-September through December in eastern WA."},{rule:"License",detail:"WA Hunting License + Upland Bird Validation."},{rule:"Bag Limit",detail:"Typically 10 per day / 30 in possession."},{rule:"Area",detail:"Okanogan, Chelan, Douglas, Grant, and Benton counties have top populations."}]},
    {id:"dove",icon:"🕊️",name:"Mourning Dove",sub:"Eastern WA — Agricultural Areas",color:"#a8a29e",
     intro:"Mourning dove is one of the most popular game birds in North America. In Washington, dove season opens in September — one of the first hunting seasons of the year. Fast-flying and challenging to hit, doves are great practice for wing shooting.",
     identification:["Small slender grey-brown bird with long pointed tail","Gentle cooing call — familiar summer sound","Very fast in flight — can exceed 55 mph","White-tipped tail feathers visible in flight"],
     huntingMethods:["Field/pass shooting: sit near grain fields or water and shoot passing birds","Decoys and calling near feeding areas","Scout sunflower and grain fields in advance"],
     behavior:"Feed heavily in grain and sunflower fields in morning and evening. Water daily — tanks and ponds are reliable locations. Migrate south in September–October.",
     calibers:[
       {name:"12 or 20 Gauge #7.5 or #8 Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Open choke — doves are fast and shots are often at distance. Non-toxic shot required on some public lands."},
       {name:"28 Gauge #8 Shot",rec:"Great Choice",recColor:"#4ade80",desc:"The dove hunter's classic — light, fun, and a great challenge for experienced wing shots."},
     ],
     waRegs:[{rule:"Season",detail:"September 1 through November 29 in eastern WA (Zone 1 and Zone 2). Check current WDFW regulations."},{rule:"License",detail:"WA Hunting License + Migratory Bird Permit."},{rule:"Bag Limit",detail:"15 mourning doves per day / 45 in possession."},{rule:"Non-Toxic Shot",detail:"Required on some public lands and within certain distances of water. Check specific area rules."}]},
    {id:"snipe",icon:"🐦",name:"Common Snipe",sub:"Wetlands Statewide",color:"#0d9488",
     intro:"The original 'snipe hunt' — the common snipe is a real bird and a challenging target! Found in wet meadows and marsh edges statewide. Their explosive zigzag flush makes them one of the most difficult birds to hit.",
     identification:["Long straight bill — nearly as long as its head","Brown streaked body with white belly","Explosive flushing flight with sharp 'scaipe' call","Very fast erratic zigzag flight pattern"],
     huntingMethods:["Walk marshy meadows and bog edges in rubber boots","Shoot quickly — snipe won't fly straight for long","A flushing dog helps locate birds in heavy cover"],
     behavior:"Probe soft mud with their long bill for invertebrates. Very cryptically colored — nearly invisible until flushed. Migrate through WA in fall. Some birds winter in mild western WA.",
     calibers:[
       {name:"12 or 20 Gauge #8 or #9 Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Open choke (skeet) — snipe are small and shots are close-range. The challenge is hitting them, not killing them."},
     ],
     waRegs:[{rule:"Season",detail:"Typically September 1 through December 31. Check current WDFW regulations."},{rule:"License",detail:"WA Hunting License + Migratory Bird Permit."},{rule:"Bag Limit",detail:"8 per day / 24 in possession."}]},
    {id:"sandhill-crane",icon:"🦢",name:"Sandhill Crane",sub:"Eastern WA — Agricultural Areas",color:"#6366f1",
     intro:"Washington recently reopened sandhill crane hunting after a long closure — now with a very limited season in eastern WA. Cranes are large, prehistoric-looking birds and excellent table fare often called 'the ribeye of the sky.'",
     identification:["Very large grey birds — 4-foot wingspan","Distinctive red forehead patch","Fly with neck outstretched (unlike herons which fold their neck)","Loud rattling call audible from miles away"],
     huntingMethods:["Field hunting over full-body crane decoys","Pass shooting at flyways near roost sites","Scouting key as birds concentrate in specific grain fields"],
     behavior:"Highly migratory. Stage in large numbers in eastern WA grain fields in October–November before continuing south. Roost on sandbars and open water at night.",
     calibers:[
       {name:"12 Gauge Non-Toxic BB, BBB, or T Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Large birds require large non-toxic shot for clean kills. Same setup as Canada geese. Full choke recommended."},
     ],
     waRegs:[{rule:"Season",detail:"Limited season in specific eastern WA zones — typically mid-October to November. Check current WDFW regulations carefully."},{rule:"License",detail:"WA Hunting License + Special Sandhill Crane Permit (separate lottery). Also need Federal Sandhill Crane permit."},{rule:"Bag Limit",detail:"Very limited — typically 1–3 birds per season depending on the zone. Confirm current limits before hunting."},{rule:"Non-Toxic Shot",detail:"Required. Same federal requirement as all migratory waterfowl."}]},
  ],
  "waterfowl": [
    {id:"duck",icon:"🦆",name:"Ducks",sub:"Statewide — Ponds, Rivers, Coast",color:"#0ea5e9",
     intro:"Washington offers world-class duck hunting. Mallards, teal, widgeon, pintail, and diving ducks all migrate through the state. Western WA coastal areas and eastern WA reservoirs/ponds are top locations.",
     identification:["Mallards: green head, yellow bill on drakes","Teal: small, fast-flying, early season birds","Widgeon: whistling call, white forehead on drakes","Pintail: elegant long tail, brown head"],
     huntingMethods:["Decoy spreads with duck calls","Jump shooting rivers and potholes","Boat hunting coastal bays and large reservoirs"],
     behavior:"Strong migratory species. Peak migration through WA is October–December. Early season teal can be hunted in September. Respond well to decoys and calls.",
     calibers:[
       {name:"12 Gauge Non-Toxic #2, #3, or #4 Steel",rec:"Required by Law",recColor:"#4ade80",desc:"Non-toxic shot is federally required for all waterfowl hunting. #2 or #3 steel for mallards. #6 steel for teal."},
       {name:"20 Gauge Non-Toxic",rec:"Good Choice",recColor:"#facc15",desc:"Effective with modern non-toxic loads. Use #2 or #3 steel for larger ducks."},
       {name:"Bismuth or Tungsten Shot",rec:"Premium Option",recColor:"#a78bfa",desc:"Patterns like lead but legal for waterfowl. More expensive but dramatically better performance than steel — worth it for serious hunters."},
     ],
     waRegs:[{rule:"Federal + State License",detail:"Must have both WA Hunting License + WA Waterfowl License + Federal Duck Stamp. All three required."},{rule:"Non-Toxic Shot",detail:"FEDERALLY REQUIRED for all waterfowl. Lead shot is illegal for ducks and geese everywhere. Significant fines."},{rule:"Season",detail:"Generally October through January. Teal early season opens in September."},{rule:"Bag Limit",detail:"Varies by species and zone. Generally 7 ducks per day with species restrictions. Carry and know your limits."}]},
    {id:"teal",icon:"🦆",name:"Teal (Early Season)",sub:"Statewide — September",color:"#06b6d4",
     intro:"Washington offers a special early teal-only season in September before the regular duck season opens. Blue-winged, Green-winged, and Cinnamon teal all pass through WA. Small, fast, and exciting — teal are excellent practice before the big season.",
     identification:["Blue-winged Teal: powder blue wing patch visible in flight","Green-winged Teal: smallest WA duck — very fast","Cinnamon Teal: males have rich cinnamon-red body","All teal fly in tight twisting flocks at high speed"],
     huntingMethods:["Decoy spreads on small ponds and marshes","Pass shooting at flyways in the morning","Calling with soft quacks and teal whistles"],
     behavior:"Migrate early — most pass through WA in September. Prefer shallow marshy ponds and wetlands. Decoy readily. Very fast in flight — among the most challenging ducks to hit.",
     calibers:[
       {name:"12 or 20 Gauge #6 Non-Toxic Steel",rec:"Best Choice",recColor:"#4ade80",desc:"Small shot for small birds. Non-toxic required. Bismuth or tungsten #6 patterns much better than steel for these fast birds."},
     ],
     waRegs:[{rule:"Early Season",detail:"Special early teal-only season opens September 1 (check current WDFW dates). Teal species only — no mallards or other ducks."},{rule:"License",detail:"WA Hunting License + WA Waterfowl License + Federal Duck Stamp required — same as regular season."},{rule:"Bag Limit",detail:"Typically 6 teal per day during the early season."},{rule:"Non-Toxic Shot",detail:"Federally required — no lead shot for any waterfowl."}]},
    {id:"goose",icon:"🪿",name:"Canada & Cackling Geese",sub:"Statewide — Fields & Water",color:"#4a7c59",
     intro:"Canada geese are abundant in WA — both giant resident birds and migrating birds. Eastern WA grain fields and western WA farmland offer excellent goose hunting.",
     identification:["Canada Goose: large, black head and neck with white chin patch","Cackling Goose: similar but noticeably smaller","White-fronted Goose: orange bill, speckled belly"],
     huntingMethods:["Field hunting over full-body decoys","Water hunting over floater decoys","Guided hunts are popular and effective for beginners"],
     behavior:"Highly social. Feed in grain and grass fields during the day and rest on water at night. Respond well to calls and decoys. Resident birds can be hunted from September.",
     calibers:[
       {name:"12 Gauge Non-Toxic BB, BBB, or T Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Large geese require large non-toxic shot. BB or BBB steel is standard. Bismuth or Heavyweight patterns better but costs more."},
       {name:"20 Gauge BBB Non-Toxic",rec:"Works",recColor:"#a0a0c0",desc:"Marginal for large Canada geese — limit shots to 35 yards and use the largest non-toxic shot available for your gauge."},
     ],
     waRegs:[{rule:"Federal + State License",detail:"WA Hunting License + WA Waterfowl License + Federal Duck Stamp required."},{rule:"Non-Toxic Shot",detail:"Mandatory for all waterfowl hunting. No exceptions."},{rule:"Season",detail:"Early Canada goose season begins in September. Regular season October–January depending on zone."},{rule:"Bag Limit",detail:"Check current WA regulations — bag limits for Canada geese vary by zone and have been adjusted in recent years."}]},
    {id:"snow-goose",icon:"🪿",name:"Snow & Ross's Geese",sub:"Eastern WA — Spring Conservation Hunt",color:"#e2e8f0",
     intro:"Snow geese winter in WA in massive numbers and have a special spring conservation order hunt with very liberal bag limits. Their populations have exploded and they're damaging Arctic nesting habitat. One of the most exciting and social hunts available.",
     identification:["Snow Goose: pure white with black wingtips (adult), blue morph is grey-brown","Ross's Goose: smaller than snow goose, rounder head, stubby bill","Fly in massive V-formations — often tens of thousands of birds"],
     huntingMethods:["Large spreads of shell or rag decoys (hundreds) with electronic calls","Pass shooting flyways at staging areas","Very social hunt — large groups work together"],
     behavior:"Migrate in enormous flocks. Stage on eastern WA grain fields and Columbia Basin wetlands February–April. Respond to electronic calls and large decoy spreads.",
     calibers:[
       {name:"12 Gauge Non-Toxic BB or BBB Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Same setup as Canada geese. High-velocity steel or bismuth for clean kills on these tough birds."},
     ],
     waRegs:[{rule:"Conservation Order",detail:"Special spring conservation season (Light Goose Conservation Order) with very liberal rules — no daily bag limit on snow and Ross's geese."},{rule:"Electronic Calls",detail:"Electronic calls are LEGAL during the spring conservation order (unlike regular season)."},{rule:"Unplugged Shotguns",detail:"Shotguns may be unplugged (more than 3 shells) during the conservation order."},{rule:"Dates",detail:"Typically February 1 through April 30 in eastern WA. Check current WDFW regulations."},{rule:"License",detail:"WA Hunting License + WA Waterfowl License + Federal Duck Stamp required."}]},
    {id:"brant",icon:"🪿",name:"Brant",sub:"Western WA — Coastal",color:"#0f766e",
     intro:"Brant are small dark sea geese that migrate along the Pacific Coast and winter in protected bays of western WA. Puget Sound and coastal bays offer excellent brant hunting for those willing to put in the scouting effort.",
     identification:["Small dark goose — much smaller than Canada goose","Black head, neck, and breast with white neck markings","Fly low over water in irregular flocks","Prefer eelgrass beds and salt water"],
     huntingMethods:["Layout boat or floating blind hunting over decoys","Shore blinds at tidal flats","Small decoy spreads — brant respond to 6–12 decoys"],
     behavior:"Highly dependent on eelgrass for food. Fly low over water in small irregular groups. Less call-responsive than Canada geese — decoys are key.",
     calibers:[
       {name:"12 Gauge Non-Toxic #2 or #3 Steel",rec:"Best Choice",recColor:"#4ade80",desc:"Brant are shot at moderate ranges over water. Non-toxic required. Bismuth is excellent for the closer shots common in brant hunting."},
     ],
     waRegs:[{rule:"Season",detail:"October through January in coastal western WA zones."},{rule:"License",detail:"WA Hunting License + WA Waterfowl License + Federal Duck Stamp."},{rule:"Bag Limit",detail:"Typically 2 brant per day — check current regulations as this varies by year."},{rule:"Non-Toxic Shot",detail:"Federally required for all waterfowl."},{rule:"Area",detail:"Padilla Bay, Dungeness Bay, and southern Puget Sound are top WA brant locations."}]},
  ],
  "smallgame": [
    {id:"rabbit",icon:"🐇",name:"Cottontail Rabbit / Snowshoe Hare",sub:"Statewide",color:"#94a3b8",
     intro:"Great introductory hunting for beginners and kids. Cottontails are common in brushy areas and farmland edges statewide. Snowshoe hares are found in higher elevation forests. Fun, fast-paced, and excellent table fare.",
     identification:["Cottontail: brown with white cotton-ball tail, 2–3 lbs","Snowshoe Hare: white in winter, brown in summer, large rear feet"],
     huntingMethods:["Walk-up hunting: kick through brush piles and hedgerows","Beagle hunting: dogs push rabbits in circles back to the hunter","Snowshoeing for hares in winter"],
     behavior:"Crepuscular (active at dawn and dusk). Use brush piles, blackberry thickets, and rock piles as cover. Cottontails rarely stray far from cover.",
     calibers:[
       {name:".22 LR Rifle",rec:"Best Choice",recColor:"#4ade80",desc:"The classic rabbit/hare cartridge. Quiet, accurate, affordable, and preserves meat with head shots."},
       {name:"20 Gauge #6 or #7.5 Shot",rec:"Best Choice",recColor:"#4ade80",desc:"Great for jump shooting — quick flushing rabbits are easy to miss with a rifle."},
     ],
     waRegs:[{rule:"Season",detail:"Cottontail: year-round in most WA areas. Snowshoe Hare: year-round."},{rule:"License",detail:"WA Hunting License + Small Game License."},{rule:"Bag Limit",detail:"Cottontail: 5 per day. Snowshoe Hare: 5 per day."}]},
    {id:"squirrel",icon:"🐿️",name:"Tree Squirrel",sub:"Forests Statewide",color:"#92400e",
     intro:"Washington has Western Gray Squirrels and Douglas Squirrels (Chickarees). Excellent beginner hunting — develops shooting skills, woodsmanship, and makes excellent stew.",
     identification:["Western Gray Squirrel: large gray squirrel with bushy tail","Douglas Squirrel: small dark brown squirrel, common in conifer forests"],
     huntingMethods:["Still-hunting under oak or nut trees","Wait at a known den tree at dawn","Spot and stalk through timber"],
     behavior:"Most active early morning. Feed heavily in fall on acorns, pine seeds, and fungi. Alert and vocal when disturbed.",
     calibers:[
       {name:".22 LR Rifle",rec:"Best Choice",recColor:"#4ade80",desc:"Perfect squirrel caliber — precise head shots at 30–60 yards. Low cost, fun to shoot."},
       {name:"20 Gauge #6 Shot",rec:"Good Choice",recColor:"#facc15",desc:"For mixed-bag days with birds. More effective for moving squirrels in dense canopy."},
     ],
     waRegs:[{rule:"Season",detail:"Western Gray Squirrel: Sept 1 – Dec 31. Douglas Squirrel: year-round."},{rule:"License",detail:"WA Hunting License + Small Game License."},{rule:"Bag Limit",detail:"Western Gray Squirrel: 3 per day. Douglas Squirrel: no limit."}]},
    {id:"bobcat",icon:"🐱",name:"Bobcat",sub:"Statewide",color:"#c2410c",
     intro:"Washington's most common wild cat. Bobcats are secretive and rarely seen but widely distributed across the state. Hunting is done primarily with hounds or predator calling. Their spotted coat makes them a prized trophy.",
     identification:["About twice the size of a domestic cat — 15–35 lbs","Spotted reddish-brown coat with white belly","Short 'bobbed' tail with black tip on top","Tufted ears with small ear tufts"],
     huntingMethods:["Hound hunting (most effective method)","Predator calling with distress sounds at night","Incidental harvest while hunting other species"],
     behavior:"Solitary and highly territorial. Mostly nocturnal. Follow deer trails and use rocky outcrops. Stalk prey (rabbits, grouse, squirrels) rather than running it down.",
     calibers:[
       {name:".223 Remington",rec:"Best Choice",recColor:"#4ade80",desc:"Standard predator cartridge. Accurate, flat-shooting, and minimal pelt damage with the right bullet. Works at all ranges."},
       {name:".243 Winchester",rec:"Good Choice",recColor:"#facc15",desc:"More versatile — can be used for deer and other game as well."},
       {name:"12 Gauge #4 Buckshot",rec:"Good Choice",recColor:"#facc15",desc:"For close-range calling setups where bobcats come in tight."},
     ],
     waRegs:[{rule:"Season",detail:"Check current WDFW regulations — bobcat season varies by region and year."},{rule:"License",detail:"WA Hunting License + Bobcat Tag required."},{rule:"Quota",detail:"Bobcat has a statewide harvest quota. Check current quota status before hunting."},{rule:"Pelt Tagging",detail:"All harvested bobcats must be registered with WDFW within 5 days. Pelt tag required for export."}]},
    {id:"coyote",icon:"🐺",name:"Coyote",sub:"Statewide — No Season/Limit",color:"#b45309",
     intro:"Coyotes can be hunted year-round in Washington with no bag limit. A great way to hunt in the off-season and develop skills. Predator calling is exciting — coyotes can come in fast and close.",
     identification:["Medium-sized — 20–50 lbs","Grey to tan coat, bushy tail with black tip","Pointed nose and upright ears","High-pitched yipping howl"],
     huntingMethods:["Electronic or mouth calling with prey distress sounds","Sitting at field edges and calling in at dawn/dusk","Night hunting with a light is legal in WA"],
     behavior:"Highly adaptable. Found in all habitats statewide. Most active at dawn, dusk, and night. Territorial — respond aggressively to intrusions and prey sounds.",
     calibers:[
       {name:".223 / .224 Valkyrie",rec:"Best Choice",recColor:"#4ade80",desc:"Flat-shooting and effective to 400+ yards on coyotes. Minimal pelt damage with hollow point varmint bullets."},
       {name:".243 Winchester",rec:"Great Choice",recColor:"#4ade80",desc:"Versatile — can be used for coyotes, deer, and other game. Great all-around WA caliber."},
       {name:"12 Gauge #BB or #4 Buck",rec:"Good Choice",recColor:"#facc15",desc:"For close-range calling setups — coyotes sometimes charge in to 20–30 yards."},
     ],
     waRegs:[{rule:"Season",detail:"Year-round — no closed season for coyotes in WA."},{rule:"License",detail:"WA Hunting License required."},{rule:"Bag Limit",detail:"No bag limit on coyotes statewide."},{rule:"Night Hunting",detail:"Legal in WA with artificial light. Check local rules for any specific county or area restrictions."}]},
  ],
};

let currentTab="spots",selectedId=null,userLat=null,userLng=null,gpsStatus="idle",searchLabel=null;
// Active animal filters — default: all 3 deer on, everything else off
// ── FILTER — fully dynamic, derived from SPOTS so always in sync ────────────
const FILTER_GROUPS = [
  {key:'deer',     label:'🦌 DEER',                   ids:['black-tail','mule-deer','whitetail']},
  {key:'upland',   label:'🦃 UPLAND BIRDS',            ids:['turkey','pheasant','grouse','sharptail','chukar','hun','quail','dove','snipe','sandhill-crane']},
  {key:'waterfowl',label:'🦆 WATERFOWL',               ids:['duck','teal','goose','snow-goose','brant']},
  {key:'big-game', label:'🦌 BIG GAME',                ids:['elk','roosevelt-elk','moose','black-bear','cougar','mountain-goat','bighorn-sheep','pronghorn']},
  {key:'small',    label:'🐇 SMALL GAME & PREDATORS',  ids:['rabbit','squirrel','bobcat','coyote']},
];
const SPOT_ANIMAL_TYPES = [...new Set(SPOTS.map(s=>s.deer))];
const FILTER_IDS = FILTER_GROUPS.flatMap(g=>g.ids).filter(id=>SPOT_ANIMAL_TYPES.includes(id));
let activeFilters = new Set(['black-tail','mule-deer','whitetail']);
let activeDiffs = new Set(['Beginner','Intermediate','Advanced']);
let filterTarget = 'browse';

function buildFilterDrawer(){
  const container=document.getElementById('filterDrawerGroups');
  if(!container)return;
  let html='';
  FILTER_GROUPS.forEach(group=>{
    const available=group.ids.filter(id=>SPOT_ANIMAL_TYPES.includes(id));
    if(!available.length)return;
    const groupSpots=available.reduce((n,id)=>n+SPOTS.filter(s=>s.deer===id).length,0);
    html+=`<div class="fd-group-title" style="margin-top:14px">${group.label} <span style="color:#5a6a50;font-size:10px;font-weight:400">(${groupSpots} spots)</span></div><div class="fd-grid">`;
    available.forEach(id=>{
      const label=DEER_LABELS[id]||id;
      const count=SPOTS.filter(s=>s.deer===id).length;
      const chk=activeFilters.has(id)?'checked':'';
      html+=`<label class="fd-chip"><input type="checkbox" id="fc-${id}" ${chk} onchange="applyFilter()"><span>${label} <span style="opacity:.45;font-size:10px">(${count})</span></span></label>`;
    });
    html+=`</div>`;
  });
  // Sync difficulty checkboxes
  ['Beginner','Intermediate','Advanced'].forEach(d=>{
    const el=document.getElementById('fd-'+d);
    if(el) el.checked=activeDiffs.has(d);
  });
  container.innerHTML=html;
}

function applyDiffFilter(){
  activeDiffs.clear();
  ['Beginner','Intermediate','Advanced'].forEach(d=>{
    const el=document.getElementById('fd-'+d);
    if(el&&el.checked) activeDiffs.add(d);
  });
  refreshMaps();
}


function haversine(la1,lo1,la2,lo2){const R=3958.8,dL=(la2-la1)*Math.PI/180,dO=(lo2-lo1)*Math.PI/180;const a=Math.sin(dL/2)**2+Math.cos(la1*Math.PI/180)*Math.cos(la2*Math.PI/180)*Math.sin(dO/2)**2;return R*2*Math.asin(Math.sqrt(a));}

function showScreen(name){
  // Hide both nav elements when on browse (it has its own top nav)
  const isBrowse = name === 'browse';
  const hdr = document.getElementById('innerHeader');
  const bnav = document.getElementById('bottomNav');
  if(hdr)  hdr.style.display = isBrowse ? 'none' : '';
  if(bnav) bnav.style.display = isBrowse ? 'none' : '';
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
  const isHome=name==='home';
  document.getElementById('backBtn').style.display=isHome?'none':'block';
  document.getElementById('gpsHeaderBtn').style.display=isHome?'none':'block';
  // Nav always visible
  ['home','pack','budget','browse'].forEach(n=>{
    const el=document.getElementById('nav-'+n);
    if(el) el.className='nb'+(n===name?' active':'');
  });
  const gb=document.getElementById('gpsHeaderBtn');
  if(gpsStatus==='ok'){gb.className='gps-btn located';gb.textContent='📍 Located';}
  if(name==='browse'){
    // Use requestAnimationFrame to ensure the screen is visible before Leaflet measures it
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        if(!browseMap){
          browseMap=L.map('browseMapDiv',{zoomControl:true,attributionControl:false});
          L.tileLayer(TILE_URL,TILE_OPTS).addTo(browseMap);
          browseMap.setView([47.4,-120.5],6);
        }
        renderBrowse();
        browseMap.invalidateSize(true);
        browseMap.setView([47.4,-120.5],6);
      });
    });
  }
  if(name==='near'){setTimeout(()=>{if(nearMap)nearMap.invalidateSize();},50);}
  if(name==='budget')initBudget();
}
function goHome(){showScreen('home');selectedId=null;}

function browseAll(){
  activeFilters = new Set(SPOTS.map(s=>s.deer));
  activeDiffs   = new Set(['Beginner','Intermediate','Advanced']);
  buildFilterDrawer();
  showScreen('browse');
}

async function homeSearchGo(){
  const q = (document.getElementById('homeSearchInput').value || '').trim();
  if(!q){ showScreen('browse'); return; }

  // Show near screen in loading state while we geocode
  showScreen('near');
  document.getElementById('gpsLoading').style.display='flex';
  document.getElementById('gpsLoading').querySelector('div:nth-child(2)').textContent = 'Looking up "' + q + '"...';
  document.getElementById('gpsError').style.display='none';
  document.getElementById('gpsSuccess').style.display='none';

  try {
    // Photon by Komoot — free, no API key, CORS-friendly, browser-safe
    const params = new URLSearchParams({q: q + ' Washington', limit: '1', lang: 'en', bbox: '-124.8,45.5,-116.9,49.0'});
    const url = 'https://photon.komoot.io/api/?' + params.toString();
    const res = await fetch(url);
    const data = await res.json();
    const features = (data && data.features) || [];

    if(!features.length){
      showGPSErr("Couldn't find that location. Try a city like 'Spokane' or a zip like '98101'.");
      return;
    }

    const [lng, lat] = features[0].geometry.coordinates;
    userLat = lat;
    userLng = lng;
    searchLabel = features[0].properties.name || q;
    gpsStatus = 'ok';

    document.getElementById('gpsLoading').style.display='none';
    document.getElementById('gpsSuccess').style.display='flex';
    initNearMap();

  } catch(e) {
    showGPSErr("Couldn't reach location service. Check your internet connection and try again.");
  }
}

function requestGPS(){
  showScreen('near');
  if(!navigator.geolocation){showGPSErr("Location not supported by this browser.");return;}
  gpsStatus='loading';
  document.getElementById('gpsLoading').style.display='flex';
  document.getElementById('gpsError').style.display='none';
  document.getElementById('gpsSuccess').style.display='none';
  navigator.geolocation.getCurrentPosition(
    pos=>{userLat=pos.coords.latitude;userLng=pos.coords.longitude;gpsStatus='ok';searchLabel='your location';
      document.getElementById('gpsHeaderBtn').className='gps-btn located';
      document.getElementById('gpsHeaderBtn').textContent='📍 Located';
      document.getElementById('nav-near').className='nb active-green';
      document.getElementById('gpsLoading').style.display='none';
      document.getElementById('gpsSuccess').style.display='flex';
      initNearMap();},
    err=>{gpsStatus='error';showGPSErr(err.code===1?"Location access was denied.\n\nTap the ⓘ icon in your address bar → Permissions → set Location to Allow → tap Try Again.":"Couldn't get your location. Please try again.");},
    {timeout:12000,maximumAge:60000}
  );
}
function showGPSErr(msg){document.getElementById('gpsLoading').style.display='none';document.getElementById('gpsSuccess').style.display='none';document.getElementById('gpsError').style.display='flex';document.getElementById('gpsErrorMsg').textContent=msg;}
function getFilteredSpots(){return SPOTS.filter(s=>activeFilters.has(s.deer)&&activeDiffs.has(s.difficulty));}

// ── LEAFLET MAP ENGINE ─────────────────────────────────────────────────────
let nearMap=null, browseMap=null;
let nearMarkers=[], browseMarkers=[];

const TILE_URL='https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png';
const TILE_OPTS={attribution:'',className:'hunt-tiles'};

function makeIcon(spot, isActive){
  const m = DIFF_META[spot.difficulty] || DIFF_META['Intermediate'];
  const size = isActive ? 26 : 20;
  const glow = m.color;
  return L.divIcon({
    className: '',
    html: `<div class="lpin${isActive?' active':''}" style="background:${m.color};--pin-glow:${glow}55;width:${size}px;height:${size}px;margin:${(26-size)/2}px"></div>`,
    iconSize: [26,26], iconAnchor: [13,13], popupAnchor: [0,-18]
  });
}

function plotMarkers(map, spots, mapType){
  (mapType==='near' ? nearMarkers : browseMarkers).forEach(m => m.remove());
  if(mapType==='near') nearMarkers=[]; else browseMarkers=[];
  if(!spots.length) return;

  spots.forEach(spot => {
    const marker = L.marker([spot.lat, spot.lng], {icon: makeIcon(spot, false)}).addTo(map);
    marker._spot = spot;

    marker.on('click', e => {
      L.DomEvent.stopPropagation(e);
      // Light up the tapped pin
      const allMarkers = mapType==='near' ? nearMarkers : browseMarkers;
      allMarkers.forEach(m => m.setIcon(makeIcon(m._spot, false)));
      marker.setIcon(makeIcon(spot, true));
      // Get the pin's position in screen pixels
      const pinPx = map.latLngToContainerPoint([spot.lat, spot.lng]);
      const mapEl = document.getElementById(mapType==='near' ? 'nearMapDiv' : 'browseMapDiv');
      const mapRect = mapEl.getBoundingClientRect();
      const screenX = mapRect.left + pinPx.x;
      const screenY = mapRect.top  + pinPx.y;
      // Open the full modal, originating from pin location
      openModalFromPin(spot.id, screenX, screenY);
    });

    if(mapType==='near') nearMarkers.push(marker);
    else browseMarkers.push(marker);
  });

  // Reset pins when modal closes
  map.on('click', () => {
    (mapType==='near' ? nearMarkers : browseMarkers).forEach(m => m.setIcon(makeIcon(m._spot, false)));
  });

  const group = L.featureGroup(mapType==='near' ? nearMarkers : browseMarkers);
  map.fitBounds(group.getBounds().pad(.2), {maxZoom: 10, minZoom: 6});
}

let userDot=null;
function initNearMap(){
  if(!nearMap){
    nearMap=L.map('nearMapDiv',{zoomControl:true,attributionControl:false});
    L.tileLayer(TILE_URL,TILE_OPTS).addTo(nearMap);
  }
  // Always update the "you are here" dot (location may have changed between searches)
  if(userDot) userDot.remove();
  userDot=L.circleMarker([userLat,userLng],{
    radius:9,color:'#fff',weight:2.5,fillColor:'#3b82f6',fillOpacity:1
  }).addTo(nearMap).bindTooltip(searchLabel||'You are here',{permanent:false,direction:'top'});
  renderNearMap();
}

function initBrowseMap(){
  if(browseMap) return;
  browseMap=L.map('browseMapDiv',{zoomControl:true,attributionControl:false});
  L.tileLayer(TILE_URL,TILE_OPTS).addTo(browseMap);
  browseMap.setView([47.4,-120.5],6);
  renderBrowse();
}

function renderNearMap(){
  if(!nearMap) return;
  const RADIUS_MILES = 45;
  const filtered=getFilteredSpots();
  const withDist=filtered
    .map(s=>({...s,dist:haversine(userLat,userLng,s.lat,s.lng)}))
    .filter(s=>s.dist<=RADIUS_MILES)
    .sort((a,b)=>a.dist-b.dist);
  const sub=document.getElementById('nearSub');
  const locationName = searchLabel || 'your location';
  if(sub)sub.textContent=withDist.length+' spot'+(withDist.length!==1?'s':'')+' within 45 mi of '+locationName;
  plotMarkers(nearMap,withDist,'near');
  // Re-centre on user if no spots
  if(!withDist.length) nearMap.setView([userLat,userLng],8);
}

// Keep old name so closeFilterDrawer still calls it
function renderNearList(){renderNearMap();}

function browseCardHTML(s){
  const color=DEER_COLORS[s.deer]||'#8b6510';
  const label=DEER_LABELS[s.deer]||s.deer;
  const diffColors={Beginner:'#16a34a',Intermediate:'#d97706',Advanced:'#dc2626'};
  const dc=diffColors[s.difficulty]||'#737972';
  return `<div onclick="selectBrowseSpot('${s.id}')" style="background:#ede8da;border-radius:8px;overflow:hidden;flex-direction:column;border-top:4px solid #172c1d;box-shadow:0 1px 4px rgba(23,44,29,.06);cursor:pointer;transition:box-shadow .2s,transform .15s" onmouseenter="this.style.boxShadow='0 6px 20px rgba(23,44,29,.12)';this.style.transform='translateY(-1px)'" onmouseleave="this.style.boxShadow='0 1px 4px rgba(23,44,29,.06)';this.style.transform=''">
    <div style="padding:16px 18px 14px">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:6px">
        <span style="font-size:10px;font-weight:700;color:#fff;background:#172c1d;padding:3px 8px;border-radius:3px;font-family:'Work Sans',sans-serif;letter-spacing:1.5px;text-transform:uppercase;white-space:nowrap">${label}</span>
        <span style="font-size:10px;font-weight:600;color:${dc};padding:3px 8px;border-radius:3px;border:1px solid ${dc}44;background:${dc}11;font-family:'Work Sans',sans-serif;white-space:nowrap">${s.difficulty}</span>
      </div>
      <h4 style="font-family:'Newsreader',Georgia,serif;font-size:20px;font-weight:700;color:#172c1d;margin-bottom:4px;line-height:1.2">${s.name}</h4>
      <p style="font-family:'Work Sans',sans-serif;font-size:11px;color:#737972;margin-bottom:8px;font-style:italic">${s.subname}${s.gmu?' · '+s.gmu:''}</p>
      <p style="font-family:'Work Sans',sans-serif;font-size:12px;color:#434843;line-height:1.6;margin-bottom:12px">${s.summary.substring(0,130)}…</p>
      <div style="display:flex;align-items:center;justify-content:space-between;padding-top:10px;border-top:1px solid rgba(23,44,29,.1)">
        <span style="font-family:'Work Sans',sans-serif;font-size:10px;font-weight:700;color:#80552c;letter-spacing:1.5px;text-transform:uppercase">${s.publicLand?'Public Land':'Managed Access'}</span>
        <span style="font-family:'Work Sans',sans-serif;font-size:13px;color:#172c1d;font-weight:500;display:flex;align-items:center;gap:2px">View <span style="font-size:16px" class="material-symbols-outlined">arrow_forward</span></span>
      </div>
    </div>
  </div>`;
}

function selectBrowseSpot(id){
  // Show the full spot modal (safe, already working)
  openModal(id);

  // Also populate the inline detail panel
  const s=SPOTS.find(x=>x.id===id);
  if(!s) return;
  const panel=document.getElementById('browseDetailPanel');
  const body=document.getElementById('browseDetailBody');
  const img=document.getElementById('browseDetailImg');
  const dir=document.getElementById('browseDetailDir');
  if(!panel||!body||!img||!dir) return;

  const color=DEER_COLORS[s.deer]||'#2d4232';
  const label=DEER_LABELS[s.deer]||s.deer;
  const gmuStr = s.gmu ? ' · ' + s.gmu : '';

  // Build header strip
  img.style.background = color + '33';
  img.style.position = 'relative';
  img.style.minHeight = '96px';
  const headerDiv = document.createElement('div');
  headerDiv.style.cssText = 'position:absolute;bottom:12px;left:16px';
  const tagSpan = document.createElement('span');
  tagSpan.style.cssText = 'background:#ffdea5;color:#261900;font-size:9px;font-weight:700;font-family:Work Sans,sans-serif;letter-spacing:2px;text-transform:uppercase;padding:2px 8px;border-radius:2px;display:inline-block;margin-bottom:4px';
  tagSpan.textContent = label;
  const nameH3 = document.createElement('h3');
  nameH3.style.cssText = 'font-family:Newsreader,Georgia,serif;font-size:20px;font-weight:700;color:#fff;line-height:1.2;margin:0 0 2px';
  nameH3.textContent = s.name;
  const subP = document.createElement('p');
  subP.style.cssText = 'font-family:Work Sans,sans-serif;font-size:10px;color:rgba(255,255,255,.75);text-transform:uppercase;letter-spacing:1px;margin:0';
  subP.textContent = s.subname + gmuStr;
  headerDiv.appendChild(tagSpan);
  headerDiv.appendChild(nameH3);
  headerDiv.appendChild(subP);
  img.innerHTML = '';
  img.appendChild(headerDiv);

  // Build body using safe DOM methods
  const steps = (s.how && s.how.steps) || [];
  const terrain = (s.how && s.how.terrain) || '';
  const bestTime = (s.how && s.how.bestTime) || '';
  const gear = (s.how && s.how.gear) || [];
  const warning = (s.how && s.how.warning) || '';

  let html = '<div style="margin-bottom:14px">'
    + '<p style="font-family:Work Sans,sans-serif;font-size:10px;font-weight:700;color:#80552c;letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid #e7e2d4;padding-bottom:6px;margin-bottom:8px">Overview</p>'
    + '<p style="font-family:Work Sans,sans-serif;font-size:13px;color:#434843;line-height:1.6">' + s.summary + '</p></div>';

  if(steps.length){
    html += '<div style="margin-bottom:14px"><p style="font-family:Work Sans,sans-serif;font-size:10px;font-weight:700;color:#80552c;letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid #e7e2d4;padding-bottom:6px;margin-bottom:8px">Step by Step</p><div style="display:flex;flex-direction:column;gap:8px">';
    steps.forEach(function(st, i){
      html += '<div style="display:flex;gap:10px"><span style="font-family:Newsreader,Georgia,serif;font-weight:700;color:#80552c;font-style:italic;flex-shrink:0;min-width:24px">' + String(i+1).padStart(2,'0') + '.</span><p style="font-family:Work Sans,sans-serif;font-size:12px;color:#434843;line-height:1.6">' + st + '</p></div>';
    });
    html += '</div></div>';
  }

  if(terrain || bestTime){
    html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">';
    if(terrain) html += '<div><p style="font-family:Work Sans,sans-serif;font-size:10px;font-weight:700;color:#80552c;letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid #e7e2d4;padding-bottom:4px;margin-bottom:6px">Terrain</p><p style="font-family:Work Sans,sans-serif;font-size:11px;color:#434843;line-height:1.5">' + terrain + '</p></div>';
    if(bestTime) html += '<div><p style="font-family:Work Sans,sans-serif;font-size:10px;font-weight:700;color:#80552c;letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid #e7e2d4;padding-bottom:4px;margin-bottom:6px">Best Time</p><p style="font-family:Work Sans,sans-serif;font-size:11px;color:#434843;line-height:1.5">' + bestTime + '</p></div>';
    html += '</div>';
  }

  if(gear.length){
    html += '<div style="margin-bottom:14px"><p style="font-family:Work Sans,sans-serif;font-size:10px;font-weight:700;color:#80552c;letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid #e7e2d4;padding-bottom:6px;margin-bottom:8px">Gear</p><div style="display:flex;flex-wrap:wrap;gap:6px">';
    gear.forEach(function(g){ html += '<span style="background:#ede8da;padding:4px 10px;font-family:Work Sans,sans-serif;font-size:11px;color:#434843;border-radius:3px">' + g + '</span>'; });
    html += '</div></div>';
  }

  if(warning){
    html += '<div style="background:#ffdad6;border:1px solid rgba(186,26,26,.13);border-radius:8px;padding:12px;display:flex;gap:10px;align-items:flex-start"><span class="material-symbols-outlined" style="color:#ba1a1a;font-size:18px;flex-shrink:0">warning</span><div><p style="font-family:Work Sans,sans-serif;font-size:10px;font-weight:700;color:#ba1a1a;letter-spacing:1px;text-transform:uppercase;margin-bottom:3px">Important Note</p><p style="font-family:Work Sans,sans-serif;font-size:12px;color:#93000a;line-height:1.5">' + warning + '</p></div></div>';
  }

  body.innerHTML = html;
  dir.href = 'https://www.google.com/maps/dir/?api=1&destination=' + s.lat + ',' + s.lng + '&travelmode=driving';
  panel.style.display = 'block';
  panel.scrollIntoView({behavior:'smooth', block:'nearest'});
}

function renderBrowseCards(){
  // Render the cards list independently of the map
  const filtered=getFilteredSpots();
  const badge=document.getElementById('browseFilterCount');
  if(badge)badge.textContent=activeFilters.size>0?`(${activeFilters.size})`:'';
  const listEl=document.getElementById('browseList');
  if(listEl) listEl.innerHTML=filtered.map(s=>browseCardHTML(s)).join('');
  const countEl=document.getElementById('browseSpotCount');
  if(countEl) countEl.textContent=`${filtered.length} spot${filtered.length!==1?'s':''} found`;
}

function renderBrowse(){
  if(!browseMap){initBrowseMap();return;}
  const filtered=getFilteredSpots();
  const badge=document.getElementById('browseFilterCount');
  if(badge)badge.textContent=activeFilters.size>0?`(${activeFilters.size})`:'';
  const listEl=document.getElementById('browseList');
  if(listEl) listEl.innerHTML=filtered.map(s=>browseCardHTML(s)).join('');
  const countEl=document.getElementById('browseSpotCount');
  if(countEl) countEl.textContent=`${filtered.length} spot${filtered.length!==1?'s':''} found`;
  browseMap.setView([47.4,-120.5],6);
  plotMarkers(browseMap,filtered,'browse');
}
function openFilterDrawer(target){
  filterTarget=target;
  buildFilterDrawer(); // rebuild from live SPOTS data every time
  document.getElementById('filterOverlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeFilterDrawer(e){if(e.target===document.getElementById('filterOverlay'))closeFilterDrawerDirect();}
function closeFilterDrawerDirect(){
  document.getElementById('filterOverlay').classList.remove('open');
  document.body.style.overflow='';
  if(filterTarget==='near')renderNearMap();else renderBrowse();
}
function refreshMaps(){
  if(filterTarget==='near') renderNearMap();
  else renderBrowse();
}
function applyFilter(){
  activeFilters.clear();
  FILTER_IDS.forEach(id=>{const el=document.getElementById('fc-'+id);if(el&&el.checked)activeFilters.add(id);});
  refreshMaps();
}
function filterPreset(preset){
  const birds=['turkey','pheasant','grouse','sharptail','chukar','hun','quail','dove','snipe','sandhill-crane','duck','teal','goose','snow-goose','brant'];
  const deer=['black-tail','mule-deer','whitetail'];
  activeFilters.clear();
  FILTER_IDS.forEach(id=>{
    let on=false;
    if(preset==='deer') on=deer.includes(id);
    else if(preset==='all'||preset==='beginner') on=true;
    else if(preset==='none') on=false;
    else if(preset==='birds') on=birds.includes(id);
    if(on) activeFilters.add(id);
  });
  // Handle difficulty for beginner preset
  if(preset==='beginner'){
    activeDiffs=new Set(['Beginner']);
  } else if(preset==='none'){
    activeDiffs=new Set();
  } else {
    activeDiffs=new Set(['Beginner','Intermediate','Advanced']);
  }
  // Sync difficulty checkboxes
  ['Beginner','Intermediate','Advanced'].forEach(d=>{
    const el=document.getElementById('fd-'+d);
    if(el) el.checked=activeDiffs.has(d);
  });
  buildFilterDrawer();
  refreshMaps();
}

function setTab(t){
  currentTab=t;
  document.getElementById('browseSpots').style.display=t==='spots'?'flex':'none';
  document.getElementById('browseTips').style.display=t==='tips'?'block':'none';
  const base='padding:10px 18px;border-radius:999px;border:1.5px solid;font-family:\'Work Sans\',sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;';
  document.getElementById('tab-spots').style.cssText=base+(t==='spots'?'background:#172c1d;color:#fff;border-color:#172c1d;':'background:transparent;color:#434843;border-color:#c3c8c1;');
  document.getElementById('tab-tips').style.cssText=base+(t==='tips'?'background:#172c1d;color:#fff;border-color:#172c1d;':'background:transparent;color:#434843;border-color:#c3c8c1;');
}
function selectSpot(id){openModal(id);}
function setPackTab(t){
  document.getElementById('pack-day').style.display=t==='day'?'block':'none';
  document.getElementById('pack-multi').style.display=t==='multi'?'block':'none';
  document.getElementById('pack-firstaid').style.display=t==='firstaid'?'block':'none';
  document.getElementById('ptab-day').className='pack-tbtn'+(t==='day'?' active':'');
  document.getElementById('ptab-multi').className='pack-tbtn'+(t==='multi'?' active':'');
  document.getElementById('ptab-firstaid').className='pack-tbtn'+(t==='firstaid'?' active':'');
}


// ── QUIZ: WHAT SHOULD I HUNT? ──────────────────────────────────────────────
const QUIZ_QUESTIONS = [
