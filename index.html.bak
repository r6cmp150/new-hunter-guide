      <ellipse cx="38" cy="42" rx="18" ry="13" fill="#c0a050" opacity=".9" stroke="#5a3c18" stroke-width=".9"/>
      <!-- Long narrow muzzle -->
      <path d="M28 44 Q22 44 18 46 Q20 50 26 50 Q30 48 28 44Z" fill="#b09040" opacity=".85" stroke="#5a3c18" stroke-width=".6"/>
      <!-- Black nose -->
      <ellipse cx="19" cy="46" rx="3" ry="2" fill="#0a0804" opacity=".9"/>
      <!-- Eye -->
      <ellipse cx="32" cy="40" rx="3" ry="2.5" fill="#d4a820" opacity=".85"/>
      <ellipse cx="32" cy="40" rx="1.5" ry="2" fill="#0a0604"/>
      <!-- Large pointed ears -->
      <path d="M38 30 Q34 18 36 10 Q40 20 42 30Z" fill="#c0a050" stroke="#5a3c18" stroke-width=".8"/>
      <path d="M50 28 Q52 16 50 8 Q47 18 46 29Z" fill="#c0a050" stroke="#5a3c18" stroke-width=".8"/>
      <!-- Inner ear -->
      <path d="M39 28 Q36 20 37 14 Q40 20 41 28Z" fill="#e0b0a0" opacity=".45"/>
      <!-- Whiskers -->
      <g stroke="#7a5820" stroke-width=".7" opacity=".5">
        <line x1="24" y1="44" x2="12" y2="42"/><line x1="24" y1="47" x2="12" y2="48"/>
        <line x1="30" y1="43" x2="18" y2="40"/>
      </g>
      <ellipse cx="65" cy="79" rx="28" ry="4" fill="#3a1c06" opacity=".15"/>
    </svg>`,
  };

  const catBg = {
    'deer-elk':   'linear-gradient(160deg,#c8b050 0%,#8a6820 45%,#5a3e10 100%)',
    'bear':       'linear-gradient(160deg,#b08040 0%,#7a4e18 45%,#4a2808 100%)',
    'mountain':   'linear-gradient(160deg,#c0c0a0 0%,#8a8060 45%,#5a5030 100%)',
    'upland':     'linear-gradient(160deg,#c09050 0%,#886020 45%,#503808 100%)',
    'waterfowl':  'linear-gradient(160deg,#a0b0c0 0%,#608090 45%,#304858 100%)',
    'smallgame':  'linear-gradient(160deg,#b8a070 0%,#806040 45%,#4a3018 100%)',
  };
  const map={'deer-elk':'grid-deer-elk','bear':'grid-bear','mountain':'grid-mountain','upland':'grid-upland','waterfowl':'grid-waterfowl','smallgame':'grid-smallgame'};
  Object.entries(ANIMAL_CATEGORIES).forEach(([cat,animals])=>{
    const el=document.getElementById(map[cat]);
    if(!el)return;
    const bg = catBg[cat] || catBg['deer-elk'];
    el.innerHTML=animals.map(a=>{
      const art = animalArt[a.id] || `<div style="font-size:32px;line-height:1;filter:drop-shadow(0 2px 6px rgba(0,0,0,.6))">${a.icon}</div>`;
      return `
      <button class="animal-tile" onclick="openAnimalModal('${cat}','${a.id}')">
        <div class="at-inner" style="background:${bg}"></div>
        <div class="at-frame"></div>
        <div class="at-art">${art}</div>
        <div class="at-label">
          ${a.name}
          <span class="at-sub-label">${a.sub}</span>
        </div>
      </button>`;
    }).join('');
  });
}

// ── SPOT MODAL ─────────────────────────────────────────────────────────────
function openModalFromPin(id, screenX, screenY){
  // Set the modal sheet's transform-origin to the pin's position
  // so the slideUp animation appears to originate from the pin
  const sheet = document.querySelector('#modalOverlay .modal-sheet');
  if(sheet){
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    // Express pin position as % of viewport for transform-origin
    const ox = Math.round((screenX / vw) * 100);
    const oy = Math.round((screenY / vh) * 100);
    sheet.style.transformOrigin = `${ox}% ${oy}%`;
  }
  openModal(id);
}
function openModal(id){
  const s=SPOTS.find(x=>x.id===id);if(!s)return;
  const h=s.how,color=DEER_COLORS[s.deer];
  document.getElementById('modalTag').innerHTML=`<span style="color:${color};font-size:10px;letter-spacing:2px">${DEER_LABELS[s.deer].toUpperCase()}</span>`;
  document.getElementById('modalTitle').textContent=s.name;
  document.getElementById('modalSub').textContent=s.subname+' · '+s.gmu;
  const dirUrl=`https://www.google.com/maps/dir/?api=1&destination=${s.lat},${s.lng}&destination_place_id=${s.place_id}&travelmode=driving`;
  document.getElementById('modalBody').innerHTML=`
    <div class="msect"><div class="msect-title">📖 OVERVIEW</div><div class="msect-body">${h.overview}</div></div>
    <div class="msect"><div class="msect-title">👣 STEP BY STEP</div>${h.steps.map((st,i)=>`<div class="mstep"><div class="mstep-num">${i+1}</div><div class="mstep-text">${st}</div></div>`).join('')}</div>
    <div class="msect"><div class="msect-title">🏔️ TERRAIN</div><div class="msect-body">${h.terrain}</div></div>
    <div class="msect"><div class="msect-title">📅 BEST TIME</div><div class="msect-body">${h.bestTime}</div></div>
    <div class="msect"><div class="msect-title">🎒 GEAR</div>${h.gear.map(g=>`<div class="mgear-row"><span style="color:#4ade80;flex-shrink:0">✓</span>${g}</div>`).join('')}</div>
    <div class="mwarn">⚠️ <strong style="color:#e08080">Important:</strong> ${h.warning}</div>
    <a href="${dirUrl}" target="_blank" class="mdir-btn">🧭 Get Directions to This Spot</a>`;
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(e){if(e.target===document.getElementById('modalOverlay'))closeModalDirect();}
function closeModalDirect(){document.getElementById('modalOverlay').classList.remove('open');document.body.style.overflow='';}

// ── ANIMAL MODAL ───────────────────────────────────────────────────────────
function openAnimalModal(cat,id){
  const a=ANIMAL_CATEGORIES[cat].find(x=>x.id===id);if(!a)return;
  document.getElementById('animalModalTag').innerHTML=`<span style="color:${a.color};font-size:10px;letter-spacing:2px">🗺️ WASHINGTON STATE</span>`;
  document.getElementById('animalModalTitle').textContent=a.icon+' '+a.name;
  document.getElementById('animalModalSub').textContent=a.sub+' · Species guide & WA regulations';
  document.getElementById('animalModalBody').innerHTML=`
    <div class="msect"><div class="msect-title">📖 ABOUT THIS ANIMAL</div><div class="msect-body">${a.intro}</div></div>
    <div class="msect"><div class="msect-title">🔍 HOW TO IDENTIFY IT</div>${a.identification.map(i=>`<div class="mgear-row"><span style="color:${a.color};flex-shrink:0">•</span>${i}</div>`).join('')}</div>
    <div class="msect"><div class="msect-title">🦶 HUNTING METHODS</div>${a.huntingMethods.map(m=>`<div class="mgear-row"><span style="color:${a.color};flex-shrink:0">→</span>${m}</div>`).join('')}</div>
    <div class="msect"><div class="msect-title">🌅 BEHAVIOR</div><div class="msect-body">${a.behavior}</div></div>
    <div class="msect">
      <div class="msect-title">🔫 RECOMMENDED CALIBERS / AMMUNITION</div>
      ${a.calibers.map(c=>`
        <div class="caliber-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;gap:8px;flex-wrap:wrap">
            <div class="caliber-name">${c.name}</div>
            <span class="caliber-tag" style="background:${c.recColor}22;border:1px solid ${c.recColor}44;color:${c.recColor}">${c.rec}</span>
          </div>
          <div class="caliber-desc">${c.desc}</div>
        </div>`).join('')}
    </div>
    <div class="msect">
      <div class="msect-title" style="color:#80aaee">📋 WASHINGTON STATE REGULATIONS</div>
      <div style="background:rgba(30,50,80,.35);border:1px solid rgba(80,120,180,.25);border-radius:10px;overflow:hidden">
        ${a.waRegs.map((r,i)=>`<div class="reg-row${i===a.waRegs.length-1?' last':''}"><div class="reg-rule">${r.rule}</div><div class="reg-detail">${r.detail}</div></div>`).join('')}
      </div>
    </div>
    <div class="mwarn">⚠️ <strong style="color:#e08080">Always verify:</strong> Regulations change annually. Confirm current rules at <strong style="color:#e08080">wdfw.wa.gov/hunting/regulations</strong> before you hunt.</div>
    <div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap">
      <a href="https://fishhunt.dfw.wa.gov" target="_blank" style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;background:rgba(74,222,128,.15);border:1px solid rgba(74,222,128,.35);color:#4ade80;border-radius:10px;padding:12px;font-size:13px;text-decoration:none;font-weight:700;min-width:130px">🎫 Buy License</a>
      <a href="https://wdfw.wa.gov/hunting/regulations" target="_blank" style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;background:rgba(80,120,180,.15);border:1px solid rgba(80,120,180,.35);color:#80aaee;border-radius:10px;padding:12px;font-size:13px;text-decoration:none;font-weight:700;min-width:130px">📄 WA Regulations</a>
      <a href="https://wdfw.wa.gov/publications/02608" target="_blank" style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;background:rgba(120,80,180,.15);border:1px solid rgba(120,80,180,.35);color:#c0a0ee;border-radius:10px;padding:12px;font-size:13px;text-decoration:none;font-weight:700;min-width:130px">📋 2025 Pamphlet</a>
    </div>`;
  document.getElementById('animalModalOverlay').classList.add('open');
  document.body.style.overflow='hidden';
}
// Also used for deer tags on spot cards
function openDeerModal(deerKey){
  const catMap={'black-tail':'deer-elk','mule-deer':'deer-elk','whitetail':'deer-elk'};
  openAnimalModal(catMap[deerKey]||'deer-elk',deerKey);
}
function closeAnimalModal(e){if(e.target===document.getElementById('animalModalOverlay'))closeAnimalModalDirect();}
function closeAnimalModalDirect(){document.getElementById('animalModalOverlay').classList.remove('open');document.body.style.overflow='';}


// ── DIFFICULTY BADGE ──────────────────────────────────────────────────────
const DIFF_META = {
  'Beginner':     {color:'#4ade80', bg:'rgba(74,222,128,.15)',  border:'rgba(74,222,128,.35)',  icon:'🟢', desc:'Great for first-time hunters. Easy terrain, good road access, forgiving conditions.'},
  'Intermediate': {color:'#facc15', bg:'rgba(250,204,21,.15)',  border:'rgba(250,204,21,.35)',  icon:'🟡', desc:'Some experience helpful. Moderate terrain or conditions. A good second or third hunt.'},
  'Advanced':     {color:'#fb923c', bg:'rgba(251,146,60,.15)',  border:'rgba(251,146,60,.35)',  icon:'🟠', desc:'Challenging terrain, physical demands, or complex tactics. Rewarding for prepared hunters.'},
  'Expert':       {color:'#ef4444', bg:'rgba(239,68,68,.15)',   border:'rgba(239,68,68,.35)',   icon:'🔴', desc:'Remote, steep, or highly technical. Requires advanced skills, fitness, and experience.'},
};
function diffBadge(d){
  const m=DIFF_META[d]||DIFF_META['Intermediate'];
  return `<span class="tag diff-tag" style="background:${m.bg};border:1px solid ${m.border};color:${m.color}" title="${m.desc}">${m.icon} ${d}</span>`;
}

// ── SPOT CARD HTML ─────────────────────────────────────────────────────────
function cardHTML(s,distMi){
  const color=DEER_COLORS[s.deer],label=DEER_LABELS[s.deer],isSelected=selectedId===s.id;
  const distBadge=distMi!=null?`<div class="dist-badge"><div class="dist-num">${distMi<10?distMi.toFixed(1):Math.round(distMi)}</div><div class="dist-unit">MI AWAY</div></div>`:'';
  const pubTag=s.publicLand?`<span class="tag" style="background:rgba(74,222,128,.15);border:1px solid rgba(74,222,128,.3);color:#4ade80">PUBLIC LAND</span>`:'';
  const dirUrl=`https://www.google.com/maps/dir/?api=1&destination=${s.lat},${s.lng}&destination_place_id=${s.place_id}&travelmode=driving`;
  return `<div class="spot-card${isSelected?' selected':''}" onclick="selectSpot('${s.id}')">
    <div style="display:flex;justify-content:space-between;gap:8px;margin-bottom:6px">
      <div style="flex:1"><div class="spot-name">${s.name}</div><div class="spot-sub">${s.subname} · ${s.gmu}</div></div>${distBadge}
    </div>
    <div class="tags">
      <button class="tag-btn" onclick="event.stopPropagation();openDeerModal('${s.deer}')"><span class="tag" style="background:${color}22;border:1px solid ${color}44;color:${color}">${label} ⓘ</span></button>
      ${pubTag}
      ${diffBadge(s.difficulty)}
    </div>
    <div class="spot-summary">${s.summary}</div>
    <div class="spot-access">🚗 ${s.access}</div>
    <div class="card-btns">
      <a href="${dirUrl}" target="_blank" class="dir-btn" onclick="event.stopPropagation()">🧭 Directions</a>
      <button class="how-btn" onclick="event.stopPropagation();openModal('${s.id}')">🎯 How to Hunt This Spot</button>
    </div>
  </div>`;
}


// ── BUDGET ESTIMATOR ──────────────────────────────────────────────────────

const BUDGET_DATA = {
  // 2025 WA resident license fees (post July 1 38% increase)
  licenses: {
    'deer-elk':    { label:'Deer + Elk License', cost:117, note:'Covers both deer and elk tags for the year' },
    'deer-only':   { label:'Deer Tag Only', cost:49,  note:'Just a deer tag — good if you only want to deer hunt' },
    'small-game':  { label:'Small Game License', cost:27,  note:'Covers rabbits, squirrels, grouse, chukar, quail, HUN, and dove' },
    'turkey':      { label:'Turkey Tag (add-on)', cost:22,  note:'Added to a base license — spring turkey season' },
    'bird-migratory': { label:'Migratory Bird Permit + Authorization', cost:28, note:'Required for ducks, geese, teal, dove, brant — federal + state combined' },
    'hunter-ed':   { label:'Hunter Ed Course', cost:0, note:'Free in Washington — required if born after Jan 1, 1972. Take at hunter-ed.com' },
    'discover-pass': { label:'Discover Pass (DNR/WDFW lands)', cost:35, note:'Required to park at many public hunting access areas' },
  },

  // Gear categories — each has budget/mid/premium tiers
  gear: [
    {
      id: 'firearm',
      label: 'Firearm',
      icon: '🔫',
      options: {
        'already-own':    { label:'I already own one', cost:0, note:'No cost — make sure it is legal for the season and animal you are hunting' },
        'budget-shotgun': { label:'Buy: Budget shotgun (Mossberg 500 or Stevens)', cost:380, note:'A 12 or 20 gauge works for birds, turkey, small game, and even deer with slugs' },
        'mid-shotgun':    { label:'Buy: Mid-range shotgun (Beretta A300 or Browning BPS)', cost:750, note:'Smoother action, better fit, and more reliable than entry-level guns. Great if you plan to bird hunt seriously.' },
        'budget-rifle':   { label:'Buy: Budget rifle + scope (Savage Axis or Ruger American)', cost:550, note:'Best for deer and big game. Includes a basic 3-9x scope. Most versatile option.' },
        'mid-rifle':      { label:'Buy: Mid-range rifle + scope (Tikka, Bergara)', cost:1100, note:'Noticeably better fit, finish, and out-of-box accuracy. Worth it if you plan to hunt seriously.' },
      },
      default: 'budget-rifle',
    },
    {
      id: 'clothing',
      label: 'Hunting Clothing',
      icon: '🧥',
      options: {
        'use-what-i-have': { label:"Use what I already own", cost:0, note:'Quiet dark earth-tone or camo clothes you own can work fine — especially for birds and small game' },
        'budget': { label:'Budget camo set (jacket + pants)', cost:80, note:'Basic camo fleece or softshell from Walmart, Amazon, or Bass Pro. Functional for most WA hunting.' },
        'mid':    { label:'Mid-range layering system', cost:280, note:'Quieter fabrics, better rain resistance. Makes a real difference in wet western WA.' },
        'quality':{ label:'Quality system (First Lite, King\'s, ScentLok)', cost:600, note:'Designed for serious hunters. Scent control, waterproofing, and quiet movement in one system.' },
      },
      default: 'budget',
    },
    {
      id: 'boots',
      label: 'Boots',
      icon: '🥾',
      options: {
        'own': { label:'I have waterproof boots already', cost:0, note:'Any waterproof boots with ankle support will work — rubber boots are ideal for wet western WA' },
        'budget': { label:'Budget hunting boots ($80–130)', cost:100, note:'Irish Setter Wingshooter, LaCrosse Alphaburly rubber — functional for most conditions' },
        'mid':    { label:'Mid-range boots ($150–250)', cost:200, note:'Much better support and waterproofing. Worth it for long days on rough terrain.' },
        'quality':{ label:'Quality boots ($300+) (Kenetrek, Danner)', cost:380, note:'Built for serious mountain terrain and full seasons of hard use. Lasts 5–10 years.' },
      },
      default: 'budget',
    },
    {
      id: 'optics',
      label: 'Binoculars',
      icon: '🔭',
      options: {
        'skip': { label:'Skip for now — not needed for my hunt', cost:0, note:'Fine for dense timber bird hunting. Not ideal for open-country deer and elk.' },
        'budget': { label:'Budget binos ($60–120) (Vortex Crossfire)', cost:90, note:'Good enough to spot deer at 200 yards. Acceptable for a first season.' },
        'mid':    { label:'Mid-range binos ($200–400) (Vortex Diamondback)', cost:280, note:'Much better image clarity and light transmission. Worth it for open-country hunting.' },
        'quality':{ label:'Quality binos ($500+) (Vortex Viper, Maven)', cost:550, note:'The kind serious hunters use. Edge-to-edge clarity, built to last decades.' },
      },
      default: 'budget',
    },
    {
      id: 'ammo',
      label: 'Ammunition or Shells',
      icon: '🎯',
      options: {
        'minimal':  { label:'Minimal — 20 rounds to sight in + 2 boxes hunting', cost:60, note:'Enough for a basic deer or big game rifle season' },
        'standard': { label:'Standard — practice + hunting supply', cost:120, note:'Enough to practice at the range plus a full hunting season' },
        'birds':    { label:'Upland birds — 4 boxes of shells', cost:80, note:'Pheasant, grouse, or quail. Figure 2–4 boxes of #5 or #6 shot.' },
        'waterfowl':{ label:'Waterfowl — non-toxic shells (steel/bismuth)', cost:110, note:'Non-toxic shot is federally required for all waterfowl. More expensive than standard shot.' },
      },
      default: 'standard',
    },
    {
      id: 'extras',
      label: 'Extras',
      icon: '🎒',
      options: {
        'minimal': { label:'Bare minimum — knife + headlamp', cost:40, note:'A $25 folding knife and a headlamp are all you strictly need beyond the basics' },
        'practical': { label:'Practical kit — knife, daypack, orange vest, calls', cost:130, note:'Everything for a comfortable day hunt. Hunter orange vest ($20), day pack ($50), knife ($30), calls ($30).' },
        'full': { label:'Full kit — add rangefinder, game bags, trekking poles', cost:320, note:'For the hunter who wants to be properly equipped from day one. Rangefinder alone is $150–200.' },
      },
      default: 'practical',
    },
    {
      id: 'processing',
      label: 'Game Processing (if successful)',
      icon: '🍖',
      options: {
        'diy': { label:'Do it yourself — free (learn online)', cost:0, note:'YouTube has excellent tutorials. You need a sharp knife and a cool place to hang the meat.' },
        'butcher': { label:'Take to a butcher ($150–400 for deer)', cost:250, note:'Professional butcher will process, wrap, and freeze your deer or elk. Easiest option for beginners.' },
        'skip': { label:'Not applicable — hunting birds or small game', cost:0, note:'Small game and birds are processed at home — easy to learn and no butcher needed.' },
      },
      default: 'diy',
    },
  ],

  // Hunter Ed note
  hunterEdNote: 'Hunter Education is FREE in Washington and required if you were born after January 1, 1972. Take the online course at hunter-ed.com — it takes about 8–10 hours and you finish with an in-person field day.',
};

// State for current selections
let budgetSelections = {};

function initBudget(){
  // Set defaults
  BUDGET_DATA.gear.forEach(g => { budgetSelections[g.id] = g.default; });
  budgetSelections.licenseType = 'deer-only';
  budgetSelections.discoverPass = true;
  renderBudget();
}

function renderBudget(){
  const f = document.getElementById('budgetForm');
  if(!f) return;
  let html = '';

  // ── License section ──
  html += `<div style="margin-bottom:22px">
    <div style="font-size:10px;letter-spacing:2.5px;color:#b48c3c;margin-bottom:10px">📋 LICENSES & TAGS</div>`;

  const licOpts = [
    { val:'small-game', label:'Small game / birds only', sub:'Grouse, pheasant, rabbit, quail, chukar, dove' },
    { val:'deer-only',  label:'Deer (one tag)', sub:'Modern firearm deer season' },
    { val:'deer-elk',   label:'Deer + Elk package', sub:'Both tags, best value if hunting both' },
    { val:'bird-migratory', label:'Ducks, geese, or other waterfowl', sub:'Requires federal + state migratory bird permits' },
    { val:'turkey',     label:'Turkey only (spring season)', sub:'Add-on tag to a base license' },
  ];
  html += `<div style="font-size:13px;color:#8a9a7a;margin-bottom:8px">What do you want to hunt?</div>`;
  html += `<div style="display:flex;flex-direction:column;gap:7px;margin-bottom:12px">`;
  licOpts.forEach(o => {
    const sel = budgetSelections.licenseType === o.val;
    html += `<button onclick="budgetSet('licenseType','${o.val}')" style="text-align:left;padding:11px 13px;border-radius:10px;border:1.5px solid ${sel?'rgba(180,140,60,.6)':'rgba(255,255,255,.1)'};background:${sel?'rgba(180,140,60,.15)':'rgba(255,255,255,.03)'};color:${sel?'#f0e4c0':'#8a9a7a'};font-family:inherit;cursor:pointer;width:100%">
      <div style="font-size:13px;font-weight:${sel?'700':'400'}">${o.label}</div>
      <div style="font-size:11px;color:#5a6a50;margin-top:2px">${o.sub}</div>
    </button>`;
  });
  html += `</div>`;

  const dpSel = budgetSelections.discoverPass;
  html += `<label style="display:flex;align-items:center;gap:10px;padding:10px 13px;border-radius:10px;border:1.5px solid ${dpSel?'rgba(180,140,60,.5)':'rgba(255,255,255,.1)'};background:${dpSel?'rgba(180,140,60,.1)':'rgba(255,255,255,.03)'};cursor:pointer">
    <input type="checkbox" ${dpSel?'checked':''} onchange="budgetToggle('discoverPass')" style="width:16px;height:16px;accent-color:#b48c3c;flex-shrink:0">
    <div><div style="font-size:13px;color:#e8dcc8">Add Discover Pass ($35)</div><div style="font-size:11px;color:#5a6a50;margin-top:1px">Required to park at most DNR and WDFW hunting access areas</div></div>
  </label>`;
  html += `</div>`;

  // ── Gear sections ──
  html += `<div style="margin-bottom:22px">
    <div style="font-size:10px;letter-spacing:2.5px;color:#b48c3c;margin-bottom:10px">🎒 GEAR</div>`;

  BUDGET_DATA.gear.forEach(g => {
    const cur = budgetSelections[g.id];
    const curOpt = g.options[cur];
    html += `<div style="margin-bottom:14px">
      <div style="font-size:13px;color:#e8dcc8;font-weight:600;margin-bottom:7px">${g.icon} ${g.label}</div>
      <div style="display:flex;flex-direction:column;gap:6px">`;
    Object.entries(g.options).forEach(([val, opt]) => {
      const sel = cur === val;
      html += `<button onclick="budgetSet('${g.id}','${val}')" style="text-align:left;padding:10px 13px;border-radius:10px;border:1.5px solid ${sel?'rgba(180,140,60,.55)':'rgba(255,255,255,.09)'};background:${sel?'rgba(180,140,60,.13)':'rgba(255,255,255,.03)'};color:${sel?'#f0e4c0':'#8a9a7a'};font-family:inherit;cursor:pointer;width:100%;display:flex;justify-content:space-between;align-items:flex-start;gap:10px">
        <div style="flex:1">
          <div style="font-size:13px;font-weight:${sel?'700':'400'}">${opt.label}</div>
          <div style="font-size:11px;color:#5a6a50;margin-top:2px;line-height:1.4">${opt.note}</div>
        </div>
        <div style="font-size:13px;font-weight:700;color:${sel?'#d4a840':'#4a5a40'};white-space:nowrap;margin-top:1px">${opt.cost===0?'Free':'$'+opt.cost}</div>
      </button>`;
    });
    html += `</div></div>`;
  });
  html += `</div>`;

  f.innerHTML = html;
  renderBudgetResults();
}

function budgetSet(key, val){
  budgetSelections[key] = val;
  renderBudget();
}
function budgetToggle(key){
  budgetSelections[key] = !budgetSelections[key];
  renderBudget();
}

function renderBudgetResults(){
  const r = document.getElementById('budgetResults');
  if(!r) return;

  // Calculate totals
  const lic = BUDGET_DATA.licenses[budgetSelections.licenseType];
  const licCost = lic ? lic.cost : 0;
  const dpCost = budgetSelections.discoverPass ? 35 : 0;

  let gearTotal = 0;
  const lineItems = [];

  // License items
  lineItems.push({ cat:'Licenses', label: lic ? lic.label : 'License', cost: licCost, note: lic ? lic.note : '' });
  if(budgetSelections.discoverPass) lineItems.push({ cat:'Licenses', label:'Discover Pass', cost:35, note:'Required for most WA public land parking' });
  lineItems.push({ cat:'Licenses', label:'Hunter Education', cost:0, note:'Free in WA — required if born after Jan 1 1972' });

  // Gear items
  BUDGET_DATA.gear.forEach(g => {
    const sel = budgetSelections[g.id];
    const opt = g.options[sel];
    if(opt && opt.cost > 0){
      lineItems.push({ cat:'Gear', label: g.label + ' — ' + opt.label.split('(')[0].trim(), cost: opt.cost, note: opt.note });
      gearTotal += opt.cost;
    }
  });

  const licTotal = licCost + dpCost;
  const grandTotal = licTotal + gearTotal;

  // Budget tier label
  let tier, tierColor, tierDesc;
  if(grandTotal < 300){
    tier = 'Bare Minimum Start'; tierColor = '#4ade80';
    tierDesc = 'This is about as low as it gets. Totally doable — many successful hunters started with exactly this.';
  } else if(grandTotal < 700){
    tier = 'Practical Beginner Budget'; tierColor = '#facc15';
    tierDesc = 'A realistic, comfortable first-year setup. You will have everything you need without overspending.';
  } else if(grandTotal < 1400){
    tier = 'Well-Equipped Hunter'; tierColor = '#fb923c';
    tierDesc = 'You will be well-prepared from day one. Gear at this level lasts many seasons.';
  } else {
    tier = 'Fully Kitted Out'; tierColor = '#ef4444';
    tierDesc = 'Top-end first-year investment. Gear at this level is what serious hunters use for decades.';
  }

  let html = `
  <div style="background:rgba(180,140,60,.1);border:1.5px solid rgba(180,140,60,.4);border-radius:14px;padding:18px;margin-bottom:16px;margin-top:4px">
    <div style="font-size:10px;letter-spacing:2px;color:#b48c3c;margin-bottom:4px">YOUR ESTIMATED FIRST-YEAR BUDGET</div>
    <div style="font-size:36px;font-weight:700;color:#f0e4c0;margin-bottom:2px">$${grandTotal.toLocaleString()}</div>
    <div style="font-size:13px;font-weight:700;color:${tierColor};margin-bottom:6px">${tier}</div>
    <div style="font-size:12px;color:#6a7a60;line-height:1.6">${tierDesc}</div>
  </div>

  <div style="display:flex;gap:8px;margin-bottom:16px">
    <div style="flex:1;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:10px;padding:12px;text-align:center">
      <div style="font-size:18px;font-weight:700;color:#b48c3c">$${licTotal}</div>
      <div style="font-size:11px;color:#5a6a50;margin-top:2px">Licenses & Tags</div>
    </div>
    <div style="flex:1;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:10px;padding:12px;text-align:center">
      <div style="font-size:18px;font-weight:700;color:#b48c3c">$${gearTotal}</div>
      <div style="font-size:11px;color:#5a6a50;margin-top:2px">Gear</div>
    </div>
    <div style="flex:1;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:10px;padding:12px;text-align:center">
      <div style="font-size:18px;font-weight:700;color:#4ade80">$0</div>
      <div style="font-size:11px;color:#5a6a50;margin-top:2px">Year 2+</div>
    </div>
  </div>`;

  // Line items breakdown
  const cats = ['Licenses','Gear'];
  cats.forEach(cat => {
    const items = lineItems.filter(l => l.cat === cat);
    if(!items.length) return;
    html += `<div style="margin-bottom:14px">
      <div style="font-size:10px;letter-spacing:2px;color:#5a6a50;margin-bottom:8px">${cat.toUpperCase()}</div>`;
    items.forEach(item => {
      html += `<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.05)">
        <div style="flex:1">
          <div style="font-size:13px;color:#e8dcc8">${item.label}</div>
          <div style="font-size:11px;color:#5a6a50;margin-top:1px;line-height:1.4">${item.note}</div>
        </div>
        <div style="font-size:13px;font-weight:700;color:${item.cost===0?'#4ade80':'#d4a840'};white-space:nowrap">${item.cost===0?'Free':'$'+item.cost}</div>
      </div>`;
    });
    html += `</div>`;
  });

  // Year 2 savings note
  html += `<div style="background:rgba(74,222,128,.07);border:1px solid rgba(74,222,128,.2);border-radius:10px;padding:12px;margin-bottom:14px">
    <div style="font-size:12px;font-weight:700;color:#4ade80;margin-bottom:4px">📅 Year 2 and beyond</div>
    <div style="font-size:12px;color:#6a7a60;line-height:1.6">Your gear is already paid for. Year 2 costs drop to just <strong style="color:#e8dcc8">$${licTotal + 50}–$${licTotal + 100}</strong> for a new license, tags, and ammo. The startup cost is the most expensive part.</div>
  </div>`;

  // Money-saving tips
  html += `<div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:14px;margin-bottom:14px">
    <div style="font-size:12px;font-weight:700;color:#b48c3c;margin-bottom:8px">💡 Ways to spend less</div>
    <div style="font-size:12px;color:#6a7a60;line-height:1.7">
      • <strong style="color:#c0b090">Facebook Marketplace</strong> — used rifles, shotguns, and boots sell for 30–50% off. Great way to start cheap.<br>
      • <strong style="color:#c0b090">Skip the binoculars</strong> — not needed for timber bird hunting or small game. Add them in year 2.<br>
      • <strong style="color:#c0b090">Process your own game</strong> — YouTube can teach you to butcher a deer in an afternoon. Saves $150–250 every season.<br>
      • <strong style="color:#c0b090">Start with small game or birds</strong> — a $27 small game license and a basic shotgun is the lowest-cost entry into hunting in WA.
    </div>
  </div>`;

  html += `<a href="https://fishhunt.dfw.wa.gov" target="_blank" style="display:block;width:100%;padding:13px;border-radius:10px;background:rgba(180,140,60,.18);border:1px solid rgba(180,140,60,.4);color:#d4a840;font-size:13px;font-weight:700;text-align:center;text-decoration:none;margin-bottom:6px">🎫 Buy Your WA License at fishhunt.dfw.wa.gov →</a>`;

  r.style.display = 'block';
  r.innerHTML = html;
}

buildAnimalGrids();
buildFilterDrawer();

// ── NAV HELPERS ──────────────────────────────────────────────────────────────
function homePage() {
  document.getElementById('home-page').classList.remove('hidden');
  document.getElementById('app-shell').classList.remove('active');
  document.querySelectorAll('.nb').forEach(b => b.classList.remove('active'));
  document.getElementById('nav-home').classList.add('active');
}

function enterApp(screenName) {
  document.getElementById('home-page').classList.add('hidden');
  document.getElementById('app-shell').classList.add('active');
  showScreen(screenName);
}

function heroSearchGo() {
  const q = document.getElementById('heroSearchInput').value.trim();
  enterApp('near');
  if (q) {
    // trigger existing search logic after transition
    setTimeout(() => homeSearchGo(), 50);
  }
}

// Patch homeSearchGo to read from heroSearchInput if no home input
const _origHomeSearchGo = window.homeSearchGo;
window.homeSearchGo = async function(overrideQ) {
  const q = overrideQ || (document.getElementById('homeSearch') ? document.getElementById('homeSearch').value.trim() : '') || document.getElementById('heroSearchInput').value.trim();
  if (!q) { enterApp('browse'); return; }
  // rest of logic below handled by original code reading homeSearch
  document.getElementById('home-page').classList.add('hidden');
  document.getElementById('app-shell').classList.add('active');
  showScreen('near');
  document.getElementById('gpsLoading').style.display='flex';
  document.getElementById('gpsSuccess').style.display='none';
  document.getElementById('gpsError').style.display='none';
  try {
    const r = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q+' Washington')}&format=json&limit=1`);
    const d = await r.json();
    if(!d.length) throw new Error('Location not found. Try a city name or zip code.');
    userLat = parseFloat(d[0].lat);
    userLng = parseFloat(d[0].lon);
    initNearMap();
    renderNearMap();
    document.getElementById('gpsLoading').style.display='none';
    document.getElementById('gpsSuccess').style.display='flex';
  } catch(e) {
    document.getElementById('gpsLoading').style.display='none';
    showGPSErr(e.message||'Search failed. Try again.');
  }
};
</script>

</body>
</html>